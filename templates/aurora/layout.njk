<!DOCTYPE html>
<html lang="{{ language }}" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#f2f0eb">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="{{ appName }}">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <title>{{ title }} — {{ appName }}</title>
  <script nonce="{{ cspNonce }}">
(function(){try{var s=localStorage.getItem('gc-theme-mode');var t=s||(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',t);}catch(e){document.documentElement.setAttribute('data-theme','dark');}})();
</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/pro.css?v={{ appVersion }}">
  <link rel="stylesheet" href="/css/aurora.css?v={{ appVersion }}">
  {% block head %}{% endblock %}
</head>
<body>

<div class="app">
  <div class="app-brand">
    <span class="mark"><svg viewBox="0 0 24 24" fill="none"><path d="M12 2 4 6v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6l-8-4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m8.5 12 2.5 2.5L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
    <span class="nm">{{ appName }}<br><small>{{ baseUrl | replace("https://","") | replace("http://","") }}</small></span>
  </div>
  {% include theme + "/partials/topbar.njk" %}
  {% include theme + "/partials/sidebar.njk" %}
  <div class="sidebar-overlay" id="sidebar-overlay"></div>
  <main class="main">
    {% if flash.success %}<div class="flash flash-success">{{ flash.success }}</div>{% endif %}
    {% if flash.error %}<div class="flash flash-error">{{ flash.error }}</div>{% endif %}
    {% block content %}{% endblock %}
  </main>
</div>
{% include theme + "/partials/bottomnav.njk" %}
{% include theme + "/partials/fab.njk" %}

