<div class="modal-overlay" id="sh-connect-modal" style="display:none">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title">{{ t('smarthome.connect.title') }}</div>
      <button class="modal-close" onclick="document.getElementById('sh-connect-modal').style.display='none'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">{{ t('smarthome.connect.name') }}</label>
        <input class="form-input" id="sh-c-name" type="text" value="Phoscon-Gateway">
      </div>
      <div class="form-group">
        <label class="form-label">{{ t('smarthome.connect.route') }}</label>
        <select class="form-select" id="sh-c-route"></select>
        <span class="form-hint">{{ t('smarthome.connect.route_hint') }}</span>
      </div>
      <div class="form-group">
        <label class="form-label">{{ t('smarthome.connect.apikey_optional') }}</label>
        <input class="form-input" id="sh-c-key" type="text" placeholder="{{ t('smarthome.connect.apikey_ph') }}">
        <span class="form-hint">{{ t('smarthome.connect.apikey_hint') }}</span>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" onclick="document.getElementById('sh-connect-modal').style.display='none'">{{ t('common.cancel') }}</button>
      <button class="btn btn-primary" id="sh-c-submit">{{ t('smarthome.connect.acquire') }}</button>
    </div>
  </div>
</div>
