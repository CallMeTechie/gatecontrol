{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.routing') }}</div>
    <h1 class="page-title">{{ t('gateway_pools.title') }}</h1>
    <p class="page-sub">{{ t('gateway_pools.subtitle') }}</p>
  </div>
  <div class="page-actions">
    {% if not license.features.gateway_pools %}
    <span class="feature-lock"><svg viewBox="0 0 24 24" width="14" height="14" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2"/></svg>{{ t('common.pro') }}</span>
    {% endif %}
    <button id="btn-migrate-routes" class="btn btn-ghost btn-sm">{{ t('gateway_pools.migrate_routes') }}</button>
    <button id="btn-create-pool" class="btn btn-primary"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>{{ t('gateway_pools.create') }}</button>
  </div>
</div>

<div class="grid">
  {% for pool in pools %}
  <div class="card span6">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="5" rx="8" ry="3" stroke="currentColor" stroke-width="2"/><path d="M4 5v14c0 1.7 3.6 3 8 3s8-1.3 8-3V5M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3" stroke="currentColor" stroke-width="2"/></svg></span>
      {{ pool.name }}
      <span class="card-sub"><span class="pool-mode-badge pool-mode-{{ pool.mode }}">{{ t('gateway_pools.mode_' + pool.mode) }}</span></span>
    </div>
    <div class="kv">
      {% for m in pool.members %}
        {% if loop.first %}
        <div class="row">
          <span class="k">{{ t('gateway_pools.active_member') }}</span>
          <span class="v">{% for p in gatewayPeers %}{% if p.id == m.peer_id %}{{ p.name }}{% endif %}{% endfor %}<span class="tag tag-green tag-dot" style="margin-left:6px"></span></span>
        </div>
        {% endif %}
      {% endfor %}
      {% if pool.members | length > 1 %}
      <div class="row">
        <span class="k">{{ t('gateway_pools.standby') }}</span>
        <span class="v">{% for m in pool.members %}{% if not loop.first %}{% for p in gatewayPeers %}{% if p.id == m.peer_id %}{{ p.name }}{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}{% endif %}{% endfor %}</span>
      </div>
      {% endif %}
      <div class="row">
        <span class="k">{{ t('gateway_pools.failback_cooldown') }}</span>
        <span class="v">{{ pool.failback_cooldown_s }}s</span>
      </div>
      {% if pool.mode == 'load_balancing' and pool.lb_policy %}
      <div class="row">
        <span class="k">{{ t('gateway_pools.lb_policy') }}</span>
        <span class="v">{{ t('gateway_pools.lb_policy_' + pool.lb_policy) }}</span>
      </div>
      {% endif %}
    </div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn btn-sm btn-ghost btn-edit-pool" data-pool-id="{{ pool.id }}">{{ t('gateway_pools.edit') }}</button>
      <button class="btn btn-sm btn-danger btn-delete-pool" data-pool-id="{{ pool.id }}">{{ t('gateway_pools.delete') }}</button>
    </div>
  </div>
  {% else %}
  <div class="card span12" style="text-align:center;color:var(--text-3);padding:40px">{{ t('gateway_pools.empty') }}</div>
  {% endfor %}

  <!-- Preset Templates card -->
  <div class="card span6">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3v18M3 12h18" stroke="currentColor" stroke-width="2"/></svg></span>
      {{ t('gateway_pools.preset_templates') }}
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px">
      <button class="btn btn-ghost btn-block btn-cooldown-preset" data-preset-i18n="gateway_pools.preset_lxc" data-preset-value="60">LXC</button>
      <button class="btn btn-ghost btn-block btn-cooldown-preset" data-preset-i18n="gateway_pools.preset_linux_vm" data-preset-value="180">Linux VM</button>
      <button class="btn btn-ghost btn-block btn-cooldown-preset" data-preset-i18n="gateway_pools.preset_proxmox" data-preset-value="600">Proxmox</button>
      <button class="btn btn-ghost btn-block btn-cooldown-preset" data-preset-i18n="gateway_pools.preset_nas" data-preset-value="900">Synology NAS</button>
      <button class="btn btn-ghost btn-block btn-cooldown-preset" data-preset-i18n="gateway_pools.preset_windows" data-preset-value="1800">Windows</button>
      <button class="btn btn-ghost btn-block btn-cooldown-preset" data-preset-i18n="gateway_pools.preset_docker" data-preset-value="30">Docker</button>
    </div>
  </div>
</div>

<!-- Form modal (Aurora classes) -->
<div id="pool-form-modal" class="modal-overlay" style="display:none">
  <div class="modal modal-wide">
    <div class="modal-head">
      <span class="mi"><svg viewBox="0 0 24 24" fill="none" width="17" height="17"><ellipse cx="12" cy="5" rx="8" ry="3" stroke="currentColor" stroke-width="2"/><path d="M4 5v14c0 1.7 3.6 3 8 3s8-1.3 8-3V5M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3" stroke="currentColor" stroke-width="2"/></svg></span>
      <h2 class="modal-title" id="pool-form-title">{{ t('gateway_pools.create') }}</h2>
      <button class="modal-close" id="btn-cancel-pool">&times;</button>
    </div>
    <form id="pool-form" class="modal-body">
      <input type="hidden" name="id">

      <div class="pool-form-grid">
        <div class="pool-form-col">
          <div class="form-group">
            <label class="form-label">{{ t('gateway_pools.name') }}</label>
            <input type="text" name="name" class="form-input" required>
          </div>

          <div class="form-group">
            <label class="form-label">{{ t('gateway_pools.mode') }}</label>
            <select name="mode" class="form-input">
              <option value="failover">{{ t('gateway_pools.mode_failover') }}</option>
              {% if license.features.gateway_pool_load_balancing %}
              <option value="load_balancing">{{ t('gateway_pools.mode_load_balancing') }}</option>
              {% else %}
              <option value="load_balancing" disabled>{{ t('gateway_pools.mode_load_balancing') }} ({{ t('gateway_pools.license_locked_lb') }})</option>
              {% endif %}
            </select>
          </div>

          <div class="form-group lb-policy-row" style="display:none">
            <label class="form-label">{{ t('gateway_pools.lb_policy') }}</label>
            <select name="lb_policy" class="form-input">
              <option value="round_robin">{{ t('gateway_pools.lb_policy_round_robin') }}</option>
              <option value="least_conn">{{ t('gateway_pools.lb_policy_least_conn') }}</option>
              <option value="ip_hash">{{ t('gateway_pools.lb_policy_ip_hash') }}</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">{{ t('gateway_pools.failback_cooldown') }} (s)</label>
            <div style="display:flex;gap:8px">
              <select id="cooldown-preset" class="form-input" style="flex:2"></select>
              <input type="number" name="failback_cooldown_s" class="form-input" min="0" required style="flex:1">
            </div>
            <div class="form-hint">{{ t('gateway_pools.failback_cooldown_help') }}</div>
          </div>

          <div class="form-group">
            <label class="form-label">{{ t('gateway_pools.outage_message') }}</label>
            <textarea name="outage_message" class="form-input" rows="2"></textarea>
          </div>
        </div>

        <div class="pool-form-col pool-members-col">
          <label class="form-label">{{ t('gateway_pools.members') }}</label>
          <div class="form-hint" style="margin-bottom:8px">{{ t('gateway_pools.priority_help') }}</div>
          <div id="pool-members" class="pool-members-list" data-empty-text="{{ t('gateway_pools.no_members_yet') }}"></div>
          <div class="add-member-row" style="display:flex;gap:8px;align-items:flex-end;margin-top:12px">
            <div style="flex:1;min-width:0">
              <label class="form-label" style="font-size:11px">Gateway</label>
              <select id="new-member-peer" class="form-input" data-all-empty-text="{{ t('gateway_pools.no_more_gateways') }}">
                {% for p in gatewayPeers %}<option value="{{ p.id }}">{{ p.name }}</option>{% endfor %}
              </select>
            </div>
            <button type="button" id="btn-add-member" class="btn btn-sm">{{ t('gateway_pools.add') }}</button>
          </div>
        </div>
      </div>

      <div class="modal-foot">
        <button type="button" class="btn" id="btn-cancel-pool-footer">{{ t('common.cancel') }}</button>
        <button type="submit" class="btn btn-primary">{{ t('common.save') }}</button>
      </div>
    </form>
  </div>
</div>

<!-- Migration modal (Aurora classes) -->
<div id="pool-migrate-modal" class="modal-overlay" style="display:none">
  <div class="modal">
    <div class="modal-head">
      <h2 class="modal-title">{{ t('gateway_pools.migrate_routes') }}</h2>
      <button class="modal-close" id="btn-migrate-cancel">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group" id="migrate-mode-group">
        <label class="form-label">{{ t('gateway_pools.migrate_mode') }}</label>
        <label><input type="radio" name="migrate-mode" value="pool" checked> {{ t('gateway_pools.migrate_mode_pool') }}</label>
        <label><input type="radio" name="migrate-mode" value="relocate"> {{ t('gateway_pools.migrate_mode_relocate') }}</label>
      </div>
      <div id="migrate-routes-list"></div>
      <div class="modal-foot">
        <button type="button" class="btn" id="btn-migrate-cancel-footer">{{ t('common.cancel') }}</button>
        <button type="button" class="btn btn-primary" id="btn-migrate-submit">OK</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/gatewayPools.js?v={{ appVersion }}"></script>
{% endblock %}
