{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('dns.eyebrow') }}</div>
    <h1 class="page-title">{{ t('dns.title') }}</h1>
    <p class="page-sub">{{ t('dns.subtitle') }}</p>
  </div>
  <div class="page-actions">
    <span class="feature-lock">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2"/></svg>
      {{ t('dns.feature_pro') }}
    </span>
    <button class="btn btn-ghost" id="btn-dns-reload">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
      {{ t('common.reload') }}
    </button>
  </div>
</div>

{# ── Hidden JS-contract IDs (stat + config sections hidden in Aurora) ─── #}
{# dns-stat-* are null-checked in dns.js (if (!node) return) so safe to omit,   #}
{# but kept hidden for forward-compat and robustness.                             #}
<span id="dns-stat-total" hidden>0</span>
<span id="dns-stat-resolved" hidden>0</span>
<span id="dns-stat-auto" hidden>0</span>
<span id="dns-stat-stale" hidden>0</span>
<span id="dns-status-badge" hidden></span>
<span id="dns-domain" hidden></span>
<span id="dns-hosts-path" hidden></span>
<span id="dns-mtime" hidden></span>
{# Static-tbody: Aurora renderStatic() is guarded (isAurora() returns early),    #}
{# but the element must exist so the JS getElementById doesn't throw.             #}
<table hidden><tbody id="dns-static-tbody"></tbody></table>

{# ── Search toolbar ──────────────────────────────────────────────────────── #}
<div class="toolbar">
  <div class="search-box">
    <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m20 20-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    <input type="search" id="dns-peer-search" placeholder="{{ t('common.search') }}">
  </div>
</div>

{# ── Records table (unified: static + peer) ──────────────────────────── #}
<div class="grid">
  <div class="card span12">
    <div class="card-title">{{ t('dns.peer_records') }}</div>
    <table class="data-table">
      <thead>
        <tr>
          <th>{{ t('dns.hostname') }}</th>
          <th>{{ t('dns.record_type') }}</th>
          <th>{{ t('dns.ip') }}</th>
        </tr>
      </thead>
      <tbody id="dns-peer-tbody">
        <tr><td colspan="3" style="text-align:center;color:var(--text-3);padding:20px">{{ t('common.loading') }}</td></tr>
      </tbody>
    </table>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/dns.js?v={{ appVersion }}"></script>
{% endblock %}
