{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.routing') }}</div>
    <h1 class="page-title">{{ t('rdp.title') }}</h1>
    <p class="page-sub" id="rdp-subtitle">{{ t('rdp.subtitle', { count: '0' }) }}</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" id="btn-add-rdp" {% if rdpLocked %}disabled{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('rdp.add') }}
    </button>
  </div>
</div>

{% if rdpLocked %}
<div class="alert alert-warning" style="margin-bottom:16px">
  {{ t('error.license.feature_not_available') }}
  <a href="https://callmetechie.de/products/gatecontrol/pricing" target="_blank" style="margin-left:8px;font-weight:600">Upgrade</a>
</div>
{% endif %}

{# -- Stats Cards: hidden in Aurora but kept for JS null-check safety --------- #}
{# setStatValue() null-checks getElementById; hidden keeps HTML valid & IDs reachable #}
{% set rdpLocked = not license.hasFeature('remote_desktop') %}
<div id="rdp-stats" hidden>
  <span id="rdp-stat-total">0</span>
  <span id="rdp-stat-online"><span class="stat-dot stat-dot-green"></span>0</span>
  <span id="rdp-stat-offline"><span class="stat-dot stat-dot-red"></span>0</span>
  <span id="rdp-stat-sessions"><span class="stat-dot stat-dot-blue"></span>0</span>
  <span id="rdp-stat-maintenance"><span class="stat-dot stat-dot-amber"></span>0</span>
  <span id="rdp-stat-rotation"><span class="stat-dot stat-dot-purple"></span>0</span>
</div>

{# -- Filter bar: hidden in Aurora; IDs kept for JS (view/status-filter/search) -- #}
<div id="rdp-filterbar" hidden>
  <div class="input-wrap">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="search" id="rdp-search" placeholder="{{ t('rdp.search') }}">
  </div>
  <div class="btn-group" id="rdp-view-toggle">
    <button class="btn btn-ghost btn-sm active" data-view="grid" title="{{ t('rdp.view_grid') }}">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    </button>
    <button class="btn btn-ghost btn-sm" data-view="list" title="{{ t('rdp.view_list') }}">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    </button>
  </div>
  <div class="btn-group" id="rdp-status-filter">
    <button class="btn btn-ghost btn-sm active" data-filter="all">{{ t('rdp.filter_all') }}</button>
    <button class="btn btn-ghost btn-sm" data-filter="online">{{ t('rdp.filter_online') }}</button>
    <button class="btn btn-ghost btn-sm" data-filter="offline">{{ t('rdp.filter_offline') }}</button>
  </div>
</div>

{# -- VM Grid / List ----------------------------------------- #}
<div id="rdp-grid">
  <div style="font-size:13px;color:var(--muted);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
</div>

{# -- Create/Edit Modal (Wizard) ----------------------------- #}
<div class="modal-overlay" id="rdp-modal-overlay" style="display:none">
  <div id="rdp-modal" class="modal modal-xl modal-wizard">

    {# Sticky Header with wizard progress #}
    <div class="modal-head wiz-head">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px">
        <div style="min-width:0;flex:1">
          <h2 class="modal-title" id="rdp-modal-title">{{ t('rdp.wizard.title_create') }}</h2>
          <div style="font-size:12px;color:var(--muted);margin-top:4px;display:flex;align-items:center;gap:8px">
            <span id="rdp-modal-subtitle" style="font-family:var(--font-mono);font-size:11px;color:var(--faint)"></span>
            <span style="color:var(--faint)">·</span>
            <strong id="rdp-modal-steptitle" style="color:var(--text-1);font-weight:600"></strong>
          </div>
        </div>
        <button class="icon-btn" id="rdp-modal-close" style="width:32px;height:32px;flex-shrink:0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      {# Step indicator: numbered circles connected by a line #}
      <div id="rdp-wizard-steps" style="display:flex;align-items:center;margin-top:14px;gap:0">
        <div class="rdp-step-dot" data-pill="1" data-step-key="connection"
             data-label="{{ t('rdp.wizard.step_connection') }}"
             title="1 · {{ t('rdp.wizard.step_connection') }}">1</div>
        <div class="rdp-step-line" data-step-key="auth"></div>
        <div class="rdp-step-dot" data-pill="2" data-step-key="auth"
             data-label="{{ t('rdp.wizard.step_auth') }}"
             title="2 · {{ t('rdp.wizard.step_auth') }}">2</div>
        <div class="rdp-step-line" data-step-key="experience"></div>
        <div class="rdp-step-dot" data-pill="3" data-step-key="experience"
             data-label="{{ t('rdp.wizard.step_experience') }}"
             title="3 · {{ t('rdp.wizard.step_experience') }}">3</div>
        <div class="rdp-step-line" data-step-key="security"></div>
        <div class="rdp-step-dot" data-pill="4" data-step-key="security"
             data-label="{{ t('rdp.wizard.step_security') }}"
             title="4 · {{ t('rdp.wizard.step_security') }}">4</div>
        <div class="rdp-step-line" data-step-key="wol"></div>
        <div class="rdp-step-dot" data-pill="5" data-step-key="wol"
             data-label="WoL &amp; Tags"
             title="5 · WoL &amp; Tags">5</div>
        <div class="rdp-step-line" data-step-key="access"></div>
        <div class="rdp-step-dot" data-pill="6" data-step-key="access"
             data-label="{{ t('rdp.wizard.step_access') }}"
             title="6 · {{ t('rdp.wizard.step_access') }}">6</div>
      </div>
    </div>

    {# Scrollable Body #}
    <form id="rdp-form">
      <input type="hidden" id="rdp-edit-id">
      <div class="modal-body" style="display:flex;flex-direction:column;gap:20px">

        {# Wizard-Step 1: Connection #}
        <div data-wizard-step="1" data-step-key="connection">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_connection') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.name') }} *</label>
              <input type="text" id="rdp-name" required maxlength="100" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.description') }}</label>
              <input type="text" id="rdp-description" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.host') }} *</label>
              <div style="position:relative">
                <input type="text" id="rdp-host" required placeholder="{{ t('rdp.host_placeholder') }}" autocomplete="off"
                  style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                <div id="rdp-host-suggestions" style="display:none;position:absolute;top:100%;left:0;right:0;max-height:200px;overflow-y:auto;background:var(--surface);border:1px solid var(--line);border-top:none;border-radius:0 0 var(--radius-sm) var(--radius-sm);z-index:10;box-shadow:var(--shadow-md)">
                </div>
              </div>
              <div id="rdp-host-hint" style="font-size:10px;color:var(--faint);margin-top:3px">{{ t('rdp.host_hint.default') }}</div>
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.port') }}</label>
              <input type="number" id="rdp-port" value="3389" min="1" max="65535" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.access_mode') }}</label>
              <select id="rdp-access-mode" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                <option value="internal">{{ t('rdp.access_mode.internal') }}</option>
                <option value="external">{{ t('rdp.access_mode.external') }}</option>
                <option value="both">{{ t('rdp.access_mode.both') }}</option>
                {% if license.hasFeature('rdp_via_gateway') %}
                <option value="gateway">{{ t('rdp.access_mode.gateway') }}</option>
                {% else %}
                <option value="gateway" disabled>{{ t('rdp.access_mode.gateway') }} (Pro)</option>
                {% endif %}
              </select>
            </div>
            <div id="rdp-external-fields" style="display:none;grid-column:1/-1">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <div>
                  <label id="rdp-external-hostname-label" style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.external_hostname') }}</label>
                  <input type="text" id="rdp-external-hostname" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                </div>
                <div>
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.external_port') }}</label>
                  <input type="number" id="rdp-external-port" min="1" max="65535" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                </div>
              </div>
            </div>

            {# Home-Gateway-Specific fields (access_mode=gateway) #}
            <div id="rdp-homegw-fields" style="display:none;grid-column:1/-1">
              <div style="padding:10px;background:color-mix(in srgb, var(--teal) 5%, transparent);border:1px solid color-mix(in srgb, var(--teal) 30%, var(--line));border-radius:var(--radius-sm);margin-bottom:8px">
                <div style="font-size:11px;color:var(--muted)">{{ t('rdp.access_mode_hint.gateway') }}</div>
                <div style="font-size:11px;color:var(--muted);margin-top:4px;font-weight:600">{{ t('rdp.gateway_lan_target_note') }}</div>
                <div style="font-size:10px;color:var(--faint);margin-top:4px">{{ t('rdp.gateway_nla_note') }}</div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <div>
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.gateway_peer') }} *</label>
                  <select id="rdp-homegw-peer" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                    <option value="">—</option>
                  </select>
                  <div style="font-size:10px;color:var(--faint);margin-top:3px">{{ t('rdp.gateway_peer_hint') }}</div>
                </div>
                <div>
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.gateway_listen_port') }}</label>
                  <input type="number" id="rdp-homegw-listen-port" min="1" max="65535" placeholder="3389" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                  <div style="font-size:10px;color:var(--faint);margin-top:3px">{{ t('rdp.gateway_listen_port_hint') }}</div>
                </div>
              </div>
            </div>

            {# Microsoft RD-Gateway (TSGateway) — NOT the Home-Gateway #}
            <div style="grid-column:1/-1;border-top:1px solid var(--line);margin-top:4px;padding-top:10px">
              <div style="font-size:11px;font-weight:600;color:var(--muted);margin-bottom:4px">{{ t('rdp.ms_rdg_section') }}</div>
              <div style="font-size:10px;color:var(--faint);margin-bottom:8px">{{ t('rdp.ms_rdg_hint') }}</div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <div>
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.ms_rdg_host') }}</label>
                  <input type="text" id="rdp-gateway-host" placeholder="rdg.example.com" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                </div>
                <div>
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.ms_rdg_port') }}</label>
                  <input type="number" id="rdp-gateway-port" value="443" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                </div>
              </div>
            </div>
          </div>
        </div>

        {# Wizard-Step 2: Auth #}
        <div data-wizard-step="2" data-step-key="auth">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_auth') }}</div>
          <div id="rdp-cred-stored-banner" class="banner-amber" role="alert" style="display:none;margin-bottom:10px">{{ t('rdp.cred.stored_invalid') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.credentials') }}</label>
              <select id="rdp-credential-mode" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                <option value="none">{{ t('rdp.credential_none') }}</option>
                <option value="user_only">{{ t('rdp.credential_user') }}</option>
                <option value="full">{{ t('rdp.credential_full') }}</option>
              </select>
            </div>
            <div id="rdp-domain-field">
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.domain') }}</label>
              <input type="text" id="rdp-domain" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
          </div>
          <div id="rdp-cred-fields" style="display:none;margin-top:10px">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div>
                <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.username') }}</label>
                <input type="text" id="rdp-username" autocomplete="off" data-1p-ignore data-lpignore="true" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
              </div>
              <div id="rdp-password-group">
                <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.password') }}</label>
                <input type="password" id="rdp-password" autocomplete="new-password" data-1p-ignore data-lpignore="true" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
              </div>
            </div>
            <div id="rdp-ssh-key-group" style="display:none;margin-top:10px">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <div style="grid-column:1/-1">
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.ssh_private_key') }}</label>
                  <textarea id="rdp-ssh-private-key" rows="4" autocomplete="off" placeholder="-----BEGIN..." style="width:100%;padding:8px 12px;font-size:11px;font-family:var(--font-mono);border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);resize:vertical;box-sizing:border-box"></textarea>
                </div>
                <div>
                  <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.ssh_passphrase') }}</label>
                  <input type="password" id="rdp-ssh-passphrase" autocomplete="new-password" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                </div>
              </div>
            </div>
          </div>
          {# Credential set-hints (shown in edit mode if cred already stored) #}
          <div id="rdp-cred-set-username" style="display:none;margin-top:6px;font-size:11px;color:var(--muted)">
            <span class="rdp-cred-set-label"></span>
            <button type="button" class="btn btn-sm btn-ghost rdp-cred-remove" data-cred="username" style="margin-left:6px"></button>
          </div>
          <div id="rdp-cred-set-password" style="display:none;margin-top:6px;font-size:11px;color:var(--muted)">
            <span class="rdp-cred-set-label"></span>
            <button type="button" class="btn btn-sm btn-ghost rdp-cred-remove" data-cred="password" style="margin-left:6px"></button>
          </div>
          <div id="rdp-cred-set-ssh-private-key" style="display:none;margin-top:6px;font-size:11px;color:var(--muted)">
            <span class="rdp-cred-set-label"></span>
            <button type="button" class="btn btn-sm btn-ghost rdp-cred-remove" data-cred="ssh_private_key" style="margin-left:6px"></button>
          </div>
          <div id="rdp-cred-set-ssh-passphrase" style="display:none;margin-top:6px;font-size:11px;color:var(--muted)">
            <span class="rdp-cred-set-label"></span>
            <button type="button" class="btn btn-sm btn-ghost rdp-cred-remove" data-cred="ssh_passphrase" style="margin-left:6px"></button>
          </div>
          {# SSH auth mode selector (SSH protocol only) #}
          <div id="rdp-ssh-auth-seg" style="display:none;margin-top:10px">
            <div style="display:flex;gap:6px">
              <button type="button" class="btn btn-sm btn-ghost active" data-auth-mode="password">{{ t('rdp.auth.password') }}</button>
              <button type="button" class="btn btn-sm btn-ghost" data-auth-mode="key">{{ t('rdp.auth.key') }}</button>
            </div>
          </div>
          <div id="rdp-ascii-hint" style="display:none;margin-top:8px;font-size:11px;color:var(--faint);line-height:1.4">{{ t('rdp.browser.ascii_hint') }}</div>
          <div style="margin-top:8px;font-size:11px;color:var(--faint);display:flex;align-items:center;gap:6px">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            {{ t('rdp.e2ee_note') }}
          </div>
        </div>

        {# Wizard-Step 3: Display #}
        <div data-wizard-step="3" data-step-key="experience">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_display') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.resolution') }}</label>
              <select id="rdp-resolution-mode" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                <option value="fullscreen">{{ t('rdp.resolution_fullscreen') }}</option>
                <option value="fixed">{{ t('rdp.resolution_fixed') }}</option>
                <option value="dynamic">{{ t('rdp.resolution_dynamic') }}</option>
              </select>
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.color_depth') }}</label>
              <select id="rdp-color-depth" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                <option value="32" selected>32 bit</option>
                <option value="24">24 bit</option>
                <option value="16">16 bit</option>
                <option value="15">15 bit</option>
                <option value="8">8 bit</option>
              </select>
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:4px">
              <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-multi-monitor" style="accent-color:var(--teal)"> {{ t('rdp.multi_monitor') }}</label>
            </div>
          </div>
          <div id="rdp-resolution-fields" style="display:none;margin-top:10px">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div>
                <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.resolution_width') }}</label>
                <input type="number" id="rdp-resolution-width" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
              </div>
              <div>
                <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.resolution_height') }}</label>
                <input type="number" id="rdp-resolution-height" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
              </div>
            </div>
          </div>
        </div>

        {# Wizard-Step 3: Resources (same step as Display) #}
        <div data-wizard-step="3" data-step-key="experience">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_resources') }}</div>
          <div style="display:flex;flex-wrap:wrap;gap:12px">
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-redirect-clipboard" checked style="accent-color:var(--teal)"> {{ t('rdp.clipboard') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-redirect-printers" style="accent-color:var(--teal)"> {{ t('rdp.printers') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-redirect-drives" style="accent-color:var(--teal)"> {{ t('rdp.drives') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-redirect-usb" style="accent-color:var(--teal)"> {{ t('rdp.usb') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-redirect-smartcard" style="accent-color:var(--teal)"> {{ t('rdp.smartcard') }}</label>
          </div>
          <div style="margin-top:10px">
            <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.audio') }}</label>
            <select id="rdp-audio-mode" style="width:200px;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body)">
              <option value="local">{{ t('rdp.audio_local') }}</option>
              <option value="remote">{{ t('rdp.audio_remote') }}</option>
              <option value="off">{{ t('rdp.audio_off') }}</option>
            </select>
          </div>
        </div>

        {# Wizard-Step 4: Performance #}
        <div data-wizard-step="4" data-step-key="security">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_performance') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.network_profile') }}</label>
              <select id="rdp-network-profile" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
                <option value="auto">Auto</option>
                <option value="lan">LAN</option>
                <option value="broadband">Broadband</option>
                <option value="modem">Modem</option>
              </select>
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.bandwidth_limit') }} (kbps)</label>
              <input type="number" id="rdp-bandwidth-limit" min="0" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:10px">
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-nla" checked style="accent-color:var(--teal)"> {{ t('rdp.nla') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-disable-wallpaper" style="accent-color:var(--teal)"> {{ t('rdp.wallpaper') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-disable-themes" style="accent-color:var(--teal)"> {{ t('rdp.themes') }}</label>
            <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-disable-animations" style="accent-color:var(--teal)"> {{ t('rdp.animations') }}</label>
          </div>
        </div>

        {# Wizard-Step 4: Session (same step as Performance) #}
        <div data-wizard-step="4" data-step-key="security">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_session') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.session_timeout') }} (s)</label>
              <input type="number" id="rdp-session-timeout" min="0" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.remote_app') }}</label>
              <input type="text" id="rdp-remote-app" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.start_program') }}</label>
              <input type="text" id="rdp-start-program" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:4px">
              <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-admin-session" style="accent-color:var(--teal)"> {{ t('rdp.admin_session') }}</label>
            </div>
          </div>
        </div>

        {# Wizard-Step 5: Wake-on-LAN #}
        <div data-wizard-step="5" data-step-key="wol" id="rdp-wol-section">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.tab_wol') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div style="display:flex;align-items:flex-end;padding-bottom:4px">
              <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-wol-enabled" style="accent-color:var(--teal)"> {{ t('rdp.wol') }}</label>
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.wol_mac') }}</label>
              <input type="text" id="rdp-wol-mac" placeholder="AA:BB:CC:DD:EE:FF" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
            </div>
          </div>
        </div>

        {# Wizard-Step 5: Access Control & Tags (same step as WoL) #}
        <div data-wizard-step="5" data-step-key="wol">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.section_access_control') }}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.maintenance') }}</label>
              <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;margin-bottom:8px"><input type="checkbox" id="rdp-maintenance-enabled" style="accent-color:var(--teal)"> {{ t('rdp.maintenance') }}</label>
              <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;margin-bottom:8px"><input type="checkbox" id="rdp-health-check" checked style="accent-color:var(--teal)"> {{ t('rdp.health_check') }}</label>
              <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-credential-rotation-enabled" style="accent-color:var(--teal)"> {{ t('rdp.credential_rotation') }}</label>
              <div style="margin-top:8px">
                <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.rotation_days') }}</label>
                <input type="number" id="rdp-rotation-days" value="90" min="1" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
              </div>
            </div>
            <div>
              <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.tags') }}</label>
              <input type="text" id="rdp-tags" placeholder="tag1, tag2, ..." style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);box-sizing:border-box">
              <div style="margin-top:8px">
                <label style="font-size:11px;font-weight:600;color:var(--muted);display:block;margin-bottom:3px">{{ t('rdp.notes') }}</label>
                <textarea id="rdp-notes" rows="4" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);font-family:var(--font-body);resize:vertical;box-sizing:border-box"></textarea>
              </div>
            </div>
          </div>
        </div>

        {# Wizard-Step 6: Visibility / User Access #}
        <div data-wizard-step="6" data-step-key="access">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('routes.visible_to_users') }}</div>
          <div style="font-size:11px;color:var(--faint);margin-bottom:6px">{{ t('routes.visible_to_users_hint') }}</div>
          <div id="rdp-user-ids" style="display:flex;flex-wrap:wrap;gap:6px"></div>
        </div>

        {# Wizard-Step 6: Review & Save #}
        <div data-wizard-step="6" data-step-key="access">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.wizard.review_title') }}</div>
          <div style="font-size:11px;color:var(--faint);margin-bottom:10px">{{ t('rdp.wizard.review_hint') }}</div>
          <div id="rdp-wizard-review" style="font-size:12px;background:var(--surface-2);border:1px solid var(--line);border-radius:var(--radius-sm);padding:12px;max-height:260px;overflow-y:auto;font-family:var(--font-mono)"></div>
        </div>

        {# Browser-access section (hidden until toggle enabled; rdp.js reveals) #}
        <div id="rdp-browser-reveal" style="display:none">
          <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">{{ t('rdp.browser.section') }}</div>
          <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer"><input type="checkbox" id="rdp-browser-enabled" style="accent-color:var(--teal)"> {{ t('rdp.browser.enable') }}</label>
        </div>

      </div>
    </form>

    {# Sticky Wizard Footer #}
    <div class="modal-foot wiz-foot">
      <button class="btn btn-ghost" id="rdp-modal-cancel">{{ t('rdp.wizard.cancel') }}</button>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost" id="rdp-wizard-prev" style="display:none">← {{ t('rdp.wizard.back') }}</button>
        <button class="btn btn-primary" id="rdp-wizard-next">{{ t('rdp.wizard.next') }} →</button>
        <button class="btn btn-primary" id="rdp-modal-save" style="display:none">{{ t('rdp.wizard.save') }}</button>
      </div>
    </div>

  </div>
</div>

{# Session history modal (opened by Aurora card "Session-Verlauf" button) #}
{% include theme + "/partials/modals/peer-traffic.njk" %}

{% endblock %}

{% block scripts %}
<script src="/js/rdp.js?v={{ appVersion }}"></script>
{% endblock %}
