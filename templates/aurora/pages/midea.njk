{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <p class="eyebrow">{{ t('nav.system') }}</p>
    <h1>{{ t('midea.title') }}</h1>
    <p class="subtitle">{{ t('midea.subtitle') }}</p>
  </div>
  <button id="midea-discover" class="btn">{{ t('midea.discover') }}</button>
</div>

<section class="card">
  <h2>{{ t('midea.cloud.title') }}</h2>
  <form id="midea-cloud-form" class="form-grid">
    <label>{{ t('midea.cloud.app') }}
      <select name="app"><option value="msmarthome">MSmartHome</option><option value="nethome">NetHome Plus</option></select>
    </label>
    <label>{{ t('midea.cloud.email') }}<input name="email" type="email" autocomplete="username"></label>
    <label>{{ t('midea.cloud.password') }}<input name="password" type="password" autocomplete="current-password"></label>
    <button type="submit" class="btn btn-primary">{{ t('midea.cloud.connect') }}</button>
  </form>
  <p id="midea-cloud-msg" class="muted"></p>
</section>

<section class="card">
  <h2>{{ t('midea.manual.title') }}</h2>
  <p class="subtitle">{{ t('midea.manual.hint') }}</p>
  <form id="midea-ip-form" class="form-grid">
    <label>{{ t('midea.manual.ip') }}<input name="ip" type="text" inputmode="decimal" placeholder="192.168.x.y" autocomplete="off"></label>
    <label>{{ t('midea.manual.name') }}<input name="name" type="text" autocomplete="off"></label>
    <label>{{ t('midea.manual.cloud_device') }}
      <select name="sn"><option value="">{{ t('midea.manual.no_cloud') }}</option></select>
    </label>
    <button type="submit" class="btn btn-primary">{{ t('midea.devices.add') }}</button>
  </form>
  <p id="midea-ip-msg" class="muted"></p>
</section>

<section class="card">
  <h2>{{ t('midea.devices.title') }}</h2>
  <p class="subtitle">{{ t('midea.cloud.usage_hint') }}</p>
  <div id="midea-cloud-list"></div>
  <div id="midea-devices"></div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/midea.js" defer></script>
{% endblock %}
