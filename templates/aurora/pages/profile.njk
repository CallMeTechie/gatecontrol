{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.account') }}</div>
    <h1 class="page-title">{{ t('profile.title') }}</h1>
    <p class="page-sub">{{ t('profile.subtitle') }}</p>
  </div>
</div>

<div class="grid">
  {# ─── Profile ──────────────────────────────────────── #}
  <div class="card span6">
    <div class="card-title">
      <span class="ic">
        <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </span>
      <span>{{ t('settings.profile') }}</span>
    </div>
    <div style="margin-top:14px">
      <div class="form-group">
        <label class="form-label">{{ t('settings.display_name') }}</label>
        <input class="form-input" type="text" id="settings-display-name" placeholder="Administrator" maxlength="64">
      </div>
      <div class="form-group">
        <label class="form-label">{{ t('settings.username') }}</label>
        <input class="form-input mono" type="text" id="settings-username" disabled>
      </div>
      <div class="form-group">
        <label class="form-label">{{ t('settings.email') }}</label>
        <input class="form-input" type="text" id="settings-email" placeholder="admin@example.com" maxlength="255">
      </div>
    </div>
    <div id="profile-message" style="display:none"></div>
    <button class="btn btn-primary btn-block" id="btn-save-profile" style="margin-top:14px">
      {{ t('common.save') }}
    </button>
  </div>

  {# ─── Security & Display ──────────────────────────── #}
  <div class="card span6">
    <div class="card-title">
      <span class="ic">
        <svg viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2"/></svg>
      </span>
      <span>{{ t('profile.security_display') }}</span>
    </div>
    <div style="margin-top:14px">
      <div class="form-group">
        <label class="form-label">{{ t('settings.current_password') }}</label>
        <input class="form-input" type="password" id="settings-current-pw" autocomplete="current-password">
      </div>
      <div class="form-group">
        <label class="form-label">{{ t('settings.new_password') }}</label>
        <input class="form-input" type="password" id="settings-new-pw" autocomplete="new-password">
      </div>
      <div class="form-group">
        <label class="form-label">{{ t('settings.confirm_password') }}</label>
        <input class="form-input" type="password" id="settings-confirm-pw" autocomplete="new-password">
      </div>
      <div id="password-message" style="display:none"></div>
      <button class="btn btn-primary btn-block" id="btn-change-password" style="margin-top:6px;margin-bottom:20px">
        {{ t('settings.change_password') }}
      </button>
      <div class="form-group">
        <label class="form-label">{{ t('settings.language') }}</label>
        <div class="toggle-group" id="language-buttons">
          {% for lang in availableLanguages %}
          <button class="toggle-btn {{ 'on' if lang == language else '' }}" data-lang="{{ lang }}">
            {% if lang == 'de' %}Deutsch{% elif lang == 'en' %}English{% else %}{{ lang }}{% endif %}
          </button>
          {% endfor %}
        </div>
        <span class="form-hint">{{ t('settings.language_hint') }}</span>
      </div>
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">{{ t('profile.theme') }}</label>
        <div class="toggle-group" id="theme-buttons">
          <button class="toggle-btn {{ 'on' if theme == 'default' or not theme else '' }}" data-theme="default">{{ t('profile.theme_classic') }}</button>
          <button class="toggle-btn {{ 'on' if theme == 'pro' else '' }}" data-theme="pro">{{ t('profile.theme_pro') }}</button>
          <button class="toggle-btn {{ 'on' if theme == 'aurora' else '' }}" data-theme="aurora">{{ t('profile.theme_aurora') }}</button>
        </div>
        <span class="form-hint">{{ t('profile.theme_hint') }}</span>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/profile.js?v={{ appVersion }}"></script>
{% endblock %}
