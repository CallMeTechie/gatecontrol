{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('pihole.eyebrow') }}</div>
    <div class="page-title">{{ t('pihole.title') }}</div>
    <div class="page-sub">{{ t('pihole.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">
    <button class="btn btn-ghost" id="btn-pihole-reload">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
      {{ t('common.reload') }}
    </button>
  </div>
</div>

{# ── Attribution-collapsed warning ────────────────────── #}
<div id="ph-attribution-warn" style="display:none;padding:12px 16px;margin-bottom:16px;background:var(--amber-lt);border:1px solid var(--amber-bd);border-radius:var(--radius-sm)">
  <span style="font-size:13px;color:var(--amber)">{{ t('pihole.attribution_collapsed') }}</span>
</div>

{# ── Row 1: Donut (span5) + Top Blocked Domains (span7) ── #}
<div class="grid" style="margin-bottom:18px">

  {# ── Donut card ─────────────────────────────────────────── #}
  <div class="card span5">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M5 5l14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
      {{ t('pihole.title') }}
      <span id="ph-blocking-badge" class="tag tag-grey" style="margin-left:auto">—</span>
    </div>
    <div class="pi-wrap">
      <div class="donut-host">
        <svg class="donut" viewBox="0 0 120 120">
          <circle class="track" cx="60" cy="60" r="52" fill="none" stroke-width="15"/>
          <circle class="val" id="pi-donut" cx="60" cy="60" r="52" fill="none" stroke-width="15" stroke-linecap="round" stroke-dasharray="326.7" stroke-dashoffset="326.7" transform="rotate(-90 60 60)"/>
        </svg>
        <div class="donut-center">
          <div>
            <div class="big" id="ph-stat-blocked-pct">—</div>
            <div class="cap">{{ t('pihole.cap_blocked') }}</div>
          </div>
        </div>
      </div>
      <div class="pi-stats">
        <div class="s"><span class="n" id="ph-stat-queries">—</span><span class="t">{{ t('pihole.stat_queries') }}</span></div>
        <div class="s"><span class="n blk" id="ph-stat-blocked">—</span><span class="t">{{ t('pihole.stat_blocked') }}</span></div>
        <div class="s"><span class="n" style="color:var(--teal)" id="ph-stat-allowed">—</span><span class="t">{{ t('pihole.stat_allowed') }}</span></div>
      </div>
    </div>
    {# ── Gravity + Clients as KPIs ─────────────────────────── #}
    <div style="margin-top:16px;display:flex;gap:12px">
      <div class="kpi" style="flex:1">
        <div class="lab">{{ t('pihole.stat_gravity') }}</div>
        <div class="val" id="ph-stat-gravity">—</div>
      </div>
      <div class="kpi" style="flex:1">
        <div class="lab">{{ t('pihole.stat_clients') }}</div>
        <div class="val" id="ph-stat-clients">—</div>
      </div>
    </div>
  </div>

  {# ── Top Blocked Domains toplist ────────────────────────── #}
  <div class="card span7">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 19V5M4 19h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
      {{ t('pihole.top_blocked') }}
    </div>
    <div class="toplist" style="border-top:0;padding-top:6px">
      <ul id="ph-top-domains-tbody">
        <li><span class="d">{{ t('common.loading') }}</span></li>
      </ul>
    </div>
  </div>
</div>

{# ── Row 2: History chart (span7) + Top Clients (span5) ── #}
<div class="grid" style="margin-bottom:18px">
  <div class="card span7">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      {{ t('pihole.history_title') }}
    </div>
    <div class="card-body">
      <div class="chart-area" id="ph-chart-area">
        <svg class="chart-svg" id="ph-chart-svg" viewBox="0 0 560 120" preserveAspectRatio="none"></svg>
      </div>
    </div>
  </div>
  <div class="card span5">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="9" cy="8" r="3.2" stroke="currentColor" stroke-width="2"/><path d="M3 20c0-3.3 2.7-5 6-5s6 1.7 6 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M16 5.5a3 3 0 0 1 0 5.5M18 20c0-2.4-1-4-2.5-4.6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
      {{ t('pihole.top_clients') }}
    </div>
    <div class="toplist" style="border-top:0;padding-top:6px">
      <div class="h" id="ph-client-col-peer">{{ t('pihole.peer') }}</div>
      <ul id="ph-top-clients-tbody">
        <li><span class="d">{{ t('common.loading') }}</span></li>
      </ul>
    </div>
  </div>
</div>

{# ── Row 3: Query Types (span6) + Blocking Control (span6) #}
<div class="grid" style="margin-bottom:18px">
  <div class="card span6">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" stroke="currentColor" stroke-width="2"/></svg></span>
      {{ t('pihole.query_types') }}
    </div>
    <div class="card-body" id="ph-query-types-list">
      <div style="text-align:center;color:var(--text-3);padding:20px">{{ t('common.loading') }}</div>
    </div>
  </div>
  <div class="card span6">
    <div class="card-title">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="6" y="5" width="4" height="14" rx="1" stroke="currentColor" stroke-width="2"/><rect x="14" y="5" width="4" height="14" rx="1" stroke="currentColor" stroke-width="2"/></svg></span>
      {{ t('pihole.control') }}
    </div>
    <div class="card-body">
      <div style="display:flex;flex-direction:column;gap:8px">
        <button class="btn btn-ghost" id="btn-ph-pause-30s">{{ t('pihole.pause_30s') }}</button>
        <button class="btn btn-ghost" id="btn-ph-pause-5m">{{ t('pihole.pause_5m') }}</button>
        <button class="btn btn-ghost" id="btn-ph-pause-30m">{{ t('pihole.pause_30m') }}</button>
        <button class="btn btn-primary" id="btn-ph-enable">{{ t('pihole.enable_blocking') }}</button>
      </div>
    </div>
  </div>
</div>

{# ── Health / Connection card ─────────────────────────── #}
<div class="card">
  <div class="card-title">
    {{ t('pihole.connection') }}
    <span id="ph-status-badge" class="tag tag-grey" style="margin-left:auto">—</span>
  </div>
  <div class="card-body">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px">
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('pihole.status') }}</div>
        <div style="font-size:14px;margin-top:4px" id="ph-health-status">—</div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('pihole.last_sync') }}</div>
        <div style="font-size:13px;margin-top:4px;font-family:var(--font-mono)" id="ph-health-sync">—</div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('pihole.instances') }}</div>
        <div style="font-size:14px;margin-top:4px" id="ph-health-instances">—</div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/pihole.js?v={{ appVersion }}"></script>
{% endblock %}
