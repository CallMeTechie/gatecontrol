{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.system') }}</div>
    <div class="page-title">{{ t('nav.logs') }}</div>
    <div class="page-sub" id="logs-subtitle">{{ t('logs.subtitle_live') }}</div>
  </div>
  <div class="page-actions">
    <button class="btn btn-ghost btn-sm" id="activity-export-csv">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      {{ t('logs.export_csv') }}
    </button>
  </div>
</div>

{# ─── Type tabs — outside page-header in Aurora ─── #}
<div class="tabs" id="log-type-tabs">
  <div class="tab active" data-type="activity">{{ t('logs.activity') }}</div>
  <div class="tab" data-type="access">{{ t('logs.access') }}</div>
  <div class="tab" data-type="history">{{ t('rdp.history') }}</div>
</div>

{# ─── Activity Log Panel ─── #}
<div id="activity-panel">
  <div class="toolbar">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m20 20-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <input placeholder="{{ t('logs.search_placeholder') }}" id="log-search">
    </div>
    <span class="toggle-group" id="log-severity-filter">
      <button class="tab active" data-severity="all">{{ t('logs.all') }}</button>
      <button class="tab" data-severity="success">{{ t('logs.success') }}</button>
      <button class="tab" data-severity="info">Info</button>
      <button class="tab" data-severity="warning">{{ t('logs.warning') }}</button>
      <button class="tab" data-severity="error">{{ t('logs.error') }}</button>
    </span>
    <span id="logs-count" style="font-size:12px;color:var(--muted)"></span>
    <button class="btn btn-ghost btn-sm" id="activity-export-json" style="margin-left:auto">{{ t('logs.export_json') }}</button>
  </div>
  <div class="grid">
    <div class="card span12" id="full-activity-log">
      <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
    </div>
  </div>
  <div id="activity-pagination" style="margin-top:12px"></div>
</div>

{# ─── Access Log Panel ─── #}
<div id="access-panel" style="display:none">
  <div class="toolbar">
    <span class="toggle-group" id="access-status-filter">
      <button class="tab active" data-status="">{{ t('logs.all') }}</button>
      <button class="tab" data-status="200">2xx</button>
      <button class="tab" data-status="300">3xx</button>
      <button class="tab" data-status="400">4xx</button>
      <button class="tab" data-status="500">5xx</button>
    </span>
    <span id="access-count" style="font-size:12px;color:var(--muted)"></span>
    <div style="margin-left:auto;display:flex;gap:6px">
      <button class="btn btn-ghost btn-sm" id="access-export-csv">{{ t('logs.export_csv') }}</button>
      <button class="btn btn-ghost btn-sm" id="access-export-json">{{ t('logs.export_json') }}</button>
    </div>
  </div>
  <div class="grid">
    <div class="card span12" id="access-log-container">
      <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
    </div>
  </div>
  <div id="access-pagination" style="margin-top:12px"></div>
</div>

{# ─── Connection History Panel ─── #}
<div id="history-panel" style="display:none">
  <div class="grid">
    <div class="card span12">
      <div class="card-title">
        <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
        {{ t('rdp.history') }}
        <select class="filter-select" id="rdp-history-status" style="font-size:11px;padding:4px 8px">
          <option value="">{{ t('common.all') }}</option>
          <option value="active">{{ t('rdp.status_active') }}</option>
          <option value="ended">{{ t('rdp.status_ended') }}</option>
        </select>
        <select class="filter-select" id="rdp-history-period" style="font-size:11px;padding:4px 8px">
          <option value="24h">{{ t('logs.last_24h') }}</option>
          <option value="7d">{{ t('logs.last_7d') }}</option>
          <option value="30d">{{ t('logs.last_30d') }}</option>
        </select>
        <div style="margin-left:auto;display:flex;gap:8px">
          <button class="btn btn-ghost btn-sm" id="rdp-history-export-csv">CSV</button>
          <button class="btn btn-ghost btn-sm" id="rdp-history-export-json">JSON</button>
        </div>
      </div>
      <div id="rdp-history-list">
        <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/logs.js?v={{ appVersion }}"></script>
<script src="/js/rdp-history.js?v={{ appVersion }}" nonce="{{ nonce }}"></script>
{% endblock %}
