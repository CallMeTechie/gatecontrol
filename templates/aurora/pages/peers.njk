{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow" data-i18n="peers.eyebrow">{{ t('peers.eyebrow') }}</div>
    <h1 class="page-title" data-i18n="peers.title">
      {{ t('peers.title') }}
      {% if license.features.vpn_peers is defined and license.features.vpn_peers != -1 %}
        <span class="limit-badge {% if peerCount >= license.features.vpn_peers %}at-limit{% endif %}">
          {{ peerCount }} / {{ license.features.vpn_peers }}
        </span>
      {% endif %}
    </h1>
    <p class="page-sub" data-i18n="peers.subtitle">{{ t('peers.subtitle') }}</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" id="btn-add-peer">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
      <span data-i18n="peers.add">{{ t('peers.add') }}</span>
    </button>
  </div>
</div>

<!-- Batch button: hidden in Aurora layout but kept for JS event listener -->
<button id="btn-batch-peers" style="display:none" aria-hidden="true"></button>

<!-- Toolbar: search input + status toggle-group -->
<div class="toolbar">
  <div class="search-box">
    <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m20 20-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    <input type="search" id="peer-search" data-i18n-ph="peers.search" placeholder="{{ t('peers.search') }}">
  </div>
  <span class="toggle-group" id="aurora-status-toggle">
    <button class="toggle-btn on" data-status="all" data-i18n="common.all">{{ t('common.all') or 'All' }}</button>
    <button class="toggle-btn" data-status="online" data-i18n="peers.online">{{ t('peers.online') or 'Online' }}</button>
    <button class="toggle-btn" data-status="offline" data-i18n="peers.offline">{{ t('peers.offline') or 'Offline' }}</button>
  </span>
</div>

<!-- Hidden DOM anchors required by peers.js — never removed -->
<div style="display:none" aria-hidden="true">
  <span id="peer-status-tags"></span>
  <div id="peer-tag-filters"></div>
  <select id="peer-group-filter"><option value="">{{ t('peer_groups.all') }}</option></select>
  <span id="stat-gw-online"></span><span id="stat-gw-total"></span>
  <span id="stat-cl-online"></span><span id="stat-cl-total"></span>
</div>

<!-- ─── Gateways card ──────────────────────────────────────── -->
<div class="card span12" style="margin-bottom:18px">
  <div class="card-title">
    <span class="ic">
      <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="3" y="14" width="18" height="6" rx="2" stroke="currentColor" stroke-width="2"/></svg>
    </span>
    <span data-i18n="peers.gateways_section">{{ t('peers.gateways_section') or 'Home Gateways' }}</span>
    <span class="card-sub" id="gw-section-count">—</span>
  </div>
  <div class="unit-grid" id="gateways-container" style="margin-top:14px">
    <div class="aurora-gw-empty">{{ t('common.loading') }}</div>
  </div>
</div>

<!-- ─── Peers / Clients card ───────────────────────────────── -->
<div class="card span12">
  <div class="card-title">
    <span class="ic">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </span>
    <span data-i18n="peers.clients_section">{{ t('peers.clients_section') or 'Peers / Clients' }}</span>
    <span class="card-sub" id="peers-section-count">—</span>
  </div>
  <table class="data-table" style="margin-top:8px">
    <thead>
      <tr>
        <th class="batch-col" style="display:none;width:40px"><input type="checkbox" id="batch-select-all-peers" title="{{ t('batch.select_all') }}"></th>
        <th data-i18n="peers.name_device">{{ t('peers.name_device') }}</th>
        <th data-i18n="peers.wg_ip">{{ t('peers.wg_ip') }}</th>
        <th data-i18n="peers.last_contact">{{ t('peers.last_contact') }}</th>
        <th data-i18n="peers.traffic">{{ t('peers.traffic') }}</th>
        <th data-i18n="peers.status">{{ t('peers.status') }}</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="peers-tbody">
      <tr><td colspan="6" style="text-align:center;color:var(--muted);padding:40px">{{ t('common.loading') }}</td></tr>
    </tbody>
  </table>
  <!-- Mobile view suppressed in Aurora (responsive table layout used instead) -->
  <div class="peers-mobile" id="peers-mobile" style="display:none"></div>
</div>

<!-- Batch action bar (preserved for batch-mode JS flow) -->
<div id="batch-bar-peers" class="batch-bar" style="display:none">
  <span id="batch-bar-peers-count"></span>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
    <button class="btn btn-ghost" id="batch-enable-peers">{{ t('batch.enable') }}</button>
    <button class="btn btn-ghost" id="batch-disable-peers">{{ t('batch.disable') }}</button>
    <button class="btn btn-danger" id="batch-delete-peers">{{ t('batch.delete') }}</button>
    <select id="peer-bulk-owner" style="width:auto"></select>
    <button class="btn btn-ghost" id="peer-bulk-owner-apply">{{ t('peers.owner.bulk_assign') }}</button>
    <button class="btn btn-ghost" id="batch-cancel-peers">{{ t('batch.cancel') }}</button>
  </div>
</div>

{% include theme + "/partials/modals/peer-add.njk" %}
{% include theme + "/partials/modals/peer-edit.njk" %}
{% include theme + "/partials/modals/peer-qr.njk" %}
{% include theme + "/partials/modals/peer-traffic.njk" %}
{% include theme + "/partials/modals/peer-gateway-tokens.njk" %}
{% include theme + "/partials/modals/peer-gateway-delete.njk" %}
{% include theme + "/partials/modals/confirm.njk" %}
{% endblock %}

{% block scripts %}
<script src="/js/peers.js?v={{ appVersion }}"></script>
{% endblock %}
