{% extends theme + "/layout.njk" %}

{% block content %}
{% if license.unlicensed %}
<div style="padding:12px 16px;margin-bottom:16px;background:var(--accent-lt);border:1px solid var(--accent-bd);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
  <span style="font-size:13px;color:var(--text-1)">{{ t('license.unlicensed_banner') }}</span>
  <a href="https://callmetechie.de/products/gatecontrol/pricing" target="_blank" rel="noopener" class="btn btn-primary" style="font-size:12px;padding:6px 14px;white-space:nowrap">{{ t('license.get_free_license') }}</a>
</div>
{% endif %}
{% if needs_repair_gateways and needs_repair_gateways.length > 0 %}
<div class="alert-warning" style="padding:12px 16px;margin-bottom:16px;border-radius:var(--radius-sm)">
  <strong>{{ t('gateway_needs_repair_title') }}</strong>
  <p style="margin:4px 0 8px 0;font-size:13px">{{ t('gateway_needs_repair_msg') }}</p>
  <ul style="margin:0;padding-left:20px">
    {% for gw in needs_repair_gateways %}
      <li style="font-size:13px"><code>{{ gw.name }}</code> — <a href="/peers">{{ t('download_new_env') }}</a></li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('dashboard.eyebrow') }}</div>
    <div class="page-title">{{ t('dashboard.title') }}</div>
    <div class="page-sub">{{ t('dashboard.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">
    <a href="/peers" class="btn btn-primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('dashboard.add_peer') }}
    </a>
  </div>
</div>

<!-- ── Row 1: KPI Cards (6-across down to 1200px, then progressively stacked) ── -->
<div class="aurora-kpi-grid">

  <!-- Peers -->
  <div class="card kpi">
    <div class="top">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </div>
      <span class="lab">{{ t('dashboard.peers_connected') }}</span>
    </div>
    <div class="val" id="stat-peers">0</div>
  </div>

  <!-- Routes -->
  <div class="card kpi">
    <div class="top">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      </div>
      <span class="lab">{{ t('dashboard.active_subdomains') }}</span>
    </div>
    <div class="val" id="stat-routes">0</div>
  </div>

  <!-- Traffic -->
  <div class="card kpi">
    <div class="top">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <span class="lab">{{ t('dashboard.traffic_today') }}</span>
    </div>
    <div class="val" id="stat-traffic">0 <span style="font-size:14px;font-weight:400">B</span></div>
  </div>

  <!-- Gateways (Aurora-only KPI; populated by auroraRefreshStats) -->
  <div class="card kpi">
    <div class="top">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
      </div>
      <span class="lab">{{ t('dashboard.stat_gateways') }}</span>
    </div>
    <div class="val" id="stat-gateways">—</div>
  </div>

  <!-- Latency -->
  <div class="card kpi">
    <div class="top">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      </div>
      <span class="lab">{{ t('dashboard.avg_latency') }}</span>
    </div>
    <div class="val" id="stat-latency">—</div>
  </div>

  <!-- Monitoring / Verfügbarkeit — only shown when ≥1 route has monitoring enabled (toggled by JS) -->
  <a class="card kpi" id="kpi-monitoring" href="/routes" style="text-decoration:none;color:inherit;display:none" title="{{ t('monitoring.dashboard_link_title') or 'Routen-Monitoring verwalten' }}">
    <div class="top">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <span class="lab">{{ t('monitoring.dashboard_label') or 'Uptime' }}</span>
    </div>
    <div class="val" id="stat-monitoring">—</div>
    <div id="stat-monitoring-sub" style="font-size:11px;color:var(--faint);font-family:var(--font-mono);margin-top:4px"></div>
  </a>

</div>

<!-- ── Row 2: Traffic Chart + Pi-hole Donut ───────────────────────────────── -->
<div class="grid" style="margin-bottom:18px">

  <!-- Traffic Chart (span8) -->
  <div class="card span8">
    <div class="card-title">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      {{ t('dashboard.network_traffic') }}
      <div class="toggle-group" id="traffic-range" style="margin-left:auto">
        <button class="toggle-btn" data-r="1h">1h</button>
        <button class="toggle-btn on" data-r="24h">24h</button>
        <button class="toggle-btn" data-r="7d">7d</button>
      </div>
    </div>
    <div class="card-body">
      <!-- Bar chart container (populated by auroraRenderChart) -->
      <div class="chart" id="traffic-chart"></div>
      <!-- Legend -->
      <div class="chart-legend" style="margin-top:10px">
        <span class="chart-legend"><i style="background:var(--teal)"></i>{{ t('dashboard.download') }}</span>
        <span class="chart-legend" style="margin-left:12px"><i style="background:var(--coral)"></i>{{ t('dashboard.upload') }}</span>
      </div>
      <!-- Footer stats -->
      <div class="chart-foot">
        <div class="t">{{ t('dashboard.chart_total') }}<br><b id="t-total">—</b></div>
        <div class="t">{{ t('dashboard.chart_avg') }}<br><b id="t-avg">—</b></div>
        <div class="t">{{ t('dashboard.chart_peak') }}<br><b id="t-peak">—</b></div>
      </div>
    </div>
  </div>

  <!-- Pi-hole Donut (span4) — only rendered when license gate passes -->
  {% if license.features.pihole_integration %}
  <div class="card span4" id="pihole-donut-card">
    <div class="card-title">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M5 5l14 14" stroke-linecap="round"/></svg>
      </div>
      {{ t('dashboard.pihole_title') }}
      <span class="card-sub" id="pihole-donut-sub"></span>
    </div>
    <div class="card-body">
      <div class="pi-wrap">
        <div class="donut-host">
          <svg class="donut" id="dash-donut" viewBox="0 0 36 36">
            <circle class="track" cx="18" cy="18" r="15.9155" fill="none" stroke-width="3"/>
            <circle class="val" cx="18" cy="18" r="15.9155" fill="none" stroke-width="3"
              stroke-dasharray="0 100" stroke-dashoffset="25" stroke-linecap="round"/>
          </svg>
          <div class="donut-center">
            <div>
              <div class="big" id="donut-pct">—</div>
              <div class="cap">{{ t('dashboard.pihole_blocked_pct') }}</div>
            </div>
          </div>
        </div>
        <div class="pi-stats" id="pihole-stats-body">
          <div class="empty-state" style="padding:12px">{{ t('common.loading') }}</div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

</div>

<!-- ── Row 3: Recent Events + Quick Actions ───────────────────────────────── -->
<div class="grid" style="margin-bottom:18px">

  <!-- Recent Events (span6) -->
  <div class="card span6">
    <div class="card-title">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      {{ t('dashboard.recent_events') }}
      <span class="card-sub">{{ t('dashboard.realtime') }}</span>
    </div>
    <div class="card-body" id="activity-feed">
      <div style="font-size:13px;color:var(--faint);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
    </div>
  </div>

  <!-- Quick Actions (span6) -->
  <div class="card span6">
    <div class="card-title">
      <div class="ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </div>
      {{ t('dashboard.quick_actions') }}
    </div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <a href="/peers?action=add" class="btn btn-ghost" style="justify-content:center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          {{ t('dashboard.quick_add_peer') }}
        </a>
        <a href="/routes?action=add" class="btn btn-ghost" style="justify-content:center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="5" x2="12" y2="19"/></svg>
          {{ t('dashboard.quick_add_route') }}
        </a>
        <a href="/gateways" class="btn btn-ghost" style="justify-content:center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><rect x="3" y="4" width="18" height="6" rx="2"/><rect x="3" y="14" width="18" height="6" rx="2"/></svg>
          {{ t('dashboard.quick_gateways') }}
        </a>
        <a href="/logs" class="btn btn-ghost" style="justify-content:center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          {{ t('dashboard.quick_logs') }}
        </a>
      </div>
    </div>
  </div>

</div>

<!-- ── Row 4: System Resources ────────────────────────────────────────────── -->
<div class="grid" style="margin-bottom:18px">

  <!-- CPU — radial donut gauge (Aurora) -->
  <div class="card span4">
    <div class="card-title">{{ t('dashboard.cpu_usage') }}</div>
    <div class="card-body">
      <div class="res-gauge-wrap">
        <div class="donut-host">
          <svg class="donut" id="cpu-donut" viewBox="0 0 36 36">
            <circle class="track" cx="18" cy="18" r="15.9155" fill="none" stroke-width="3"/>
            <circle class="val" cx="18" cy="18" r="15.9155" fill="none" stroke-width="3"
              stroke-dasharray="0 100" stroke-dashoffset="25" stroke-linecap="round"/>
          </svg>
          <div class="donut-center">
            <div class="big" id="cpu-pct">—</div>
          </div>
        </div>
        <div class="res-gauge-info">
          <div class="ri" id="cpu-info">—</div>
        </div>
      </div>
      <!-- #cpu-bar kept hidden for shared-function ID contract -->
      <div style="display:none"><div id="cpu-bar"></div></div>
    </div>
  </div>

  <!-- RAM — radial donut gauge (Aurora) -->
  <div class="card span4">
    <div class="card-title">{{ t('dashboard.ram_usage') }}</div>
    <div class="card-body">
      <div class="res-gauge-wrap">
        <div class="donut-host">
          <svg class="donut" id="ram-donut" viewBox="0 0 36 36">
            <circle class="track" cx="18" cy="18" r="15.9155" fill="none" stroke-width="3"/>
            <circle class="val" cx="18" cy="18" r="15.9155" fill="none" stroke-width="3"
              stroke-dasharray="0 100" stroke-dashoffset="25" stroke-linecap="round"/>
          </svg>
          <div class="donut-center">
            <div class="big" id="ram-pct">—</div>
          </div>
        </div>
        <div class="res-gauge-info">
          <div class="ri" id="ram-info">—</div>
        </div>
      </div>
      <!-- #ram-bar kept hidden for shared-function ID contract -->
      <div style="display:none"><div id="ram-bar"></div></div>
    </div>
  </div>

  <!-- Uptime -->
  <div class="card span4">
    <div class="card-title">
      {{ t('dashboard.uptime') }}
      <span class="card-sub" style="font-family:var(--font-mono);font-size:11px;font-weight:600;color:var(--faint);margin-left:auto" id="uptime-boot"></span>
    </div>
    <div class="card-body">
      <div style="font-family:var(--font-mono);font-size:20px;font-weight:600;color:var(--teal)" id="uptime-value">—</div>
    </div>
  </div>

</div>

<!-- Auto-update setup modal -->
<div class="modal-overlay" id="au-setup-modal-overlay" style="display:none">
  <div class="modal">
    <div class="modal-head">
      <span class="modal-title" id="au-setup-title"></span>
      <button class="modal-close" data-close-modal aria-label="{{ t('common.close') }}">&times;</button>
    </div>
    <div class="modal-body" id="au-setup-body"></div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/dashboard.js?v={{ appVersion }}"></script>
{% endblock %}
