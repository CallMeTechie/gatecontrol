{% extends theme + "/layout.njk" %}

{% block head %}<link rel="stylesheet" href="/css/midea.css">{% endblock %}

{% block content %}
<div class="midea-page">
  <div class="page-header">
    <div>
      <div class="page-eyebrow">{{ t('nav.system') }} · Klima</div>
      <h1 class="page-title">{{ t('midea.title') }}</h1>
      <div class="page-sub">{{ t('midea.subtitle') }}</div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-left:auto;align-items:center">
      <button id="midea-discover" class="btn btn-ghost">{{ t('midea.discover') }}</button>
      <button id="midea-add-open" class="btn btn-primary">{{ t('midea.add.title') }}</button>
    </div>
  </div>

  <div class="kpi-strip" id="midea-kpis"></div>
  <div class="ac-grid" id="midea-devices"></div>

  {% include theme + "/partials/modals/midea-owner.njk" %}
  {% include theme + "/partials/modals/midea-add.njk" %}
</div>
{% endblock %}

{% block scripts %}
<script src="/js/midea.js" defer></script>
{% endblock %}
