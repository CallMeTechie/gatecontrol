{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('dns.eyebrow') }}</div>
    <div class="page-title">{{ t('dns.title') }}</div>
    <div class="page-sub">{{ t('dns.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">
    <button class="btn btn-ghost" id="btn-dns-reload">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
      {{ t('common.reload') }}
    </button>
  </div>
</div>

{# ── Stats ─────────────────────────────────────────────────── #}
<div id="dns-stats" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px">
  <div class="stat-card">
    <div class="stat-value" id="dns-stat-total">0</div>
    <div class="stat-label">{{ t('dns.stat_total') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="dns-stat-resolved"><span class="stat-dot stat-dot-green"></span>0</div>
    <div class="stat-label">{{ t('dns.stat_resolved') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="dns-stat-auto"><span class="stat-dot stat-dot-blue"></span>0</div>
    <div class="stat-label">{{ t('dns.stat_auto') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="dns-stat-stale"><span class="stat-dot stat-dot-amber"></span>0</div>
    <div class="stat-label">{{ t('dns.stat_stale') }}</div>
  </div>
</div>

{# ── Config-Card ───────────────────────────────────────────── #}
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
    <span class="card-title">{{ t('dns.config') }}</span>
  </div>
  <div class="card-body">
    <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(220px,1fr));gap:12px">
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('dns.status') }}</div>
        <div style="font-size:14px;margin-top:4px" id="dns-status-badge">
          <span class="tag tag-grey">—</span>
        </div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('dns.domain') }}</div>
        <div style="font-family:var(--font-mono);font-size:14px;margin-top:4px" id="dns-domain">—</div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('dns.hosts_file') }}</div>
        <div style="font-family:var(--font-mono);font-size:11px;margin-top:4px;color:var(--text-2);word-break:break-all" id="dns-hosts-path">—</div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px">{{ t('dns.last_rebuild') }}</div>
        <div style="font-size:14px;margin-top:4px" id="dns-mtime">—</div>
      </div>
    </div>
  </div>
</div>

{# ── Static-Records ────────────────────────────────────────── #}
<div class="card" style="margin-bottom:14px">
  <div class="card-head">
    <span class="card-title">{{ t('dns.static_records') }}</span>
  </div>
  <div class="card-body">
    <div style="font-size:12px;color:var(--text-3);margin-bottom:8px">{{ t('dns.static_records_hint') }}</div>
    <table class="peer-table" style="font-size:12px">
      <thead>
        <tr>
          <th>{{ t('dns.fqdn') }}</th>
          <th>{{ t('dns.ip') }}</th>
        </tr>
      </thead>
      <tbody id="dns-static-tbody">
        <tr><td colspan="2" style="text-align:center;color:var(--text-3);padding:20px">{{ t('common.loading') }}</td></tr>
      </tbody>
    </table>
  </div>
</div>

{# ── Peer-Records ──────────────────────────────────────────── #}
<div class="card">
  <div class="card-head">
    <span class="card-title">{{ t('dns.peer_records') }}</span>
    <div style="margin-left:auto">
      <input type="search" id="dns-peer-search" placeholder="{{ t('common.search') }}" style="padding:6px 10px;font-size:12px;min-width:200px">
    </div>
  </div>
  <div class="table-wrap">
    <table class="peer-table" style="font-size:12px">
      <thead>
        <tr>
          <th>{{ t('peers.name_device') }}</th>
          <th>{{ t('dns.hostname') }}</th>
          <th>{{ t('dns.fqdn') }}</th>
          <th>{{ t('dns.ip') }}</th>
          <th>{{ t('dns.source') }}</th>
          <th>{{ t('dns.reported_at') }}</th>
        </tr>
      </thead>
      <tbody id="dns-peer-tbody">
        <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:20px">{{ t('common.loading') }}</td></tr>
      </tbody>
    </table>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/dns.js"></script>
{% endblock %}
