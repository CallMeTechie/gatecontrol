<!DOCTYPE html>
<html lang="{{ language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#F8FAFC">
  <title>{{ t('route_auth.verify_access') }} — {{ domain }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/pro.css">
  {% if branding and branding.color %}
  <style nonce="{{ cspNonce }}">
    :root { --ra-accent: {{ branding.color }}; }
    .login-card .btn-primary { background: {{ branding.color }}; }
    .logo-icon { background: {{ branding.color }}; }
  </style>
  {% endif %}
  {% if branding and branding.bg_image %}
  <style nonce="{{ cspNonce }}">body { background: url('/branding/{{ branding.bg_image }}') center/cover no-repeat fixed; }</style>
  {% elif branding and branding.bg %}
  <style nonce="{{ cspNonce }}">body { background: {{ branding.bg }}; }</style>
  {% endif %}
  <style nonce="{{ cspNonce }}">
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: var(--space-4);
      font-family: var(--font-sans);
    }

    .login-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      padding: var(--space-8);
      width: 100%;
      max-width: 420px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-6);
    }

    .logo-icon {
      width: 40px;
      height: 40px;
      background: var(--accent);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .logo-icon svg {
      width: 20px;
      height: 20px;
    }

    .logo-wordmark {
      font-size: var(--text-lg);
      font-weight: var(--weight-bold);
      color: var(--text-primary);
      letter-spacing: -0.02em;
    }

    .domain-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-1) var(--space-3);
      background: var(--accent-light);
      border: 1px solid var(--accent-border);
      border-radius: var(--radius-full);
      font-size: var(--text-xs);
      font-weight: var(--weight-medium);
      color: var(--accent-text);
      margin-bottom: var(--space-5);
    }

    .domain-badge svg {
      width: 12px;
      height: 12px;
      flex-shrink: 0;
    }

    .card-header {
      margin-bottom: var(--space-6);
    }

    .card-eyebrow {
      font-size: var(--text-xs);
      font-weight: var(--weight-medium);
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: var(--space-1);
    }

    .card-title {
      font-size: var(--text-xl);
      font-weight: var(--weight-bold);
      color: var(--text-primary);
      letter-spacing: -0.02em;
    }

    .step-indicator {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      margin-bottom: var(--space-6);
    }

    .step-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--border);
      transition: background 0.15s;
    }

    .step-dot.active {
      background: var(--accent);
    }

    .step-dot.done {
      background: var(--green);
    }

    .step-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .lock-icon {
      width: 48px;
      height: 48px;
      background: var(--accent-light);
      border: 1px solid var(--accent-border);
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto var(--space-4);
    }

    .lock-icon svg {
      width: 22px;
      height: 22px;
      stroke: var(--accent);
    }

    .info-text {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      text-align: center;
      margin-bottom: var(--space-5);
    }

    .form-group {
      margin-bottom: var(--space-4);
    }

    .form-label {
      display: block;
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--text-secondary);
      margin-bottom: var(--space-2);
    }

    .form-input {
      width: 100%;
      height: 42px;
      padding: 0 var(--space-3);
      font-size: var(--text-base);
      font-family: var(--font-sans);
      color: var(--text-primary);
      background: var(--bg-input);
      border: 1px solid var(--border-input);
      border-radius: var(--radius);
      box-sizing: border-box;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none;
    }

    .form-input:focus {
      border-color: var(--border-focus);
      background: var(--bg-input-focus);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .btn-primary {
      width: 100%;
      height: 42px;
      margin-top: var(--space-2);
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      font-family: var(--font-sans);
      color: var(--text-inverse);
      background: var(--ra-accent, var(--accent));
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      transition: opacity 0.15s;
    }

    .btn-primary:hover {
      opacity: 0.9;
    }

    .btn-primary:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .form-error {
      background: var(--red-light);
      border: 1px solid var(--red-border);
      color: var(--red-text);
      padding: var(--space-3) var(--space-4);
      border-radius: var(--radius);
      font-size: var(--text-sm);
      margin-bottom: var(--space-4);
      display: none;
    }

    .form-error:not(:empty) {
      display: block;
    }

    .error-card {
      background: var(--red-light);
      border: 1px solid var(--red-border);
      color: var(--red-text);
      padding: var(--space-3) var(--space-4);
      border-radius: var(--radius);
      font-size: var(--text-sm);
      margin-bottom: var(--space-4);
    }

    .code-inputs {
      display: flex;
      gap: var(--space-2);
      justify-content: center;
      margin-bottom: var(--space-5);
    }

    .code-inputs input {
      width: 44px;
      height: 52px;
      text-align: center;
      font-size: var(--text-xl);
      font-weight: var(--weight-semibold);
      font-family: var(--font-mono);
      color: var(--text-primary);
      background: var(--bg-input);
      border: 1px solid var(--border-input);
      border-radius: var(--radius);
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
      -moz-appearance: textfield;
    }

    .code-inputs input::-webkit-inner-spin-button,
    .code-inputs input::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .code-inputs input:focus {
      border-color: var(--border-focus);
      background: var(--bg-input-focus);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .link-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      margin-top: var(--space-4);
    }

    .text-link {
      font-size: var(--text-sm);
      color: var(--accent);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      text-decoration: none;
      font-family: var(--font-sans);
    }

    .text-link:hover {
      text-decoration: underline;
    }

    .link-sep {
      width: 1px;
      height: 12px;
      background: var(--border);
    }

    .page-footer {
      margin-top: var(--space-6);
      font-size: var(--text-xs);
      color: var(--text-muted);
      text-align: center;
    }
  </style>
</head>
<body>

  <div class="login-card">

    {# Logo + Title #}
    <div class="logo" style="{% if branding and not branding.title %}justify-content:center{% endif %}">
      {% if branding and branding.logo %}
      <img src="/branding/{{ branding.logo }}" alt="Logo" style="max-height:96px;max-width:400px;object-fit:contain{% if branding and not branding.title %};margin:0 auto;display:block{% endif %}">
      {% elif not branding or branding.title %}
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      {% endif %}
      {% if not branding or branding.title %}
      <div class="logo-wordmark">{{ branding.title if branding and branding.title else 'GateControl' }}</div>
      {% endif %}
    </div>
    {% if branding and branding.text %}
    <div style="text-align:center;font-size:var(--text-sm);color:var(--text-muted);margin-bottom:var(--space-4)">{{ branding.text }}</div>
    {% endif %}

    {# Error card (non-JS / server-side errors) #}
    {% if error %}
    <div class="error-card">{{ errorMessage }}</div>
    {% endif %}

    {# ── STEP 2: Email Code ─────────────────────────────── #}
    {% if is2faStep2 and twoFactorMethod == 'email_code' %}

      <div class="domain-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        {{ domain }}
      </div>

      <div class="card-header">
        <div class="card-eyebrow">{{ t('route_auth.access_to') }}</div>
        <div class="card-title">{{ t('route_auth.step_2_email_code') }}</div>
      </div>

      <div class="step-indicator">
        <div class="step-dot done"></div>
        <div class="step-line"></div>
        <div class="step-dot active"></div>
      </div>

      <div class="info-text">{{ t('route_auth.code_sent_to') }} <strong>{{ maskedEmail }}</strong></div>

      <div class="form-error" id="form-error"></div>

      <form id="verify-form" method="POST" action="/route-auth/verify-code">
        <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
        <input type="hidden" name="route" value="{{ domain }}">
        <input type="hidden" name="redirect" value="{{ redirect }}">

        <div class="code-inputs" id="code-inputs">
          <input type="number" maxlength="1" inputmode="numeric" autocomplete="one-time-code" autofocus>
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
        </div>
        <input type="hidden" name="code" id="code-value">

        <button type="submit" class="btn-primary" id="verify-btn">{{ t('route_auth.verify') }}</button>
      </form>

      <div class="link-row">
        <button type="button" class="text-link" id="resend-btn">{{ t('route_auth.resend_code') }}</button>
        <div class="link-sep"></div>
        <a href="/route-auth/login?route={{ domain }}&redirect={{ redirect | urlencode }}" class="text-link">{{ t('route_auth.back') }}</a>
      </div>

    {# ── STEP 2: TOTP ───────────────────────────────────── #}
    {% elif is2faStep2 and twoFactorMethod == 'totp' %}

      <div class="domain-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        {{ domain }}
      </div>

      <div class="card-header">
        <div class="card-eyebrow">{{ t('route_auth.access_to') }}</div>
        <div class="card-title">{{ t('route_auth.step_2_authenticator') }}</div>
      </div>

      <div class="step-indicator">
        <div class="step-dot done"></div>
        <div class="step-line"></div>
        <div class="step-dot active"></div>
      </div>

      <div class="lock-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>

      <div class="info-text">{{ t('route_auth.enter_authenticator_code') }}</div>

      <div class="form-error" id="form-error"></div>

      <form id="verify-form" method="POST" action="/route-auth/verify-code">
        <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
        <input type="hidden" name="route" value="{{ domain }}">
        <input type="hidden" name="redirect" value="{{ redirect }}">

        <div class="code-inputs" id="code-inputs">
          <input type="number" maxlength="1" inputmode="numeric" autocomplete="one-time-code" autofocus>
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
        </div>
        <input type="hidden" name="code" id="code-value">

        <button type="submit" class="btn-primary" id="verify-btn">{{ t('route_auth.verify') }}</button>
      </form>

      <div class="link-row">
        <a href="/route-auth/login?route={{ domain }}&redirect={{ redirect | urlencode }}" class="text-link">{{ t('route_auth.back') }}</a>
      </div>

    {# ── email_password + 2FA: Step 1 ───────────────────── #}
    {% elif twoFactorEnabled and not is2faStep2 %}

      <div class="domain-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        {{ domain }}
      </div>

      <div class="card-header">
        <div class="card-eyebrow">{{ t('route_auth.access_to') }}</div>
        <div class="card-title">{{ t('route_auth.step_1_sign_in') }}</div>
      </div>

      <div class="step-indicator">
        <div class="step-dot active"></div>
        <div class="step-line"></div>
        <div class="step-dot"></div>
      </div>

      <div class="form-error" id="form-error"></div>

      <form id="login-form" method="POST" action="/route-auth/login">
        <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
        <input type="hidden" name="route" value="{{ domain }}">
        <input type="hidden" name="redirect" value="{{ redirect }}">

        <div class="form-group">
          <label class="form-label" for="email">{{ t('route_auth.email') }}</label>
          <input class="form-input" type="email" id="email" name="email" autocomplete="email" autofocus required>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">{{ t('route_auth.password') }}</label>
          <input class="form-input" type="password" id="password" name="password" autocomplete="current-password" required>
        </div>

        <button type="submit" class="btn-primary" id="login-btn">{{ t('route_auth.continue') }}</button>
      </form>

    {# ── email_password (no 2FA) ────────────────────────── #}
    {% elif authType == 'email_password' %}

      <div class="domain-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        {{ domain }}
      </div>

      <div class="card-header">
        <div class="card-eyebrow">{{ t('route_auth.access_to') }}</div>
        <div class="card-title">{{ t('route_auth.verify_access') }}</div>
      </div>

      <div class="form-error" id="form-error"></div>

      <form id="login-form" method="POST" action="/route-auth/login">
        <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
        <input type="hidden" name="route" value="{{ domain }}">
        <input type="hidden" name="redirect" value="{{ redirect }}">

        <div class="form-group">
          <label class="form-label" for="email">{{ t('route_auth.email') }}</label>
          <input class="form-input" type="email" id="email" name="email" autocomplete="email" autofocus required>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">{{ t('route_auth.password') }}</label>
          <input class="form-input" type="password" id="password" name="password" autocomplete="current-password" required>
        </div>

        <button type="submit" class="btn-primary" id="login-btn">{{ t('route_auth.sign_in') }}</button>
      </form>

    {# ── email_code ────────────────────────────────────── #}
    {% elif authType == 'email_code' %}

      <div class="domain-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        {{ domain }}
      </div>

      <div class="card-header">
        <div class="card-eyebrow">{{ t('route_auth.access_to') }}</div>
        <div class="card-title">{{ t('route_auth.verify_access') }}</div>
      </div>

      <div class="form-error" id="form-error"></div>

      {# Email section — visible initially #}
      <div id="email-section">
        <form id="send-code-form" method="POST" action="/route-auth/send-code">
          <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
          <input type="hidden" name="route" value="{{ domain }}">
          <input type="hidden" name="redirect" value="{{ redirect }}">

          <div class="form-group">
            <label class="form-label" for="email">{{ t('route_auth.email') }}</label>
            <input class="form-input" type="email" id="email" name="email" autocomplete="email" autofocus required>
          </div>

          <button type="submit" class="btn-primary" id="send-code-btn">{{ t('route_auth.send_code') }}</button>
        </form>
      </div>

      {# Code section — hidden until code sent #}
      <div id="code-section" style="display:none;">
        <div class="info-text" id="code-info-text"></div>

        <form id="verify-form" method="POST" action="/route-auth/verify-code">
          <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
          <input type="hidden" name="route" value="{{ domain }}">
          <input type="hidden" name="redirect" value="{{ redirect }}">

          <div class="code-inputs" id="code-inputs">
            <input type="number" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
            <input type="number" maxlength="1" inputmode="numeric">
            <input type="number" maxlength="1" inputmode="numeric">
            <input type="number" maxlength="1" inputmode="numeric">
            <input type="number" maxlength="1" inputmode="numeric">
            <input type="number" maxlength="1" inputmode="numeric">
          </div>
          <input type="hidden" name="code" id="code-value">

          <button type="submit" class="btn-primary" id="verify-btn">{{ t('route_auth.verify') }}</button>
        </form>

        <div class="link-row">
          <button type="button" class="text-link" id="resend-btn">{{ t('route_auth.resend_code') }}</button>
        </div>
      </div>

    {# ── totp ──────────────────────────────────────────── #}
    {% elif authType == 'totp' %}

      <div class="domain-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        {{ domain }}
      </div>

      <div class="card-header">
        <div class="card-eyebrow">{{ t('route_auth.access_to') }}</div>
        <div class="card-title">{{ t('route_auth.verify_access') }}</div>
      </div>

      <div class="lock-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>

      <div class="info-text">{{ t('route_auth.enter_authenticator_code') }}</div>

      <div class="form-error" id="form-error"></div>

      <form id="verify-form" method="POST" action="/route-auth/verify-code">
        <input type="hidden" name="_csrf" value="{{ routeCsrfToken }}">
        <input type="hidden" name="route" value="{{ domain }}">
        <input type="hidden" name="redirect" value="{{ redirect }}">

        <div class="code-inputs" id="code-inputs">
          <input type="number" maxlength="1" inputmode="numeric" autocomplete="one-time-code" autofocus>
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
          <input type="number" maxlength="1" inputmode="numeric">
        </div>
        <input type="hidden" name="code" id="code-value">

        <button type="submit" class="btn-primary" id="verify-btn">{{ t('route_auth.verify') }}</button>
      </form>

    {% endif %}

  </div>

  <div class="page-footer">{{ t('route_auth.protected_by') }}</div>

  <script src="/js/route-auth-login.js"></script>
</body>
</html>
