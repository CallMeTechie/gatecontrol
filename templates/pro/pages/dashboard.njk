{% extends theme + "/layout.njk" %}

{% block content %}
{% if license.unlicensed %}
<div style="padding:12px 16px;margin-bottom:16px;background:var(--accent-lt);border:1px solid var(--accent-bd);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
  <span style="font-size:13px;color:var(--text-1)">{{ t('license.unlicensed_banner') }}</span>
  <a href="https://callmetechie.de/products/gatecontrol/pricing" target="_blank" rel="noopener" class="btn btn-primary" style="font-size:12px;padding:6px 14px;white-space:nowrap">{{ t('license.get_free_license') }}</a>
</div>
{% endif %}

<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('dashboard.eyebrow') }}</div>
    <div class="page-title">{{ t('dashboard.title') }}</div>
    <div class="page-sub">{{ t('dashboard.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">
    <button class="btn btn-ghost" id="btn-reload">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
      {{ t('dashboard.reload') }}
    </button>
    <a href="/peers" class="btn btn-primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('dashboard.add_peer') }}
    </a>
  </div>
</div>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-card-header">
      <span class="stat-card-label">{{ t('dashboard.peers_connected') }}</span>
      <div class="stat-card-icon green">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-peers">0</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <span class="stat-card-label">{{ t('dashboard.active_subdomains') }}</span>
      <div class="stat-card-icon blue">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-routes">0</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <span class="stat-card-label">{{ t('dashboard.traffic_today') }}</span>
      <div class="stat-card-icon purple">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-traffic">0 <small style="font-size:0.5em;font-weight:500">B</small></div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <span class="stat-card-label">{{ t('dashboard.avg_latency') }}</span>
      <div class="stat-card-icon amber">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-latency">—</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <span class="stat-card-label">{{ t('monitoring.dashboard_label') or 'Uptime' }}</span>
      <div class="stat-card-icon green">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-monitoring">—</div>
  </div>
</div>

<!-- Traffic Chart + Activity Feed -->
<div class="content-grid">
  <div class="card">
    <div class="card-header">
      <span class="card-header-title">{{ t('dashboard.network_traffic') }}</span>
      <div style="display:flex;gap:20px;margin-left:auto;margin-right:12px">
        <div style="display:flex;align-items:center;gap:8px">
          <div style="width:10px;height:10px;border-radius:2px;background:var(--accent)"></div>
          <div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--text-3)">{{ t('dashboard.upload') | upper }}</div>
            <div style="font-family:var(--font-mono);font-size:16px;font-weight:600;color:var(--accent)" id="stat-upload-rate">0 B/s</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
          <div style="width:10px;height:10px;border-radius:2px;background:var(--green)"></div>
          <div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--text-3)">{{ t('dashboard.download') | upper }}</div>
            <div style="font-family:var(--font-mono);font-size:16px;font-weight:600;color:var(--green)" id="stat-download-rate">0 B/s</div>
          </div>
        </div>
      </div>
      <div class="toolbar-filter" style="border:none;background:none;padding:0;">
        <button class="tab active" data-period="1h">1h</button>
        <button class="tab" data-period="24h">24h</button>
        <button class="tab" data-period="7d">7d</button>
      </div>
    </div>
    <div class="card-body">
      <div class="chart-area" id="traffic-chart">
        <svg class="chart-svg" viewBox="0 0 560 120" preserveAspectRatio="none"></svg>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-header-title">{{ t('dashboard.recent_events') }}</span>
      <span style="font-size:11px;color:var(--text-3);margin-left:auto">{{ t('dashboard.realtime') }}</span>
    </div>
    <div class="card-body" id="activity-feed" style="padding-top:var(--space-2)">
      <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
    </div>
  </div>
</div>

<!-- System Resources -->
<div class="grid-3">
  <div class="card">
    <div class="card-header">
      <span class="card-header-title">{{ t('dashboard.cpu_usage') }}</span>
      <span style="font-size:12px;font-family:var(--font-mono);font-weight:600;color:var(--green);margin-left:auto" id="cpu-pct">—</span>
    </div>
    <div class="card-body">
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-2);margin-bottom:8px" id="cpu-info">—</div>
      <div class="meter">
        <div class="meter-bar blue" style="width:0%" id="cpu-bar"></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-header-title">{{ t('dashboard.ram_usage') }}</span>
      <span style="font-size:12px;font-family:var(--font-mono);font-weight:600;color:var(--blue);margin-left:auto" id="ram-pct">—</span>
    </div>
    <div class="card-body">
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-2);margin-bottom:8px" id="ram-info">—</div>
      <div class="meter">
        <div class="meter-bar green" style="width:0%" id="ram-bar"></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-header-title">{{ t('dashboard.uptime') }}</span>
      <span style="font-size:12px;font-family:var(--font-mono);font-weight:600;color:var(--accent);margin-left:auto" id="uptime-pct">—</span>
    </div>
    <div class="card-body">
      <div style="font-family:var(--font-mono);font-size:20px;font-weight:600;color:var(--accent)" id="uptime-value">—</div>
      <div class="meter" style="margin-top:8px">
        <div class="meter-bar amber" style="width:99.9%"></div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/dashboard.js"></script>
{% endblock %}
