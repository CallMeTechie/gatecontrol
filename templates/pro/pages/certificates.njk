{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.routing') }}</div>
    <div class="page-title">{{ t('nav.certificates') }}</div>
    <div class="page-sub">Let's Encrypt · Caddy Auto-TLS</div>
  </div>
  <div class="page-actions">
    <button class="btn btn-ghost" id="btn-certificates-refresh">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
      {{ t('common.refresh') }}
    </button>
  </div>
</div>

<div class="card">
  <div class="card-head">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <span class="card-title">{{ t('nav.certificates') }}</span>
  </div>
  <div class="card-body" id="certificates-list">
    <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/certificates.js"></script>
{% endblock %}
