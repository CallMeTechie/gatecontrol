<style nonce="{{ cspNonce }}">
.route-step-dot {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--bg-base); border: 1.5px solid var(--border);
  color: var(--text-3); font-size: 12px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  cursor: default; flex-shrink: 0; font-family: var(--font-mono);
  transition: all 120ms ease;
}
.route-step-dot.active {
  background: var(--accent); border-color: var(--accent); color: #fff;
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
}
.route-step-dot.done {
  background: color-mix(in srgb, var(--accent) 15%, var(--bg-panel));
  border-color: var(--accent); color: var(--accent); cursor: pointer;
}
.route-step-dot.done:hover {
  background: color-mix(in srgb, var(--accent) 25%, var(--bg-panel));
}
.route-step-line {
  flex: 1; height: 1.5px; background: var(--border); margin: 0 2px;
  transition: background 120ms ease;
}
.route-step-line.done { background: var(--accent); }

/* Wizard layout grid */
.wiz-row-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px 14px;
  margin-bottom: 14px;
  align-items: start;
}
.wiz-row-2 > * { margin-bottom: 0 !important; }
.wiz-section-title {
  font-size: 10px;
  font-family: var(--font-mono);
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 600;
  margin: 6px 0 8px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--border);
}
.wiz-step-body { min-height: 480px; }
@media (max-width: 640px) {
  .wiz-row-2 { grid-template-columns: 1fr; }
}
</style>

<!-- Batch action bar -->
<div id="batch-bar-routes" class="batch-bar" style="display:none">
  <span id="batch-bar-routes-count"></span>
  <div style="display:flex;gap:8px">
    <button class="btn btn-ghost" id="batch-enable-routes">{{ t('batch.enable') }}</button>
    <button class="btn btn-ghost" id="batch-disable-routes">{{ t('batch.disable') }}</button>
    <button class="btn btn-danger" id="batch-delete-routes">{{ t('batch.delete') }}</button>
    <button class="btn btn-ghost" id="batch-cancel-routes">{{ t('batch.cancel') }}</button>
  </div>
</div>

{% include theme + "/partials/modals/route-edit.njk" %}
{% include theme + "/partials/modals/confirm.njk" %}
{% endblock %}

{% block scripts %}
<script src="/js/vendor/qrcode.min.js"></script>
<script src="/js/routes.js"></script>
{% endblock %}
