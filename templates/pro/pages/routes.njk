{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('routes.eyebrow') }}</div>
    <div class="page-title">{{ t('routes.title') }}</div>
    <div class="page-sub" id="routes-subtitle">{{ t('routes.subtitle', { count: '0' }) }}</div>
    <div style="display:flex;gap:12px;margin-top:4px;flex-wrap:wrap">
      {% if license.features.http_routes is defined and license.features.http_routes != -1 %}
        <span class="limit-badge {% if httpRouteCount >= license.features.http_routes %}at-limit{% endif %}">
          {{ t('routes.type_http') }}: {{ httpRouteCount }} / {{ license.features.http_routes }}
        </span>
      {% endif %}
      {% if license.features.l4_routes is defined and license.features.l4_routes != -1 %}
        <span class="limit-badge {% if l4RouteCount >= license.features.l4_routes %}at-limit{% endif %}">
          {{ t('routes.type_l4') }}: {{ l4RouteCount }} / {{ license.features.l4_routes }}
        </span>
      {% endif %}
      {% if license.hasFeature('remote_desktop') %}
        <a href="/rdp" class="limit-badge" style="text-decoration:none;cursor:pointer">
          RDP: {{ rdpRouteCount or 0 }}
        </a>
      {% endif %}
    </div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:4px">
    <div class="input-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="route-search" placeholder="{{ t('routes.search') or 'Search routes...' }}">
    </div>
    <button class="btn btn-ghost" id="btn-batch-routes">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      {{ t('batch.select') }}
    </button>
    <button class="btn btn-primary" id="btn-add-route">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('routes.add') }}
    </button>
  </div>
</div>

<div>
  <!-- Active Routes — full width (create form moved into wizard modal below) -->
  <div class="card">
    <div class="card-header">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      <span class="card-header-title">{{ t('routes.active_routes') }}</span>
      <span style="font-size:12px;color:var(--text-3);margin-left:auto" id="routes-count">0</span>
    </div>
    <div class="card-body" id="routes-list">
      <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
    </div>
  </div>
</div>

<!-- Create-Route Wizard Modal (opened by #btn-add-route) -->
<div class="modal-overlay" id="route-modal-overlay" style="display:none">
  <div id="route-modal" style="background:var(--bg-panel);border-radius:var(--radius);width:880px;max-width:96vw;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);position:relative">

    {# Sticky Header with wizard progress #}
    <div style="padding:18px 24px 14px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--bg-panel);z-index:1">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px">
        <div style="min-width:0;flex:1">
          <div style="font-family:var(--font-display);font-size:20px;line-height:1.2" id="route-modal-title">{{ t('routes.new_route') }}</div>
          <div style="font-size:12px;color:var(--text-2);margin-top:4px;display:flex;align-items:center;gap:8px">
            <span id="route-modal-subtitle" style="font-family:var(--font-mono);font-size:11px;color:var(--text-3)"></span>
            <span style="color:var(--text-3)">·</span>
            <strong id="route-modal-steptitle" style="color:var(--text-1);font-weight:600"></strong>
          </div>
        </div>
        <button type="button" class="icon-btn" id="route-modal-close" style="width:32px;height:32px;flex-shrink:0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="route-wizard-steps" style="display:flex;align-items:center;margin-top:14px;gap:0">
        <div class="route-step-dot" data-pill="1" data-label="{{ t('routes.wizard.step_target') }}" title="1 · {{ t('routes.wizard.step_target') }}">1</div>
        <div class="route-step-line"></div>
        <div class="route-step-dot" data-pill="2" data-label="{{ t('routes.wizard.step_transport') }}" title="2 · {{ t('routes.wizard.step_transport') }}">2</div>
        <div class="route-step-line"></div>
        <div class="route-step-dot" data-pill="3" data-label="{{ t('routes.wizard.step_auth') }}" title="3 · {{ t('routes.wizard.step_auth') }}">3</div>
        <div class="route-step-line"></div>
        <div class="route-step-dot" data-pill="4" data-label="{{ t('routes.wizard.step_access') }}" title="4 · {{ t('routes.wizard.step_access') }}">4</div>
        <div class="route-step-line"></div>
        <div class="route-step-dot" data-pill="5" data-label="{{ t('routes.wizard.step_reliability') }}" title="5 · {{ t('routes.wizard.step_reliability') }}">5</div>
        <div class="route-step-line"></div>
        <div class="route-step-dot" data-pill="6" data-label="{{ t('routes.wizard.step_review') }}" title="6 · {{ t('routes.wizard.step_review') }}">6</div>
      </div>
    </div>

    <div class="wiz-step-body" style="padding:20px 24px">
      <form id="route-form">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {# ───── Step 1: Target ───── #}
        <div data-wizard-step="1">
        <div class="form-group">
          <div class="toggle-group" id="route-type-group">
            <button type="button" class="toggle-btn on" data-value="http">{{ t('routes.type_http') }}</button>
            {% if license.features.l4_routes is defined and license.features.l4_routes != 0 %}
            <button type="button" class="toggle-btn" data-value="l4">{{ t('routes.type_l4') }}</button>
            {% else %}
            <button type="button" class="toggle-btn" disabled style="opacity:0.5;cursor:not-allowed" title="{{ t('license.requires_pro') }}">{{ t('routes.type_l4') }} <span class="lock-icon"></span></button>
            {% endif %}
          </div>
          <input type="hidden" name="route_type" id="route-type" value="http">
        </div>

        <div class="wiz-row-2">
          <div>
            <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.domain') }}</label>
            <input type="text" id="create-route-domain" name="domain" placeholder="{{ t('routes.domain_placeholder') }}" style="width:100%;padding:8px 12px" required maxlength="253"
              data-dns-checking="{{ t('routes.dns_checking') }}"
              data-dns-ok="{{ t('routes.dns_ok') }}"
              data-dns-warning="{{ t('routes.dns_warning') }}">
            <small id="create-route-dns-hint" class="form-hint" style="display:none"></small>
          </div>
          <div>
            <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.description') or 'Description' }}</label>
            <input type="text" name="description" placeholder="{{ t('routes.description_placeholder') or 'Optional description' }}" style="width:100%;padding:8px 12px" maxlength="255">
          </div>
        </div>

        <div style="margin-bottom:14px">
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('route_target_kind') }}</label>
          <select class="form-select" id="create-route-target-kind" name="target_kind" style="width:100%;padding:8px 12px">
            <option value="peer">{{ t('route_target_peer') }}</option>
            <option value="gateway">{{ t('route_target_gateway') }}</option>
          </select>
        </div>

        <div id="create-route-peer-fields">
          <div class="wiz-row-2">
            <div>
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.target_peer') }}</label>
              <select name="peer_id" style="width:100%" id="route-peer-select">
                <option value="">—</option>
              </select>
            </div>
            <div>
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.target_port') }}</label>
              <input type="text" id="route-port" name="target_port" placeholder="{{ t('routes.target_port_placeholder') }}" style="width:100%;padding:8px 12px" maxlength="5">
            </div>
          </div>
        </div>

        <div id="create-route-gateway-fields" style="display:none">
          <div style="margin-bottom:14px">
            <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('route_gateway_peer') }}</label>
            <select class="form-select" id="create-route-gateway-peer" style="width:100%;padding:8px 12px">
              <option value="">—</option>
            </select>
          </div>
          <div class="wiz-row-2">
            <div>
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('route_lan_host') }}</label>
              <input type="text" id="create-route-lan-host" placeholder="192.168.1.10" style="width:100%;padding:8px 12px" maxlength="253">
            </div>
            <div>
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('route_lan_port') }}</label>
              <input type="number" id="create-route-lan-port" placeholder="8080" min="1" max="65535" style="width:100%;padding:8px 12px">
            </div>
          </div>
          <div style="margin-bottom:14px">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
              <input type="checkbox" id="create-route-wol-enabled">
              <span>{{ t('route_wol_enabled') }}</span>
            </label>
          </div>
          <div id="create-route-wol-mac-field" style="display:none;margin-bottom:14px">
            <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('route_wol_mac') }}</label>
            <input type="text" id="create-route-wol-mac" placeholder="AA:BB:CC:DD:EE:FF" pattern="^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$" style="width:100%;padding:8px 12px">
          </div>
        </div>

        <div id="l4-fields" style="display:none">
          <div class="wiz-row-2">
            <div class="form-group" style="margin-bottom:0">
              <label>{{ t('routes.l4_protocol') }}</label>
              <div class="toggle-group" id="l4-protocol-group">
                <button type="button" class="toggle-btn on" data-value="tcp">{{ t('routes.l4_protocol_tcp') }}</button>
                <button type="button" class="toggle-btn" data-value="udp">{{ t('routes.l4_protocol_udp') }}</button>
              </div>
              <input type="hidden" name="l4_protocol" id="l4-protocol" value="tcp">
            </div>
            <div class="form-group" style="margin-bottom:0">
              <label>{{ t('routes.l4_listen_port') }}</label>
              <input type="text" id="l4-listen-port" name="l4_listen_port" maxlength="11" placeholder="{{ t('routes.l4_listen_port_placeholder') }}">
            </div>
          </div>
          <div class="form-group">
            <label>{{ t('routes.l4_tls_mode') }}</label>
            <select id="l4-tls-mode" name="l4_tls_mode" class="form-select">
              <option value="none">{{ t('routes.tls_none') }}</option>
              <option value="passthrough">{{ t('routes.tls_passthrough') }}</option>
              <option value="terminate">{{ t('routes.tls_terminate') }}</option>
            </select>
            <small id="l4-tls-hint" class="form-hint" data-hint-none="{{ t('routes.tls_none_hint') }}" data-hint-terminate="{{ t('routes.tls_terminate_hint') }}"></small>
          </div>
        </div>
        </div> {# /step 1 #}

        <div id="http-fields">

          {# ───── Step 2: Transport ───── #}
          <div data-wizard-step="2">
          <div class="wiz-row-2">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('routes.force_https') }}</div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.force_https_desc') }}</div>
              </div>
              <div class="toggle on" data-field="https_enabled"></div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('routes.backend_https') or 'Backend HTTPS' }}</div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.backend_https_desc') or 'Backend uses HTTPS' }}</div>
              </div>
              <div class="toggle" data-field="backend_https"></div>
            </div>
          </div>
          <div class="wiz-row-2">
            {% if license.features.compression %}
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('routes.compress') }}</div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.compress_desc') }}</div>
              </div>
              <div class="toggle" id="create-route-compress"></div>
            </div>
            {% else %}
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)" class="feature-locked" title="{{ t('license.requires_pro') }}">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('routes.compress') }} <span class="lock-icon"></span></div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.compress_desc') }}</div>
              </div>
              <div class="toggle" id="create-route-compress"></div>
            </div>
            {% endif %}
            {% if license.features.bot_blocking %}
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('bot_blocker.title') }}</div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('bot_blocker.toggle_desc') }}</div>
              </div>
              <div class="toggle" id="create-route-bot-blocker"></div>
            </div>
            {% else %}
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)" class="feature-locked" title="{{ t('license.requires_pro') }}">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('bot_blocker.title') }} <span class="lock-icon"></span></div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('bot_blocker.toggle_desc') }}</div>
              </div>
              <div class="toggle" id="create-route-bot-blocker"></div>
            </div>
            {% endif %}
          </div>
          {% if license.features.bot_blocking %}
          <div id="create-bot-blocker-fields" style="display:none;margin-bottom:14px">
            <div style="margin-bottom:8px">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('bot_blocker.mode') }}</label>
              <select id="create-bot-blocker-mode" style="width:100%;padding:6px 10px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs)">
                <option value="block">{{ t('bot_blocker.mode_block') }}</option>
                <option value="tarpit">{{ t('bot_blocker.mode_tarpit') }}</option>
                <option value="drop">{{ t('bot_blocker.mode_drop') }}</option>
                <option value="garbage">{{ t('bot_blocker.mode_garbage') }}</option>
                <option value="redirect">{{ t('bot_blocker.mode_redirect') }}</option>
                <option value="custom">{{ t('bot_blocker.mode_custom') }}</option>
              </select>
            </div>
            <div id="create-bot-blocker-redirect" style="display:none;margin-bottom:8px">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('bot_blocker.url') }}</label>
              <input type="url" id="create-bot-blocker-url" placeholder="https://example.com" style="width:100%;padding:6px 10px;font-size:12px">
            </div>
            <div id="create-bot-blocker-custom" style="display:none">
              <div style="margin-bottom:8px">
                <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('bot_blocker.message') }}</label>
                <input type="text" id="create-bot-blocker-message" placeholder="Access denied" maxlength="500" style="width:100%;padding:6px 10px;font-size:12px">
              </div>
              <div>
                <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('bot_blocker.status_code') }}</label>
                <input type="number" id="create-bot-blocker-status" value="403" min="100" max="599" style="width:100%;padding:6px 10px;font-size:12px">
              </div>
            </div>
          </div>
          {% endif %}
          </div> {# /step 2 #}

          {# ───── Step 3: Auth ───── #}
          <div data-wizard-step="3">
          <!-- Auth type selection -->
          <div class="form-group">
            <label class="form-label">{{ t('route_auth.auth_type') }}</label>
            <div class="toggle-group" id="create-auth-type-group">
              <button type="button" class="toggle-btn on" data-value="none">{{ t('route_auth.auth_none') }}</button>
              <button type="button" class="toggle-btn" data-value="basic">{{ t('route_auth.auth_basic') }}</button>
              <button type="button" class="toggle-btn" data-value="route">{{ t('route_auth.auth_route') }}</button>
            </div>
            <input type="hidden" name="auth_type" id="create-auth-type" value="none">
          </div>

          <!-- Basic Auth fields -->
          <div id="create-basic-auth-fields" style="display:none">
            <div class="wiz-row-2">
              <div>
                <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.basic_auth_user') or 'Username' }}</label>
                <input type="text" name="basic_auth_user" placeholder="admin" autocomplete="off" style="width:100%;padding:8px 12px" maxlength="64">
              </div>
              <div>
                <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.basic_auth_password') or 'Password' }}</label>
                <input type="password" name="basic_auth_password" placeholder="••••••••" autocomplete="new-password" style="width:100%;padding:8px 12px" maxlength="128">
              </div>
            </div>
          </div>

          <!-- Route Auth fields -->
          <div id="create-route-auth-fields" style="display:none;margin-bottom:14px">
            <input type="hidden" id="create-ra-method" value="email_password">

            <!-- Single Factor view -->
            <div id="create-ra-single-factor">
              <div class="form-group">
                <label class="form-label">{{ t('route_auth.method') }}</label>
                <div class="toggle-group" id="create-ra-method-group" style="width:100%">
                  <button type="button" class="toggle-btn on" data-value="email_password" style="flex:1">{{ t('route_auth.method_email_password') }}</button>
                  <button type="button" class="toggle-btn" data-value="email_code" style="flex:1">{{ t('route_auth.method_email_code') }}</button>
                  <button type="button" class="toggle-btn" data-value="totp" style="flex:1">{{ t('route_auth.method_totp') }}</button>
                </div>
              </div>

              <div class="wiz-row-2">
                <div id="create-ra-sf-email-group">
                  <label class="form-label">{{ t('route_auth.email') }}</label>
                  <input type="email" id="create-ra-email" placeholder="name@example.com" style="width:100%">
                </div>
                <div id="create-ra-sf-password-group">
                  <label class="form-label">{{ t('route_auth.password') }}</label>
                  <input type="password" id="create-ra-password" autocomplete="new-password" style="width:100%">
                  <small class="form-hint">{{ t('route_auth.password_hint') }}</small>
                </div>
              </div>
              <div id="create-ra-sf-totp-group" style="display:none;margin-bottom:14px">
