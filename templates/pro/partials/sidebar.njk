  <div class="sidebar-footer">
    <div class="sidebar-footer-card">
      <strong>{{ t('common.gateway_host') }}</strong><br>
      {{ wgHost }}<br>
      {{ wgInterface }} &middot; {{ wgGatewayIp }} &middot; :{{ wgPort }}
    </div>
  </div>
</nav>
