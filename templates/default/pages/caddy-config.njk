{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.routing') }}</div>
    <div class="page-title">{{ t('nav.caddy_config') }}</div>
    <div class="page-sub">{{ t('caddy_config.subtitle') }}</div>
  </div>
  <button class="btn btn-ghost" style="margin-top:4px" id="btn-export-caddy">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    {{ t('caddy_config.export') }}
  </button>
</div>

<div class="card">
  <div class="card-head">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    <span class="card-title">{{ t('caddy_config.live_config') }}</span>
    <span class="card-sub" id="caddy-config-info"></span>
  </div>
  <div class="card-body">
    <div class="wg-config" id="caddy-config-view" style="max-height:70vh;overflow-y:auto">{{ t('common.loading') }}</div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/caddy-config.js"></script>
{% endblock %}
