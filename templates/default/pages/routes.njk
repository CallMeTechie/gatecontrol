{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('routes.eyebrow') }}</div>
    <div class="page-title">{{ t('routes.title') }}</div>
    <div class="page-sub" id="routes-subtitle">{{ t('routes.subtitle', { count: '0' }) }}</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:4px">
    <div class="input-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="route-search" placeholder="{{ t('routes.search') or 'Search routes...' }}">
    </div>
    <button class="btn btn-primary" id="btn-add-route">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('routes.add') }}
    </button>
  </div>
</div>

<div class="two-col">
  <div class="card">
    <div class="card-head">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      <span class="card-title">{{ t('routes.active_routes') }}</span>
      <span class="card-sub" id="routes-count">0</span>
    </div>
    <div class="card-body" id="routes-list">
      <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      <span class="card-title">{{ t('routes.new_route') }}</span>
    </div>
    <div class="card-body" style="display:flex;flex-direction:column;gap:14px">
      <form id="route-form">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="form-group">
          <div class="toggle-group" id="route-type-group">
            <button type="button" class="toggle-btn on" data-value="http">{{ t('routes.type_http') }}</button>
            <button type="button" class="toggle-btn" data-value="l4">{{ t('routes.type_l4') }}</button>
          </div>
          <input type="hidden" name="route_type" id="route-type" value="http">
        </div>
        <div style="margin-bottom:14px">
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.domain') }}</label>
          <input type="text" name="domain" placeholder="{{ t('routes.domain_placeholder') }}" style="width:100%;padding:8px 12px" required maxlength="253">
        </div>
        <div style="margin-bottom:14px">
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.description') or 'Description' }}</label>
          <input type="text" name="description" placeholder="{{ t('routes.description_placeholder') or 'Optional description' }}" style="width:100%;padding:8px 12px" maxlength="255">
        </div>
        <div style="margin-bottom:14px">
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.target_peer') }}</label>
          <select name="peer_id" style="width:100%" id="route-peer-select">
            <option value="">—</option>
          </select>
        </div>
        <div style="margin-bottom:14px">
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.target_port') }}</label>
          <input type="text" id="route-port" name="target_port" placeholder="{{ t('routes.target_port_placeholder') }}" style="width:100%;padding:8px 12px" required maxlength="5">
        </div>
        <div id="l4-fields" style="display:none">
          <div class="form-group">
            <label>{{ t('routes.l4_protocol') }}</label>
            <div class="toggle-group" id="l4-protocol-group">
              <button type="button" class="toggle-btn on" data-value="tcp">{{ t('routes.l4_protocol_tcp') }}</button>
              <button type="button" class="toggle-btn" data-value="udp">{{ t('routes.l4_protocol_udp') }}</button>
            </div>
            <input type="hidden" name="l4_protocol" id="l4-protocol" value="tcp">
          </div>
          <div class="form-group">
            <label>{{ t('routes.l4_listen_port') }}</label>
            <input type="text" id="l4-listen-port" name="l4_listen_port" maxlength="11" placeholder="{{ t('routes.l4_listen_port_placeholder') }}">
          </div>
          <div class="form-group">
            <label>{{ t('routes.l4_tls_mode') }}</label>
            <select id="l4-tls-mode" name="l4_tls_mode" class="form-select">
              <option value="none">{{ t('routes.tls_none') }}</option>
              <option value="passthrough">{{ t('routes.tls_passthrough') }}</option>
              <option value="terminate">{{ t('routes.tls_terminate') }}</option>
            </select>
            <small id="l4-tls-hint" class="form-hint" data-hint-none="{{ t('routes.tls_none_hint') }}" data-hint-terminate="{{ t('routes.tls_terminate_hint') }}"></small>
          </div>
        </div>
        <div id="http-fields">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:14px">
            <div>
              <div style="font-size:13px;font-weight:600">{{ t('routes.force_https') }}</div>
              <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.force_https_desc') }}</div>
            </div>
            <div class="toggle on" data-field="https_enabled"></div>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:14px">
            <div>
              <div style="font-size:13px;font-weight:600">Backend HTTPS</div>
              <div style="font-size:11px;color:var(--text-2);margin-top:2px">Backend nutzt HTTPS (z.B. Synology DSM Port 5001)</div>
            </div>
            <div class="toggle" data-field="backend_https"></div>
          </div>
          <!-- Auth type selection -->
          <div class="form-group">
            <label class="form-label">{{ t('route_auth.auth_type') }}</label>
            <div class="toggle-group" id="create-auth-type-group">
              <button type="button" class="toggle-btn on" data-value="none">{{ t('route_auth.auth_none') }}</button>
              <button type="button" class="toggle-btn" data-value="basic">{{ t('route_auth.auth_basic') }}</button>
              <button type="button" class="toggle-btn" data-value="route">{{ t('route_auth.auth_route') }}</button>
            </div>
            <input type="hidden" name="auth_type" id="create-auth-type" value="none">
          </div>

          <!-- Basic Auth fields -->
          <div id="create-basic-auth-fields" style="display:none;margin-bottom:14px">
            <div style="margin-bottom:10px">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.basic_auth_user') or 'Username' }}</label>
              <input type="text" name="basic_auth_user" placeholder="admin" autocomplete="off" style="width:100%;padding:8px 12px" maxlength="64">
            </div>
            <div>
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.basic_auth_password') or 'Password' }}</label>
              <input type="password" name="basic_auth_password" placeholder="••••••••" autocomplete="new-password" style="width:100%;padding:8px 12px" maxlength="128">
            </div>
          </div>

          <!-- Route Auth fields -->
          <div id="create-route-auth-fields" style="display:none;margin-bottom:14px">
            <div class="form-group">
              <label class="form-label">{{ t('route_auth.method') }}</label>
              <div class="toggle-group" id="create-ra-method-group" style="width:100%">
                <button type="button" class="toggle-btn on" data-value="email_password" style="flex:1">{{ t('route_auth.method_email_password') }}</button>
                <button type="button" class="toggle-btn" data-value="email_code" style="flex:1">{{ t('route_auth.method_email_code') }}</button>
                <button type="button" class="toggle-btn" data-value="totp" style="flex:1">{{ t('route_auth.method_totp') }}</button>
              </div>
              <input type="hidden" id="create-ra-method" value="email_password">
              <small class="form-hint" id="create-ra-method-hint" style="display:none">{{ t('route_auth.email_password_is_factor_1') }}</small>
            </div>

            <div class="form-group" id="create-ra-email-group">
              <label class="form-label">{{ t('route_auth.email') }}</label>
              <input type="email" id="create-ra-email" placeholder="name@example.com" style="width:100%">
            </div>

            <div class="form-group" id="create-ra-password-group">
              <label class="form-label">{{ t('route_auth.password') }}</label>
              <input type="password" id="create-ra-password" autocomplete="new-password" style="width:100%">
              <small class="form-hint">{{ t('route_auth.password_hint') }}</small>
            </div>

            <div id="create-ra-totp-group" style="display:none;margin-bottom:14px">
              <div style="font-size:12px;color:var(--text-3);padding:10px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);text-align:center">
                {{ t('route_auth.totp_setup') }} — {{ t('route_auth.totp_scan_qr') }}<br>
                <small style="color:var(--text-3)">TOTP kann nach dem Erstellen der Route eingerichtet werden.</small>
              </div>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:14px">
              <div>
                <div style="font-size:13px;font-weight:600">{{ t('route_auth.two_factor') }}</div>
                <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('route_auth.two_factor_desc') }}</div>
              </div>
              <div class="toggle" id="create-ra-2fa"></div>
            </div>

            <div class="form-group">
              <label class="form-label">{{ t('route_auth.session_duration') }}</label>
              <select id="create-ra-session-duration" class="form-select" style="width:100%">
                <option value="3600000">{{ t('route_auth.session_1h') }}</option>
                <option value="43200000">{{ t('route_auth.session_12h') }}</option>
                <option value="86400000" selected>{{ t('route_auth.session_24h') }}</option>
                <option value="604800000">{{ t('route_auth.session_7d') }}</option>
                <option value="2592000000">{{ t('route_auth.session_30d') }}</option>
              </select>
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:10px 16px">
          {{ t('routes.save_reload') }}
        </button>
      </form>
    </div>
  </div>
</div>

{% include theme + "/partials/modals/route-edit.njk" %}
{% include theme + "/partials/modals/confirm.njk" %}
{% endblock %}

{% block scripts %}
<script src="/js/routes.js"></script>
{% endblock %}
