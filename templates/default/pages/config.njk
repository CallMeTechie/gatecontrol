{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('config.eyebrow') }}</div>
    <div class="page-title">{{ t('config.title') }}</div>
    <div class="page-sub">{{ t('config.subtitle', { iface: wgInterface }) }} · {{ wgInterface }}.conf</div>
  </div>
  <button class="btn btn-ghost" style="margin-top:4px" id="btn-export-config">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    {{ t('config.export') }}
  </button>
</div>

<div class="two-col">
  <div class="card">
    <div class="card-head">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      <span class="card-title">{{ wgInterface }}.conf</span>
    </div>
    <div class="card-body">
      <div class="wg-config" id="wg-config-view">{{ t('common.loading') }}</div>
    </div>
  </div>

  <div style="display:flex;flex-direction:column;gap:14px">
    <div class="card">
      <div class="card-head"><span class="card-title">{{ t('config.interface_settings') }}</span></div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.listen_port') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;color:var(--accent);background:var(--accent-lt);padding:2px 8px;border-radius:4px;border:1px solid var(--accent-md)">{{ wgPort }} / UDP</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.subnet') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgSubnet }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.gateway_ip') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgGatewayIp }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.interface') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgInterface }}</code>
        </div>
        <div style="display:flex;gap:8px;padding-top:12px;border-top:1px solid var(--border)">
          <button class="btn btn-ghost" style="flex:1;justify-content:center" id="btn-wg-restart">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
            {{ t('config.restart') }}
          </button>
          <button class="btn btn-ghost" style="flex:1;justify-content:center;color:var(--amber);border-color:var(--amber-bd)" id="btn-wg-stop">{{ t('config.stop') }}</button>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">{{ t('config.caddy_status') }}</span></div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:10px">
        <div style="display:flex;align-items:center;gap:8px" id="caddy-status-indicator">
          <div class="pulse-dot"></div>
          <span style="font-size:13px;color:var(--green);font-weight:600">{{ t('config.caddy_running') }}</span>
        </div>
        <div style="font-size:12px;color:var(--text-2)" id="caddy-info">{{ t('config.https_active') }} · Let's Encrypt</div>
        <button class="btn btn-ghost" style="width:100%;justify-content:center;font-size:12px" id="btn-caddy-reload">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
          {{ t('config.caddy_reload') }}
        </button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/config.js"></script>
{% endblock %}
