{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.system') }}</div>
    <div class="page-title">{{ t('nav.settings') }}</div>
    <div class="page-sub">{{ t('settings.subtitle') }}</div>
  </div>
</div>

<div class="two-col">
  {# ─── App Info & Webhooks ───────────────────────────── #}
  <div style="display:flex;flex-direction:column;gap:14px">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        <span class="card-title">{{ t('settings.app_info') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.app_name') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;font-weight:600">{{ appName }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.version') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">v{{ appVersion }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.wg_host') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;color:var(--accent)">{{ wgHost }}:{{ wgPort }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.subnet') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgSubnet }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.default_language') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ language }}</code>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="card-title">{{ t('webhooks.title') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">{{ t('webhooks.subtitle') }}</div>
        <div id="webhooks-list"></div>
        <div style="display:flex;flex-direction:column;gap:8px;padding-top:8px;border-top:1px solid var(--border)">
          <input type="text" id="webhook-url" placeholder="{{ t('webhooks.url_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="500">
          <input type="text" id="webhook-desc" placeholder="{{ t('webhooks.description_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="255">
          <button class="btn btn-primary" id="btn-add-webhook" style="align-self:flex-start">
            {{ t('webhooks.add') }}
          </button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span class="card-title">{{ t('route_auth.smtp_server_settings') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">{{ t('route_auth.smtp_subtitle') }}</div>
        <div style="display:flex;gap:10px">
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label">{{ t('route_auth.smtp_host') }}</label>
            <input type="text" id="smtp-host" placeholder="smtp.gmail.com" style="width:100%">
          </div>
          <div class="form-group" style="width:100px;margin-bottom:0">
            <label class="form-label">{{ t('route_auth.smtp_port') }}</label>
            <input type="text" id="smtp-port" placeholder="587" style="width:100%">
          </div>
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label">{{ t('route_auth.smtp_user') }}</label>
          <input type="text" id="smtp-user" placeholder="user@gmail.com" style="width:100%">
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label">{{ t('route_auth.smtp_password') }}</label>
          <input type="password" id="smtp-password" style="width:100%">
          <small class="form-hint" id="smtp-password-hint" style="display:none"></small>
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label">{{ t('route_auth.smtp_from') }}</label>
          <input type="email" id="smtp-from" placeholder="noreply@example.com" style="width:100%">
          <small class="form-hint">{{ t('route_auth.smtp_from_hint') }}</small>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('route_auth.smtp_tls') }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('route_auth.smtp_tls_desc') }}</div>
          </div>
          <div class="toggle on" id="smtp-tls" data-managed="true"></div>
        </div>
        <div style="display:flex;justify-content:flex-end;padding-top:4px">
          <button class="btn btn-primary" id="btn-smtp-save">{{ t('route_auth.smtp_save') }}</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        <span class="card-title">{{ t('route_auth.smtp_test') }}</span>
      </div>
      <div class="card-body">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:10px">{{ t('route_auth.smtp_test_desc') }}</div>
        <div style="display:flex;gap:8px">
          <input type="email" id="smtp-test-email" placeholder="{{ t('route_auth.smtp_test_email_placeholder') }}" style="flex:1">
          <button class="btn btn-ghost" id="btn-smtp-test">{{ t('route_auth.smtp_test_send') }}</button>
        </div>
        <div id="smtp-test-result" style="display:none;padding:8px 12px;border-radius:var(--radius-xs);font-size:12px;font-family:var(--font-mono);margin-top:10px"></div>
      </div>
    </div>
  </div>

  {# ─── Backup & Danger Zone ─────────────────────────── #}
  <div style="display:flex;flex-direction:column;gap:14px">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span class="card-title">{{ t('settings.backup') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:14px">
        <div style="font-size:12px;color:var(--text-3)">{{ t('settings.backup_subtitle') }}</div>
        <div style="display:flex;flex-direction:column;gap:8px;padding-bottom:14px;border-bottom:1px solid var(--border)">
          <div style="font-size:13px;font-weight:500">{{ t('settings.backup_download') }}</div>
          <div style="font-size:11px;color:var(--text-3)">{{ t('settings.backup_download_desc') }}</div>
          <button class="btn btn-primary" id="btn-backup-download" style="align-self:flex-start">
            {{ t('settings.backup_download') }}
          </button>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="font-size:13px;font-weight:500">{{ t('settings.restore') }}</div>
          <div style="font-size:11px;color:var(--text-3)">{{ t('settings.restore_desc') }}</div>
          <input type="file" id="backup-file-input" accept=".json" style="display:none">
          <div id="backup-preview" style="display:none;padding:10px;border-radius:6px;background:var(--bg-2);font-size:12px;font-family:var(--font-mono)"></div>
          <div id="restore-message" style="display:none"></div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-ghost" id="btn-backup-select" style="flex:0 0 auto">
              {{ t('settings.restore_select') }}
            </button>
            <button class="btn btn-primary" id="btn-backup-restore" style="flex:0 0 auto;display:none">
              {{ t('settings.restore_confirm') }}
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        <span class="card-title">{{ t('security.title') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:14px">
        {# Account Lockout #}
        <div style="font-size:13px;font-weight:600">{{ t('security.lockout.title') }}</div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
          <span style="font-size:13px">{{ t('security.lockout.enabled') }}</span>
          <div class="toggle on" id="security-lockout-enabled" data-managed="true"></div>
        </div>
        <div style="display:flex;gap:10px">
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label" for="security-lockout-attempts">{{ t('security.lockout.max_attempts') }}</label>
            <input type="number" id="security-lockout-attempts" value="5" min="1" max="100" style="width:100%">
          </div>
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label" for="security-lockout-duration">{{ t('security.lockout.duration') }}</label>
            <input type="number" id="security-lockout-duration" value="15" min="1" max="1440" style="width:100%">
          </div>
        </div>

        {# Locked accounts list #}
        <div style="font-size:12px;font-weight:600;color:var(--text-2)">{{ t('security.lockout.locked_accounts') }}</div>
        <div id="security-locked-list" style="font-size:12px;color:var(--text-3)">{{ t('security.lockout.no_locked') }}</div>

        <div style="border-top:1px solid var(--border);padding-top:14px;margin-top:2px">
          {# Password Complexity #}
          <div style="font-size:13px;font-weight:600;margin-bottom:10px">{{ t('security.password.title') }}</div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:10px">
            <span style="font-size:13px">{{ t('security.password.enabled') }}</span>
            <div class="toggle" id="security-password-enabled" data-managed="true"></div>
          </div>
          <div class="form-group" style="margin-bottom:10px">
            <label class="form-label" for="security-password-min-length">{{ t('security.password.min_length') }}</label>
            <input type="number" id="security-password-min-length" value="8" min="4" max="128" style="width:100%">
          </div>
          <div style="display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <span style="font-size:12px">{{ t('security.password.require_uppercase') }}</span>
              <div class="toggle on" id="security-password-uppercase" data-managed="true"></div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <span style="font-size:12px">{{ t('security.password.require_number') }}</span>
              <div class="toggle on" id="security-password-number" data-managed="true"></div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <span style="font-size:12px">{{ t('security.password.require_special') }}</span>
              <div class="toggle on" id="security-password-special" data-managed="true"></div>
            </div>
          </div>
        </div>

        <div id="security-message" style="display:none"></div>
        <div style="display:flex;justify-content:flex-end;padding-top:4px">
          <button class="btn btn-primary" id="btn-security-save">{{ t('security.save') }}</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <span class="card-title">{{ t('monitoring.settings_title') or 'Uptime Monitoring' }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="monitoring-interval">{{ t('monitoring.interval') or 'Check interval (seconds)' }}</label>
          <input type="number" id="monitoring-interval" value="60" min="10" max="3600" style="width:100%">
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('monitoring.email_alerts') or 'Email alerts' }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('monitoring.email_alerts_desc') or 'Send email on status change' }}</div>
          </div>
          <div class="toggle" id="monitoring-email-alerts" data-managed="true"></div>
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="monitoring-alert-email">{{ t('monitoring.alert_email') or 'Alert email address' }}</label>
          <input type="email" id="monitoring-alert-email" placeholder="admin@example.com" style="width:100%">
        </div>
        <div id="monitoring-message" style="display:none"></div>
        <div style="display:flex;justify-content:flex-end;padding-top:4px">
          <button class="btn btn-primary" id="btn-monitoring-save">{{ t('monitoring.save') or 'Save' }}</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span class="card-title">{{ t('alerts.title') or 'Email Alerts' }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">{{ t('alerts.subtitle') or 'Get notified by email when events occur. Requires SMTP to be configured.' }}</div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="alerts-email">{{ t('alerts.email') or 'Alert email address' }}</label>
          <input type="email" id="alerts-email" placeholder="admin@example.com" style="width:100%">
        </div>
        <div style="font-size:12px;font-weight:600;color:var(--text-2);margin-top:4px">{{ t('alerts.events_label') or 'Notify on these events:' }}</div>
        <div id="alerts-events" style="display:flex;flex-direction:column;gap:6px">
          {% set alertGroups = [
            { label: t('alerts.group_security') or 'Security', events: 'login_failed,account_locked,password_changed' },
            { label: t('alerts.group_peers') or 'Peers', events: 'peer_connected,peer_disconnected,peer_created,peer_deleted' },
            { label: t('alerts.group_routes') or 'Routes', events: 'route_down,route_up,route_created,route_deleted' },
            { label: t('alerts.group_system') or 'System', events: 'system_start,wg_restart,backup_restored,backup_reminder,resource_alert' }
          ] %}
          {% for g in alertGroups %}
          <label style="display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;font-size:12px">
            <input type="checkbox" class="alert-event-group" data-events="{{ g.events }}" style="accent-color:var(--accent)">
            <span>{{ g.label }}</span>
          </label>
          {% endfor %}
        </div>
        <div style="border-top:1px solid var(--border);padding-top:10px;margin-top:4px">
          <div style="font-size:12px;font-weight:600;color:var(--text-2);margin-bottom:8px">{{ t('alerts.extra_checks') or 'Periodic checks' }}</div>
          <div class="form-group" style="margin-bottom:8px">
            <label class="form-label" for="alerts-backup-days">{{ t('alerts.backup_reminder') or 'Backup reminder (days, 0=off)' }}</label>
            <input type="number" id="alerts-backup-days" value="0" min="0" max="365" style="width:100%">
          </div>
          <div style="display:flex;gap:10px">
            <div class="form-group" style="flex:1;margin-bottom:0">
              <label class="form-label" for="alerts-cpu">{{ t('alerts.cpu_threshold') or 'CPU alert (%, 0=off)' }}</label>
              <input type="number" id="alerts-cpu" value="0" min="0" max="100" style="width:100%">
            </div>
            <div class="form-group" style="flex:1;margin-bottom:0">
              <label class="form-label" for="alerts-ram">{{ t('alerts.ram_threshold') or 'RAM alert (%, 0=off)' }}</label>
              <input type="number" id="alerts-ram" value="0" min="0" max="100" style="width:100%">
            </div>
          </div>
        </div>
        <div id="alerts-message" style="display:none"></div>
        <div style="display:flex;justify-content:flex-end;padding-top:4px">
          <button class="btn btn-primary" id="btn-alerts-save">{{ t('alerts.save') or 'Save' }}</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="card-title">{{ t('settings.danger_zone') }}</span>
      </div>
      <div class="card-body">
        <button class="btn btn-ghost" style="color:var(--red);border-color:var(--red-bd);width:100%;justify-content:center" id="btn-clear-logs">
          {{ t('settings.clear_logs') }}
        </button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/settings.js"></script>
{% endblock %}
