{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.system') }}</div>
    <div class="page-title">{{ t('nav.settings') }}</div>
    <div class="page-sub">{{ t('settings.subtitle') }}</div>
  </div>
</div>

<div class="two-col">
  {# ─── App Info & Webhooks ───────────────────────────── #}
  <div style="display:flex;flex-direction:column;gap:14px">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        <span class="card-title">{{ t('settings.app_info') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.app_name') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;font-weight:600">{{ appName }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.version') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">v{{ appVersion }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.wg_host') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;color:var(--accent)">{{ wgHost }}:{{ wgPort }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.subnet') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgSubnet }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.default_language') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ language }}</code>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="card-title">{{ t('webhooks.title') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">{{ t('webhooks.subtitle') }}</div>
        <div id="webhooks-list"></div>
        <div style="display:flex;flex-direction:column;gap:8px;padding-top:8px;border-top:1px solid var(--border)">
          <input type="text" id="webhook-url" placeholder="{{ t('webhooks.url_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="500">
          <input type="text" id="webhook-desc" placeholder="{{ t('webhooks.description_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="255">
          <button class="btn btn-primary" id="btn-add-webhook" style="align-self:flex-start">
            {{ t('webhooks.add') }}
          </button>
        </div>
      </div>
    </div>
  </div>

  {# ─── Backup & Danger Zone ─────────────────────────── #}
  <div style="display:flex;flex-direction:column;gap:14px">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span class="card-title">{{ t('settings.backup') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:14px">
        <div style="font-size:12px;color:var(--text-3)">{{ t('settings.backup_subtitle') }}</div>
        <div style="display:flex;flex-direction:column;gap:8px;padding-bottom:14px;border-bottom:1px solid var(--border)">
          <div style="font-size:13px;font-weight:500">{{ t('settings.backup_download') }}</div>
          <div style="font-size:11px;color:var(--text-3)">{{ t('settings.backup_download_desc') }}</div>
          <button class="btn btn-primary" id="btn-backup-download" style="align-self:flex-start">
            {{ t('settings.backup_download') }}
          </button>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="font-size:13px;font-weight:500">{{ t('settings.restore') }}</div>
          <div style="font-size:11px;color:var(--text-3)">{{ t('settings.restore_desc') }}</div>
          <input type="file" id="backup-file-input" accept=".json" style="display:none">
          <div id="backup-preview" style="display:none;padding:10px;border-radius:6px;background:var(--bg-2);font-size:12px;font-family:var(--font-mono)"></div>
          <div id="restore-message" style="display:none"></div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-ghost" id="btn-backup-select" style="flex:0 0 auto">
              {{ t('settings.restore_select') }}
            </button>
            <button class="btn btn-primary" id="btn-backup-restore" style="flex:0 0 auto;display:none">
              {{ t('settings.restore_confirm') }}
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="card-title">{{ t('settings.danger_zone') }}</span>
      </div>
      <div class="card-body">
        <button class="btn btn-ghost" style="color:var(--red);border-color:var(--red-bd);width:100%;justify-content:center" id="btn-clear-logs">
          {{ t('settings.clear_logs') }}
        </button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/settings.js"></script>
{% endblock %}
