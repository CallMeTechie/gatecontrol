{% extends theme + "/layout.njk" %}

{% block content %}
<style nonce="{{ cspNonce }}">
.settings-tabs {
  display: flex;
  gap: 0;
  border-bottom: 2px solid var(--border);
  margin-bottom: 20px;
  overflow: visible;
  position: sticky;
  top: 0;
  background: var(--bg-panel);
  z-index: 10;
  flex-shrink: 0;
}
.settings-tabs .tab {
  padding: 10px 18px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-2);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  white-space: nowrap;
  border-radius: 0;
  transition: color 0.15s, border-color 0.15s;
}
.settings-tabs .tab:hover {
  color: var(--text-1);
}
.settings-tabs .tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  background: none;
  box-shadow: none;
}
.settings-panel {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ─── Mobile: Hamburger Dropdown ─────────────────────── */
.settings-tab-toggle {
  display: none;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  width: 100%;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  color: var(--text-1);
  font-size: 13px;
  font-weight: 500;
}
.settings-tab-toggle svg {
  flex-shrink: 0;
  transition: transform 0.2s;
}
.settings-tab-toggle.open svg {
  transform: rotate(180deg);
}
.settings-tab-dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-top: none;
  border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  box-shadow: var(--shadow);
  z-index: 20;
  flex-direction: column;
}
.settings-tab-dropdown.open {
  display: flex;
}
.settings-tab-dropdown .tab {
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-2);
  cursor: pointer;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  transition: background 0.1s, color 0.1s;
  white-space: nowrap;
  margin-bottom: 0;
}
.settings-tab-dropdown .tab:last-child {
  border-bottom: none;
}
.settings-tab-dropdown .tab:hover {
  background: var(--bg-hover);
  color: var(--text-1);
}
.settings-tab-dropdown .tab.active {
  color: var(--accent);
  background: none;
  font-weight: 600;
  border-left: 3px solid var(--accent);
  box-shadow: none;
}

@media (max-width: 900px) {
  .settings-tabs {
    position: relative;
    border-bottom: none;
    margin-bottom: 16px;
  }
  .settings-tabs > .tab {
    display: none;
  }
  .settings-tab-toggle {
    display: flex;
  }
}
</style>

<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.system') }}</div>
    <div class="page-title">{{ t('nav.settings') }}</div>
    <div class="page-sub">{{ t('settings.subtitle') }}</div>
  </div>
</div>

<div class="settings-tabs">
  <button class="settings-tab-toggle" aria-expanded="false" aria-controls="settings-tab-dropdown">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    <span class="settings-tab-label">{{ t('settings.tab_general') }}</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:auto"><polyline points="6 9 12 15 18 9"/></svg>
  </button>
  <div class="settings-tab-dropdown" id="settings-tab-dropdown">
    <div class="tab active" data-settings-tab="general">{{ t('settings.tab_general') }}</div>
    <div class="tab" data-settings-tab="security">{{ t('settings.tab_security') }}</div>
    <div class="tab" data-settings-tab="backup">{{ t('settings.tab_backup') }}</div>
    <div class="tab" data-settings-tab="email">{{ t('settings.tab_email') }}</div>
    <div class="tab" data-settings-tab="monitoring">{{ t('settings.tab_monitoring') }}</div>
    <div class="tab" data-settings-tab="api">{{ t('settings.tab_api') }}</div>
    <div class="tab" data-settings-tab="advanced">{{ t('settings.tab_advanced') }}</div>
    <div class="tab" data-settings-tab="license">{{ t('settings.tab_license') }}</div>
  </div>
  <div class="tab active" data-settings-tab="general">{{ t('settings.tab_general') }}</div>
  <div class="tab" data-settings-tab="security">{{ t('settings.tab_security') }}</div>
  <div class="tab" data-settings-tab="backup">{{ t('settings.tab_backup') }}</div>
  <div class="tab" data-settings-tab="email">{{ t('settings.tab_email') }}</div>
  <div class="tab" data-settings-tab="monitoring">{{ t('settings.tab_monitoring') }}</div>
  <div class="tab" data-settings-tab="api">{{ t('settings.tab_api') }}</div>
  <div class="tab" data-settings-tab="advanced">{{ t('settings.tab_advanced') }}</div>
  <div class="tab" data-settings-tab="license">{{ t('settings.tab_license') }}</div>
</div>

{# ─── General Tab ─────────────────────────────────────── #}
<div class="settings-panel" data-settings-panel="general">
  <div class="two-col">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        <span class="card-title">{{ t('settings.app_info') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.app_name') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;font-weight:600">{{ appName }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.version') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">v{{ appVersion }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.wg_host') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;color:var(--accent)">{{ wgHost }}:{{ wgPort }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.subnet') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgSubnet }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:13px;color:var(--text-2)">{{ t('settings.default_language') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ language }}</code>
        </div>
      </div>
    </div>

    <div>
      <div class="card">
        <div class="card-head">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <span class="card-title">{{ t('settings.dns') }}</span>
        </div>
        <div class="card-body">
          {% if license.features.custom_dns %}
          <div style="margin-bottom:8px">
            <input type="text" id="settings-dns-input" placeholder="{{ t('peers.dns_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12.5px;font-family:var(--font-mono)">
          </div>
          <div style="font-size:11px;color:var(--text-3);margin-bottom:12px">{{ t('settings.dns_desc') }}</div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn btn-primary" id="btn-dns-save">{{ t('data.save') or 'Save' }}</button>
          </div>
          {% else %}
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0">
            <span style="font-size:13px;color:var(--text-2)">{{ t('settings.dns') }} <span class="lock-icon"></span></span>
            <code style="font-family:var(--font-mono);font-size:12px;color:var(--text-3)">{{ wgDns }}</code>
          </div>
          <div style="font-size:11px;color:var(--text-3)">{{ t('settings.dns_desc') }}</div>
          {% endif %}
        </div>
      </div>

      <div class="card" style="margin-top:14px">
        <div class="card-head">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <span class="card-title">{{ t('data.title') or 'Data & Retention' }}</span>
        </div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
          <div style="display:flex;gap:10px">
            <div class="form-group" style="flex:1;margin-bottom:0">
              <label class="form-label" for="data-traffic-days">{{ t('data.traffic_retention') or 'Traffic data (days)' }}</label>
              <input type="number" id="data-traffic-days" value="30" min="1" max="365" style="width:100%">
            </div>
            <div class="form-group" style="flex:1;margin-bottom:0">
              <label class="form-label" for="data-activity-days">{{ t('data.activity_retention') or 'Activity logs (days)' }}</label>
              <input type="number" id="data-activity-days" value="30" min="1" max="365" style="width:100%">
            </div>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="data-peer-timeout">{{ t('data.peer_timeout') or 'Peer online timeout (seconds)' }}</label>
            <input type="number" id="data-peer-timeout" value="180" min="30" max="600" style="width:100%">
            <small class="form-hint">{{ t('data.peer_timeout_hint') or 'Peer is considered offline after no handshake for this many seconds' }}</small>
          </div>
          <div id="data-message" style="display:none"></div>
          <div style="display:flex;justify-content:flex-end;padding-top:4px">
            <button class="btn btn-primary" id="btn-data-save">{{ t('data.save') or 'Save' }}</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# ─── Service Management ──────────────────────────── #}
  <div class="two-col">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="17" cy="7" r="3"/><circle cx="7" cy="17" r="3"/><path d="M14 10l-4 4"/><circle cx="7" cy="7" r="3"/><circle cx="17" cy="17" r="3"/></svg>
        <span class="card-title">{{ t('config.wg_service') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.listen_port') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px;color:var(--accent);background:var(--accent-lt);padding:2px 8px;border-radius:4px;border:1px solid var(--accent-md)">{{ wgPort }} / UDP</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.gateway_ip') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgGatewayIp }}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
          <span style="font-size:13px;color:var(--text-2)">{{ t('config.interface') }}</span>
          <code style="font-family:var(--font-mono);font-size:12px">{{ wgInterface }}</code>
        </div>
        <div style="display:flex;gap:8px;padding-top:4px">
          <button class="btn btn-ghost" style="flex:1;justify-content:center" id="btn-svc-wg-restart">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
            {{ t('config.restart') }}
          </button>
          <button class="btn btn-ghost" style="flex:1;justify-content:center;color:var(--amber);border-color:var(--amber-bd)" id="btn-svc-wg-stop">{{ t('config.stop') }}</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        <span class="card-title">{{ t('config.caddy_service') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:10px">
        <div style="display:flex;align-items:center;gap:8px" id="svc-caddy-status">
          <div class="pulse-dot"></div>
          <span style="font-size:13px;color:var(--green);font-weight:600">{{ t('config.caddy_running') }}</span>
        </div>
        <div style="font-size:12px;color:var(--text-2)" id="svc-caddy-info">{{ t('config.https_active') }} · Let's Encrypt</div>
        <button class="btn btn-ghost" style="width:100%;justify-content:center;font-size:12px" id="btn-svc-caddy-reload">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
          {{ t('config.caddy_reload') }}
        </button>
      </div>
    </div>
  </div>

  {# ─── WG Stop Password Modal ────────────────────── #}
  <div id="wg-stop-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div style="background:var(--bg-panel);border:1px solid var(--border);border-radius:var(--radius-md);padding:24px;max-width:400px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,.2)">
      <div style="font-size:15px;font-weight:600;color:var(--text-1);margin-bottom:4px">{{ t('config.stop_confirm_title') }}</div>
      <div style="font-size:13px;color:var(--text-2);margin-bottom:16px">{{ t('config.stop_confirm_text') }}</div>
      <input type="password" id="wg-stop-password" placeholder="{{ t('config.password_placeholder') }}" style="width:100%;padding:10px 12px;font-size:13px;margin-bottom:12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg-1);color:var(--text-1)" autocomplete="current-password">
      <div id="wg-stop-error" style="display:none;font-size:12px;color:var(--red);margin-bottom:8px"></div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button class="btn btn-ghost" id="wg-stop-cancel">{{ t('config.cancel') }}</button>
        <button class="btn btn-ghost" style="color:var(--amber);border-color:var(--amber-bd)" id="wg-stop-confirm">{{ t('config.confirm') }}</button>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <span class="card-title">{{ t('settings.danger_zone') }}</span>
    </div>
    <div class="card-body">
      <button class="btn btn-ghost" style="color:var(--red);border-color:var(--red-bd);width:100%;justify-content:center" id="btn-clear-logs">
        {{ t('settings.clear_logs') }}
      </button>
    </div>
  </div>
</div>

{# ─── Security Tab ────────────────────────────────────── #}
<div class="settings-panel" data-settings-panel="security" style="display:none">
  <div class="two-col">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        <span class="card-title">{{ t('security.lockout.title') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:14px">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
          <span style="font-size:13px">{{ t('security.lockout.enabled') }}</span>
          <div class="toggle on" id="security-lockout-enabled" data-managed="true"></div>
        </div>
        <div style="display:flex;gap:10px">
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label" for="security-lockout-attempts">{{ t('security.lockout.max_attempts') }}</label>
            <input type="number" id="security-lockout-attempts" value="5" min="1" max="100" style="width:100%">
          </div>
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label" for="security-lockout-duration">{{ t('security.lockout.duration') }}</label>
            <input type="number" id="security-lockout-duration" value="15" min="1" max="1440" style="width:100%">
          </div>
        </div>

        {# Locked accounts list #}
        <div style="font-size:12px;font-weight:600;color:var(--text-2)">{{ t('security.lockout.locked_accounts') }}</div>
        <div id="security-locked-list" style="font-size:12px;color:var(--text-3)">{{ t('security.lockout.no_locked') }}</div>

        <div id="security-message" style="display:none"></div>
        <div style="display:flex;justify-content:flex-end;padding-top:4px">
          <button class="btn btn-primary" id="btn-security-save">{{ t('security.save') }}</button>
        </div>
      </div>
    </div>

    <div>
      <div class="card">
        <div class="card-head">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span class="card-title">{{ t('security.password.title') }}</span>
        </div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:14px">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
            <span style="font-size:13px">{{ t('security.password.enabled') }}</span>
            <div class="toggle" id="security-password-enabled" data-managed="true"></div>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="security-password-min-length">{{ t('security.password.min_length') }}</label>
            <input type="number" id="security-password-min-length" value="8" min="4" max="128" style="width:100%">
          </div>
          <div style="display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <span style="font-size:12px">{{ t('security.password.require_uppercase') }}</span>
              <div class="toggle on" id="security-password-uppercase" data-managed="true"></div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <span style="font-size:12px">{{ t('security.password.require_number') }}</span>
              <div class="toggle on" id="security-password-number" data-managed="true"></div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)">
              <span style="font-size:12px">{{ t('security.password.require_special') }}</span>
