        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/><circle cx="12" cy="16" r="1"/></svg>
        <span class="card-title">{{ t('tokens.create_title') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">{{ t('tokens.subtitle') }}</div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label">{{ t('tokens.name') }}</label>
          <input type="text" id="token-name" placeholder="{{ t('tokens.name_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="100">
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label">{{ t('tokens.scopes') }}</label>
          <div id="token-scopes" style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            {# ── Left column: Access Level + Server scopes ── #}
            <div style="display:flex;flex-direction:column;gap:8px">
              {# ── Access Level ── #}
              <div>
                <div style="font-size:10px;color:var(--text-3);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.5px">{{ t('tokens.scope_group_access') }}</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px">
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer">
                    <input type="checkbox" value="full-access" class="token-scope-cb" id="scope-full-access" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_full_access') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer">
                    <input type="checkbox" value="read-only" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_read_only') }}
                  </label>
                </div>
              </div>
              {# ── Resources ── #}
              <div id="token-scope-resources">
                <div style="font-size:10px;color:var(--text-3);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.5px">{{ t('tokens.scope_group_resources') }}</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px">
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_peers_desc') }}">
                    <input type="checkbox" value="peers" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_peers') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_routes_desc') }}">
                    <input type="checkbox" value="routes" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_routes') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_settings_desc') }}">
                    <input type="checkbox" value="settings" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_settings') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_webhooks_desc') }}">
                    <input type="checkbox" value="webhooks" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_webhooks') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_logs_desc') }}">
                    <input type="checkbox" value="logs" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_logs') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_system_desc') }}">
                    <input type="checkbox" value="system" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_system') }}
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_backup_desc') }}">
                    <input type="checkbox" value="backup" class="token-scope-cb token-scope-resource" style="accent-color:var(--accent)">
                    {{ t('tokens.scope_backup') }}
                  </label>
                </div>
              </div>
            </div>
            {# ── Right column: Client App scopes + options ── #}
            <div style="display:flex;flex-direction:column;gap:8px">
              {# ── Client App ── #}
              <div>
                <div style="font-size:10px;color:var(--text-3);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.5px">{{ t('tokens.scope_group_client') }}</div>
                <div style="display:flex;flex-direction:column;gap:4px">
                  <label style="display:flex;align-items:flex-start;gap:6px;font-size:11px;padding:6px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_client_desc') }}">
                    <input type="checkbox" value="client" class="token-scope-cb token-scope-resource" id="scope-client" style="accent-color:var(--accent);margin-top:2px">
                    <div>
                      <div>{{ t('tokens.scope_client') }}</div>
                      <div style="font-size:9px;color:var(--text-3);margin-top:1px">{{ t('tokens.scope_client_desc') }}</div>
                    </div>
                  </label>
                  <div id="client-sub-scopes" style="margin-left:20px;display:flex;flex-direction:column;gap:4px">
                    <label style="display:flex;align-items:flex-start;gap:6px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_client_services_desc') }}">
                      <input type="checkbox" value="client:services" class="token-scope-cb token-scope-resource token-scope-client-sub" style="accent-color:var(--accent);margin-top:2px">
                      <div>
                        <div>{{ t('tokens.scope_client_services') }}</div>
                        <div style="font-size:9px;color:var(--text-3);margin-top:1px">{{ t('tokens.scope_client_services_desc') }}</div>
                      </div>
                    </label>
                    <label style="display:flex;align-items:flex-start;gap:6px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_client_traffic_desc') }}">
                      <input type="checkbox" value="client:traffic" class="token-scope-cb token-scope-resource token-scope-client-sub" style="accent-color:var(--accent);margin-top:2px">
                      <div>
                        <div>{{ t('tokens.scope_client_traffic') }}</div>
                        <div style="font-size:9px;color:var(--text-3);margin-top:1px">{{ t('tokens.scope_client_traffic_desc') }}</div>
                      </div>
                    </label>
                    <label style="display:flex;align-items:flex-start;gap:6px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_client_dns_desc') }}">
                      <input type="checkbox" value="client:dns" class="token-scope-cb token-scope-resource token-scope-client-sub" style="accent-color:var(--accent);margin-top:2px">
                      <div>
                        <div>{{ t('tokens.scope_client_dns') }}</div>
                        <div style="font-size:9px;color:var(--text-3);margin-top:1px">{{ t('tokens.scope_client_dns_desc') }}</div>
                      </div>
                    </label>
                    <label style="display:flex;align-items:flex-start;gap:6px;font-size:11px;padding:4px 8px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer" title="{{ t('tokens.scope_client_rdp_desc') }}">
                      <input type="checkbox" value="client:rdp" class="token-scope-cb token-scope-resource token-scope-client-sub" style="accent-color:var(--accent);margin-top:2px">
                      <div>
                        <div>{{ t('tokens.scope_client_rdp') }}</div>
                        <div style="font-size:9px;color:var(--text-3);margin-top:1px">{{ t('tokens.scope_client_rdp_desc') }}</div>
                      </div>
                    </label>
                  </div>
                </div>
              </div>
              <div id="token-mb-wrap" style="display:none;margin-top:8px">
                <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer">
                  <input type="checkbox" id="token-machine-binding">
                  {{ t('tokens.machine_binding') }}
                </label>
              </div>
              <div class="form-group" style="margin-bottom:0">
                <label class="form-label">{{ t('tokens.expires') }}</label>
                <select id="token-expires" style="width:100%;padding:8px 12px;font-size:12px">
                  <option value="">{{ t('tokens.expires_never') }}</option>
                  <option value="30d">{{ t('tokens.expires_30d') }}</option>
                  <option value="90d">{{ t('tokens.expires_90d') }}</option>
                  <option value="1y">{{ t('tokens.expires_1y') }}</option>
                  <option value="custom">{{ t('tokens.expires_custom') }}</option>
                </select>
                <input type="date" id="token-expires-custom" style="display:none;width:100%;padding:8px 12px;font-size:12px;margin-top:6px">
              </div>
              <button class="btn btn-primary" id="btn-create-token" style="align-self:flex-start">
                {{ t('tokens.add') }}
              </button>
            </div>
          </div>
        </div>
        <div id="token-created-result" style="display:none"></div>
        <div id="tokens-message" style="display:none"></div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/><circle cx="12" cy="16" r="1"/></svg>
        <span class="card-title">{{ t('tokens.active_title') }}</span>
      </div>
      <div class="card-body">
        <div id="tokens-list"></div>
      </div>
    </div>
</div>

{# ─── Advanced Tab ────────────────────────────────────── #}
<div class="settings-panel" data-settings-panel="advanced" style="display:none">
  <div class="two-col">
    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        <span class="card-title">{{ t('ip2location.title') or 'ip2location (Geo-IP)' }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
        <div style="font-size:12px;color:var(--text-3)">{{ t('ip2location.subtitle') or 'API key for country-based IP access control. Get a free key at ip2location.io' }}</div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="ip2location-key">{{ t('ip2location.api_key') or 'API Key' }}</label>
          <input type="password" id="ip2location-key" style="width:100%">
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn btn-primary" id="btn-ip2location-save" style="font-size:12px">{{ t('ip2location.save') or 'Save' }}</button>
          <button class="btn btn-ghost" id="btn-ip2location-test" style="font-size:12px">{{ t('ip2location.test') or 'Test' }}</button>
        </div>
        <div id="ip2location-result" style="display:none"></div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="card-title">{{ t('webhooks.title') }}</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
        <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">{{ t('webhooks.subtitle') }}</div>
        <div id="webhooks-list"></div>
        <div style="display:flex;flex-direction:column;gap:8px;padding-top:8px;border-top:1px solid var(--border)">
          <input type="text" id="webhook-url" placeholder="{{ t('webhooks.url_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="500">
          <input type="text" id="webhook-desc" placeholder="{{ t('webhooks.description_placeholder') }}" style="width:100%;padding:8px 12px;font-size:12px" maxlength="255">
          <button class="btn btn-primary" id="btn-add-webhook" style="align-self:flex-start">
            {{ t('webhooks.add') }}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

{# ─── License Tab ─────────────────────────────────────── #}
<div class="settings-panel" data-settings-panel="license" style="display:none">
  <div class="two-col">
    <div>
      <div class="card">
        <div class="card-head">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          <span class="card-title">{{ t('license.status') }}</span>
          <span class="card-sub" style="padding:2px 8px;border-radius:var(--radius-xs);font-weight:600;{% if license.plan == 'pro' %}background:var(--green-lt);color:var(--green);border:1px solid var(--green-bd){% elif license.plan == 'lifetime' %}background:var(--accent-lt);color:var(--accent);border:1px solid var(--accent-bd){% else %}background:var(--bg-2);color:var(--text-2);border:1px solid var(--border){% endif %}">{{ t('license.plan_' + license.plan) }}</span>
        </div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:11px">
          <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
            <span style="font-size:13px;color:var(--text-2)">{{ t('license.plan') }}</span>
            <code style="font-family:var(--font-mono);font-size:12px;font-weight:600">{{ t('license.plan_' + license.plan) }}</code>
          </div>
          {% if license.expires_at %}
          <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
            <span style="font-size:13px;color:var(--text-2)">{{ t('license.valid_until') }}</span>
            <code style="font-family:var(--font-mono);font-size:12px">{{ license.expires_at }}</code>
          </div>
          {% endif %}
          {% if license.activations %}
          <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:11px;border-bottom:1px solid var(--border)">
            <span style="font-size:13px;color:var(--text-2)">{{ t('license.activations') }}</span>
            <code style="font-family:var(--font-mono);font-size:12px">{{ license.activations }} / {{ license.max_activations }}</code>
          </div>
          {% endif %}
          {% if license.license_key_masked %}
          <div style="display:flex;justify-content:space-between;align-items:center">
            <span style="font-size:13px;color:var(--text-2)">{{ t('license.key_label') }}</span>
            <code style="font-family:var(--font-mono);font-size:12px">{{ license.license_key_masked }}</code>
          </div>
          {% endif %}
          {% if license.unlicensed %}
          <div style="padding:12px 14px;background:var(--accent-lt);border-radius:var(--radius-xs);border:1px solid var(--accent-bd);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
            <span style="font-size:12px;color:var(--text-1)">{{ t('license.unlicensed_banner') }}</span>
            <a href="https://callmetechie.de/products/gatecontrol/pricing" target="_blank" rel="noopener" class="btn btn-primary" style="font-size:12px;padding:6px 14px;white-space:nowrap">{{ t('license.get_free_license') }}</a>
          </div>
          {% elif license.plan == 'community' %}
          <div style="padding:10px 14px;background:var(--bg-2);border-radius:var(--radius-xs);border:1px solid var(--border)">
            <span style="font-size:12px;color:var(--text-2)">{{ t('license.community_hint') }}</span>
          </div>
          {% endif %}
        </div>
      </div>

      <div class="card" style="margin-top:14px">
        <div class="card-head">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span class="card-title">{% if license.license_key_masked %}{{ t('license.manage') or 'Manage License' }}{% else %}{{ t('license.activate') }}{% endif %}</span>
        </div>
        <div class="card-body">
          <form id="license-form" autocomplete="off">
            {% if not license.license_key_masked %}
            <div class="form-group">
              <label class="form-label" for="license-key-input">{{ t('license.key_label') }}</label>
              <input type="text" id="license-key-input" name="license_key" placeholder="{{ t('license.key_placeholder') }}" autocomplete="off">
            </div>
            <div class="form-group">
              <label class="form-label" for="license-signing-key-input">{{ t('license.signing_key_label') }}</label>
              <input type="text" id="license-signing-key-input" name="signing_key" placeholder="{{ t('license.signing_key_placeholder') }}" autocomplete="off">
            </div>
            <div id="license-message" style="display:none"></div>
            <div style="display:flex;justify-content:flex-end;gap:8px;padding-top:4px">
              <button type="submit" class="btn btn-primary">{{ t('license.activate') }}</button>
            </div>
            {% else %}
            <div id="license-message" style="display:none"></div>
            <div style="display:flex;justify-content:flex-end;gap:8px;padding-top:4px">
              <button type="button" class="btn btn-ghost" style="color:var(--red);border-color:var(--red-bd)" id="license-remove-btn">{{ t('license.deactivate') or 'Deactivate' }}</button>
              <button type="button" class="btn btn-primary" id="license-refresh-btn">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                {{ t('license.refresh') or 'Refresh' }}
              </button>
            </div>
            {% endif %}
          </form>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        <span class="card-title">{{ t('license.features') }}</span>
      </div>
    <div class="card-body" style="padding:0">
      <div class="feature-grid">
      {% for key, value in license.features %}
      <div class="feature-cell">
        <span style="font-size:13px;color:var(--text-1)">{{ key | replace("_", " ") | capitalize }}</span>
        {% if value is number and value == -1 %}
          <span style="font-size:12px;color:var(--green);font-weight:600">{{ t('license.unlimited') }}</span>
        {% elif value is number and value == 0 %}
          <span style="font-size:12px;color:var(--text-3)">{{ t('license.feature_disabled') }}</span>
        {% elif value is number %}
          <code style="font-family:var(--font-mono);font-size:12px;font-weight:600">{{ value }}</code>
        {% elif value == true %}
          <span style="font-size:12px;color:var(--green);font-weight:600">{{ t('license.feature_enabled') }}</span>
        {% elif value == false %}
          <span style="font-size:12px;color:var(--text-3)">{{ t('license.feature_disabled') }}</span>
        {% endif %}
      </div>
      {% endfor %}
      </div>
    </div>
  </div>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/settings.js"></script>
<script src="/js/tokens.js"></script>
{% endblock %}
