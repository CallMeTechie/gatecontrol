        <input type="email" id="alerts-email" placeholder="admin@example.com" style="width:100%">
      </div>
      <div style="font-size:12px;font-weight:600;color:var(--text-2);margin-top:4px">{{ t('alerts.events_label') or 'Notify on these events:' }}</div>
