{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('peers.eyebrow') }}</div>
    <div class="page-title">
      {{ t('peers.title') }}
      {% if license.features.vpn_peers is defined and license.features.vpn_peers != -1 %}
        <span class="limit-badge {% if peerCount >= license.features.vpn_peers %}at-limit{% endif %}">
          {{ peerCount }} / {{ license.features.vpn_peers }}
        </span>
      {% endif %}
    </div>
    <div class="page-sub">{{ t('peers.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:4px">
    <button class="btn btn-ghost" id="btn-batch-peers">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      {{ t('batch.select') }}
    </button>
    <button class="btn btn-primary" id="btn-add-peer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('peers.add') }}
    </button>
  </div>
</div>

<!-- Stats strip -->
<div class="peers-stats" id="peers-stats">
  <div class="peers-stat">
    <div class="peers-stat-icon green">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    </div>
    <div>
      <div class="peers-stat-label">{{ t('peers.stats.gateways') or 'Gateways' }}</div>
      <div class="peers-stat-value"><span id="stat-gw-online">—</span> <span class="peers-stat-muted" id="stat-gw-total">/ 0</span></div>
    </div>
  </div>
  <div class="peers-stat">
    <div class="peers-stat-icon blue">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div>
      <div class="peers-stat-label">{{ t('peers.stats.clients') or 'Clients' }}</div>
      <div class="peers-stat-value"><span id="stat-cl-online">—</span> <span class="peers-stat-muted" id="stat-cl-total">/ 0</span></div>
    </div>
  </div>
  <div class="peers-stat">
    <div class="peers-stat-icon accent">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
    </div>
    <div>
      <div class="peers-stat-label">{{ t('peers.stats.gateway_routes') or 'Gateway-Routen' }}</div>
      <div class="peers-stat-value"><span id="stat-gw-routes">—</span></div>
    </div>
  </div>
</div>

<!-- ─── Home Gateways ──────────────────────────────────── -->
<section class="peers-section">
  <div class="peers-section-head">
    <div class="peers-section-title">
      <h2>{{ t('peers.gateways_section') or 'Home Gateways' }}</h2>
      <span class="peers-section-count" id="gw-section-count">—</span>
    </div>
  </div>
  <div id="gateways-container" class="gw-grid">
    <div class="gw-empty">{{ t('common.loading') }}</div>
  </div>
</section>

<!-- ─── Peers / Clients ─────────────────────────────────── -->
<section class="peers-section">
  <div class="peers-section-head">
    <div class="peers-section-title">
      <h2>{{ t('peers.clients_section') or 'Peers / Clients' }}</h2>
      <span class="peers-section-count" id="peers-section-count">—</span>
    </div>
  </div>

  <div class="peers-filter-bar">
    <div class="input-wrap" style="flex:1;min-width:220px">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="peer-search" placeholder="{{ t('peers.search') }}">
    </div>
    <select id="peer-group-filter" style="padding:7px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg-card);color:var(--text-1);min-width:140px">
      <option value="">{{ t('peer_groups.all') }}</option>
    </select>
    <div style="display:flex;gap:6px;margin-left:auto" id="peer-status-tags"></div>
  </div>
  <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px" id="peer-tag-filters"></div>

  <div class="card" style="padding:0">
    <div class="table-wrap peers-desktop">
      <table class="peer-table">
        <thead>
          <tr>
            <th class="batch-col" style="display:none;width:40px"><input type="checkbox" id="batch-select-all-peers" title="{{ t('batch.select_all') }}"></th>
            <th>{{ t('peers.name_device') }}</th>
            <th>{{ t('peers.wg_ip') }}</th>
            <th>{{ t('peers.last_contact') }}</th>
            <th>{{ t('peers.traffic') }}</th>
            <th>{{ t('peers.status') }}</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="peers-tbody">
          <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:40px">{{ t('common.loading') }}</td></tr>
        </tbody>
      </table>
    </div>
    <div class="peers-mobile" id="peers-mobile"></div>
  </div>
</section>

<!-- Batch action bar -->
<div id="batch-bar-peers" class="batch-bar" style="display:none">
  <span id="batch-bar-peers-count"></span>
  <div style="display:flex;gap:8px">
    <button class="btn btn-ghost" id="batch-enable-peers">{{ t('batch.enable') }}</button>
    <button class="btn btn-ghost" id="batch-disable-peers">{{ t('batch.disable') }}</button>
    <button class="btn btn-danger" id="batch-delete-peers">{{ t('batch.delete') }}</button>
    <button class="btn btn-ghost" id="batch-cancel-peers">{{ t('batch.cancel') }}</button>
  </div>
</div>

{% include theme + "/partials/modals/peer-add.njk" %}
{% include theme + "/partials/modals/peer-edit.njk" %}
{% include theme + "/partials/modals/peer-qr.njk" %}
{% include theme + "/partials/modals/peer-traffic.njk" %}
{% include theme + "/partials/modals/peer-gateway-tokens.njk" %}
{% include theme + "/partials/modals/confirm.njk" %}

<style nonce="{{ cspNonce }}">
/* ─── Stats strip ─── */
.peers-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; margin-bottom: 22px; }
.peers-stat { background: var(--bg-card, var(--bg-panel, #fff)); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 14px; display: flex; align-items: center; gap: 10px; }
.peers-stat-icon { width: 34px; height: 34px; border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.peers-stat-icon.green { background: var(--green-lt); color: var(--green); }
.peers-stat-icon.blue  { background: var(--blue-lt);  color: var(--blue); }
.peers-stat-icon.accent { background: var(--accent-lt); color: var(--accent); }
.peers-stat-label { font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.05em; font-family: var(--font-mono); }
.peers-stat-value { font-size: 16px; font-weight: 700; color: var(--text-1); }
.peers-stat-muted { color: var(--text-3); font-weight: 500; font-size: 13px; }

/* ─── Section heads ─── */
.peers-section { margin-bottom: 28px; }
.peers-section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
.peers-section-title { display: flex; align-items: baseline; gap: 10px; }
.peers-section-title h2 { margin: 0; font-size: 17px; font-weight: 700; }
.peers-section-count { font-family: var(--font-mono); color: var(--text-3); font-size: 12px; }
.peers-filter-bar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 10px; }

/* ─── Gateway grid / card ─── */
.gw-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
@media (min-width: 1100px) { .gw-grid.multi { grid-template-columns: 1fr 1fr; } }
.gw-empty { padding: 24px; text-align: center; color: var(--text-3); font-size: 13px; }
.gw-card { background: var(--bg-card, var(--bg-panel, #fff)); border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.04); transition: box-shadow 140ms; }
.gw-card.offline { border-color: var(--red-bd); }
.gw-card:hover { box-shadow: 0 2px 6px rgba(0,0,0,0.06); }
.gw-card-head { padding: 14px 18px; display: grid; grid-template-columns: auto 1fr auto; gap: 12px; align-items: center; cursor: pointer; user-select: none; }
.gw-card-head:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }
.gw-card.expanded .gw-card-head { border-bottom: 1px solid var(--border); }
.gw-avatar { width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--accent-lt); color: var(--accent); display: flex; align-items: center; justify-content: center; }
.gw-avatar svg { width: 22px; height: 22px; }
.gw-identity h3 { margin: 0; font-size: 16px; font-weight: 700; line-height: 1.2; }
.gw-identity-meta { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); margin-top: 3px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
.gw-identity-meta .sep { opacity: 0.4; }
.gw-status { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.version-chip { font-family: var(--font-mono); font-size: 10px; padding: 3px 7px; border-radius: var(--radius-xs); background: var(--bg-base, transparent); color: var(--text-2); border: 1px solid var(--border); }
.gw-chev { color: var(--text-3); transition: transform 160ms; display: flex; }
.gw-chev svg { width: 18px; height: 18px; }
.gw-card.expanded .gw-chev { transform: rotate(180deg); }

.status-pill { font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: 0.06em; padding: 4px 9px; border-radius: 999px; text-transform: uppercase; border: 1px solid transparent; display: inline-flex; align-items: center; }
.status-pill.online { background: var(--green-lt); color: var(--green); border-color: var(--green-bd); }
.status-pill.offline { background: var(--red-lt); color: var(--red); border-color: var(--red-bd); }
.status-pill.degraded { background: var(--amber-lt); color: var(--amber); border-color: var(--amber-bd); }
.status-pill .dot { display: inline-block; width: 6px; height: 6px; border-radius: 999px; margin-right: 5px; background: currentColor; animation: gw-pulse 2s infinite; }
@keyframes gw-pulse { 0%, 100% { opacity: 0.5; transform: scale(0.9); } 50% { opacity: 1; transform: scale(1.1); } }

.gw-card-body, .gw-actions { display: none; }
.gw-card.expanded .gw-card-body { display: grid; grid-template-columns: 1fr; }
.gw-card.expanded .gw-actions { display: flex; }
@media (min-width: 780px) {
  .gw-card.expanded .gw-card-body { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
}
.gw-section { padding: 14px 18px; }
.gw-section + .gw-section { border-top: 1px solid var(--border); }
@media (min-width: 780px) {
  .gw-section + .gw-section { border-top: 0; border-left: 1px solid var(--border); }
}
.gw-section-title { font-family: var(--font-mono); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 10px; }

.tele-rows { display: grid; grid-template-columns: auto 1fr; gap: 4px 14px; font-family: var(--font-mono); font-size: 11.5px; }
.tele-k { color: var(--text-3); text-transform: uppercase; letter-spacing: 0.05em; font-size: 10px; }
.tele-v { color: var(--text-1); word-break: break-all; }
.tele-bar { display: inline-block; width: 90px; height: 5px; background: var(--border); border-radius: 999px; overflow: hidden; vertical-align: middle; margin-left: 6px; }
.tele-bar-fill { display: block; height: 100%; background: var(--accent); }
.tele-bar-fill.warn { background: var(--amber); }
.tele-bar-fill.bad { background: var(--red); }

.gw-routes-list { display: flex; flex-direction: column; gap: 6px; }
.gw-route-row { display: grid; grid-template-columns: 14px 1fr auto auto; align-items: center; gap: 10px; padding: 6px 8px; border-radius: var(--radius-xs); background: var(--bg-base, transparent); border: 1px solid var(--border); font-size: 12px; }
.gw-route-dot { width: 8px; height: 8px; border-radius: 999px; background: var(--green); }
.gw-route-dot.down { background: var(--red); }
.gw-route-dot.check { background: var(--amber); }
.gw-route-domain { font-family: var(--font-mono); font-size: 12px; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.gw-route-target { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-3); white-space: nowrap; }
.gw-route-kind { font-family: var(--font-mono); font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: var(--radius-xs); background: var(--bg-card, var(--bg-panel)); color: var(--text-2); border: 1px solid var(--border); letter-spacing: 0.06em; }
.gw-route-kind.http { color: var(--blue); border-color: var(--blue-bd); background: var(--blue-lt); }
.gw-route-kind.l4 { color: var(--accent); border-color: var(--accent-bd); background: var(--accent-lt); }

.gw-actions { padding: 10px 14px; border-top: 1px solid var(--border); background: var(--bg-base, transparent); gap: 8px; flex-wrap: wrap; justify-content: flex-end; align-items: center; }
.gw-actions-left { margin-right: auto; font-size: 11px; color: var(--text-3); font-family: var(--font-mono); }
</style>
{% endblock %}

{% block scripts %}
<script src="/js/peers.js"></script>
{% endblock %}
