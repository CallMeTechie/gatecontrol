{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('rdp.eyebrow') }}</div>
    <div class="page-title">{{ t('rdp.title') }}</div>
    <div class="page-sub" id="rdp-subtitle">{{ t('rdp.subtitle', { count: '0' }) }}</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:4px">
    <div class="input-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="rdp-search" placeholder="{{ t('rdp.search') }}">
    </div>
    <div class="btn-group" id="rdp-view-toggle">
      <button class="btn btn-ghost btn-sm active" data-view="grid" title="{{ t('rdp.view_grid') }}">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      </button>
      <button class="btn btn-ghost btn-sm" data-view="list" title="{{ t('rdp.view_list') }}">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </button>
    </div>
    <div class="btn-group" id="rdp-status-filter">
      <button class="btn btn-ghost btn-sm active" data-filter="all">{{ t('rdp.filter_all') }}</button>
      <button class="btn btn-ghost btn-sm" data-filter="online">{{ t('rdp.filter_online') }}</button>
      <button class="btn btn-ghost btn-sm" data-filter="offline">{{ t('rdp.filter_offline') }}</button>
    </div>
    {% set rdpLocked = not license.hasFeature('remote_desktop') %}
    <button class="btn btn-primary" id="btn-add-rdp" {% if rdpLocked %}disabled{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('rdp.add') }}
    </button>
  </div>
</div>

{% if rdpLocked %}
<div class="alert alert-warning" style="margin-bottom:16px">
  {{ t('error.license.feature_not_available') }}
  <a href="https://callmetechie.de/products/gatecontrol/pricing" target="_blank" style="margin-left:8px;font-weight:600">Upgrade</a>
</div>
{% endif %}

{# -- Stats Cards -------------------------------------------- #}
<div class="stats-grid" id="rdp-stats" style="margin-bottom:20px">
  <div class="stat-card">
    <div class="stat-value" id="rdp-stat-total">0</div>
    <div class="stat-label">{{ t('rdp.stat_total') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rdp-stat-online" style="color:var(--success)">0</div>
    <div class="stat-label">{{ t('rdp.stat_online') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rdp-stat-offline" style="color:var(--danger)">0</div>
    <div class="stat-label">{{ t('rdp.stat_offline') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rdp-stat-sessions" style="color:var(--accent)">0</div>
    <div class="stat-label">{{ t('rdp.stat_active_sessions') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rdp-stat-maintenance">0</div>
    <div class="stat-label">{{ t('rdp.stat_maintenance') }}</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rdp-stat-rotation" style="color:var(--warning)">0</div>
    <div class="stat-label">{{ t('rdp.stat_rotation_due') }}</div>
  </div>
</div>

{# -- VM Grid / List ----------------------------------------- #}
<div class="card">
  <div class="card-body" id="rdp-grid">
    <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
  </div>
</div>

{# -- Connection History ------------------------------------- #}
<div class="card" style="margin-top:20px">
  <div class="card-head">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    <span class="card-title">{{ t('rdp.history') }}</span>
    <div style="margin-left:auto;display:flex;gap:8px">
      <button class="btn btn-ghost btn-sm" id="rdp-history-export-csv">CSV</button>
      <button class="btn btn-ghost btn-sm" id="rdp-history-export-json">JSON</button>
    </div>
  </div>
  <div class="card-body" id="rdp-history-list">
    <div style="font-size:13px;color:var(--text-3);padding:20px 0;text-align:center">{{ t('common.loading') }}</div>
  </div>
</div>

{# -- Create/Edit Modal -------------------------------------- #}
<div class="modal-overlay" id="rdp-modal-overlay">
  <div class="modal" id="rdp-modal" style="max-width:700px">
    <div class="modal-head">
      <span class="modal-title" id="rdp-modal-title">{{ t('rdp.add') }}</span>
      <button class="modal-close" id="rdp-modal-close">&times;</button>
    </div>
    <div class="modal-body" id="rdp-modal-body">
      {# Tabs #}
      <div class="tabs" id="rdp-form-tabs" style="margin-bottom:16px">
        <button class="tab active" data-panel="rdp-tab-connection">{{ t('rdp.tab_connection') }}</button>
        <button class="tab" data-panel="rdp-tab-auth">{{ t('rdp.tab_auth') }}</button>
        <button class="tab" data-panel="rdp-tab-display">{{ t('rdp.tab_display') }}</button>
        <button class="tab" data-panel="rdp-tab-resources">{{ t('rdp.tab_resources') }}</button>
        <button class="tab" data-panel="rdp-tab-performance">{{ t('rdp.tab_performance') }}</button>
        <button class="tab" data-panel="rdp-tab-session">{{ t('rdp.tab_session') }}</button>
        <button class="tab" data-panel="rdp-tab-wol">{{ t('rdp.tab_wol') }}</button>
        <button class="tab" data-panel="rdp-tab-advanced">{{ t('rdp.tab_advanced') }}</button>
      </div>

      <form id="rdp-form">
        <input type="hidden" id="rdp-edit-id">

        {# Connection Tab #}
        <div class="edit-route-panel" id="rdp-tab-connection">
          <div class="form-group"><label>{{ t('rdp.name') }} *</label><input type="text" id="rdp-name" required maxlength="100"></div>
          <div class="form-group"><label>{{ t('rdp.description') }}</label><input type="text" id="rdp-description"></div>
          <div class="form-row">
            <div class="form-group" style="flex:2"><label>{{ t('rdp.host') }} *</label><input type="text" id="rdp-host" required></div>
            <div class="form-group" style="flex:1"><label>{{ t('rdp.port') }}</label><input type="number" id="rdp-port" value="3389" min="1" max="65535"></div>
          </div>
          <div class="form-group">
            <label>{{ t('rdp.access_mode') }}</label>
            <select id="rdp-access-mode">
              <option value="internal">{{ t('rdp.access_internal') }}</option>
              <option value="external">{{ t('rdp.access_external') }}</option>
              <option value="both">{{ t('rdp.access_both') }}</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group" style="flex:2"><label>{{ t('rdp.external_hostname') }}</label><input type="text" id="rdp-external-hostname"></div>
            <div class="form-group" style="flex:1"><label>{{ t('rdp.external_port') }}</label><input type="number" id="rdp-external-port" min="1" max="65535"></div>
          </div>
          <div class="form-row">
            <div class="form-group" style="flex:2"><label>{{ t('rdp.gateway_host') }}</label><input type="text" id="rdp-gateway-host"></div>
            <div class="form-group" style="flex:1"><label>{{ t('rdp.gateway_port') }}</label><input type="number" id="rdp-gateway-port" value="443"></div>
          </div>
        </div>

        {# Auth Tab #}
        <div class="edit-route-panel" id="rdp-tab-auth">
          <div class="form-group">
            <label>{{ t('rdp.credentials') }}</label>
            <select id="rdp-credential-mode">
              <option value="none">{{ t('rdp.credential_none') }}</option>
              <option value="user_only">{{ t('rdp.credential_user') }}</option>
              <option value="full">{{ t('rdp.credential_full') }}</option>
            </select>
          </div>
          <div id="rdp-cred-fields" style="display:none">
            <div class="form-group"><label>{{ t('rdp.domain') }}</label><input type="text" id="rdp-domain"></div>
            <div class="form-group"><label>{{ t('rdp.username') }}</label><input type="text" id="rdp-username"></div>
            <div class="form-group" id="rdp-password-group"><label>{{ t('rdp.password') }}</label><input type="password" id="rdp-password"></div>
          </div>
        </div>

        {# Display Tab #}
        <div class="edit-route-panel" id="rdp-tab-display">
          <div class="form-group">
            <label>{{ t('rdp.resolution') }}</label>
            <select id="rdp-resolution-mode">
              <option value="fullscreen">{{ t('rdp.resolution_fullscreen') }}</option>
              <option value="fixed">{{ t('rdp.resolution_fixed') }}</option>
              <option value="dynamic">{{ t('rdp.resolution_dynamic') }}</option>
            </select>
          </div>
          <div class="form-row" id="rdp-resolution-fields" style="display:none">
            <div class="form-group"><label>{{ t('rdp.resolution_width') }}</label><input type="number" id="rdp-resolution-width"></div>
            <div class="form-group"><label>{{ t('rdp.resolution_height') }}</label><input type="number" id="rdp-resolution-height"></div>
          </div>
          <div class="form-group"><label><input type="checkbox" id="rdp-multi-monitor"> {{ t('rdp.multi_monitor') }}</label></div>
          <div class="form-group">
            <label>{{ t('rdp.color_depth') }}</label>
            <select id="rdp-color-depth">
              <option value="32" selected>32 bit</option>
              <option value="24">24 bit</option>
              <option value="16">16 bit</option>
              <option value="15">15 bit</option>
              <option value="8">8 bit</option>
            </select>
          </div>
        </div>

        {# Resources Tab #}
        <div class="edit-route-panel" id="rdp-tab-resources">
          <div class="form-group"><label><input type="checkbox" id="rdp-redirect-clipboard" checked> {{ t('rdp.clipboard') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-redirect-printers"> {{ t('rdp.printers') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-redirect-drives"> {{ t('rdp.drives') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-redirect-usb"> {{ t('rdp.usb') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-redirect-smartcard"> {{ t('rdp.smartcard') }}</label></div>
          <div class="form-group">
            <label>{{ t('rdp.audio') }}</label>
            <select id="rdp-audio-mode">
              <option value="local">{{ t('rdp.audio_local') }}</option>
              <option value="remote">{{ t('rdp.audio_remote') }}</option>
              <option value="off">{{ t('rdp.audio_off') }}</option>
            </select>
          </div>
        </div>

        {# Performance Tab #}
        <div class="edit-route-panel" id="rdp-tab-performance">
          <div class="form-group">
            <label>{{ t('rdp.network_profile') }}</label>
            <select id="rdp-network-profile">
              <option value="auto">Auto</option>
              <option value="lan">LAN</option>
              <option value="broadband">Broadband</option>
              <option value="modem">Modem</option>
            </select>
          </div>
          <div class="form-group"><label><input type="checkbox" id="rdp-nla" checked> {{ t('rdp.nla') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-disable-wallpaper"> {{ t('rdp.wallpaper') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-disable-themes"> {{ t('rdp.themes') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-disable-animations"> {{ t('rdp.animations') }}</label></div>
          <div class="form-group"><label>{{ t('rdp.bandwidth_limit') }} (kbps)</label><input type="number" id="rdp-bandwidth-limit" min="0"></div>
        </div>

        {# Session Tab #}
        <div class="edit-route-panel" id="rdp-tab-session">
          <div class="form-group"><label>{{ t('rdp.session_timeout') }} (s)</label><input type="number" id="rdp-session-timeout" min="0"></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-admin-session"> {{ t('rdp.admin_session') }}</label></div>
          <div class="form-group"><label>{{ t('rdp.remote_app') }}</label><input type="text" id="rdp-remote-app"></div>
          <div class="form-group"><label>{{ t('rdp.start_program') }}</label><input type="text" id="rdp-start-program"></div>
        </div>

        {# WoL Tab #}
        <div class="edit-route-panel" id="rdp-tab-wol">
          <div class="form-group"><label><input type="checkbox" id="rdp-wol-enabled"> {{ t('rdp.wol') }}</label></div>
          <div class="form-group"><label>{{ t('rdp.wol_mac') }}</label><input type="text" id="rdp-wol-mac" placeholder="AA:BB:CC:DD:EE:FF"></div>
        </div>

        {# Advanced Tab #}
        <div class="edit-route-panel" id="rdp-tab-advanced">
          <div class="form-group"><label><input type="checkbox" id="rdp-maintenance-enabled"> {{ t('rdp.maintenance') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-health-check" checked> {{ t('rdp.health_check') }}</label></div>
          <div class="form-group"><label><input type="checkbox" id="rdp-credential-rotation-enabled"> {{ t('rdp.credential_rotation') }}</label></div>
          <div class="form-group"><label>{{ t('rdp.rotation_days') }}</label><input type="number" id="rdp-rotation-days" value="90" min="1"></div>
          <div class="form-group"><label>{{ t('rdp.notes') }}</label><textarea id="rdp-notes" rows="3"></textarea></div>
          <div class="form-group"><label>{{ t('rdp.tags') }}</label><input type="text" id="rdp-tags" placeholder="tag1, tag2, ..."></div>
        </div>
      </form>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" id="rdp-modal-cancel">{{ t('common.cancel') }}</button>
      <button class="btn btn-primary" id="rdp-modal-save">{{ t('common.save') }}</button>
    </div>
  </div>
</div>

<script src="/js/rdp.js"></script>
{% endblock %}
