{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-eyebrow">{{ t('nav.access_control') }}</div>
    <div class="page-title">{{ t('users.title') }}</div>
    <div class="page-sub">{{ t('users.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="btn btn-ghost" id="btn-create-token-standalone">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      {{ t('users.create_token') }}
    </button>
    <button class="btn btn-primary" id="btn-add-user">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('users.add_user') }}
    </button>
  </div>
</div>

{# -- Unassigned tokens banner -- #}
<div id="unassigned-banner" style="display:none;padding:12px 16px;margin-bottom:16px;background:var(--amber-lt);border:1px solid var(--amber-bd);border-radius:var(--radius-sm);font-size:13px;color:var(--text-1)">
  <div style="display:flex;align-items:center;gap:8px">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <span><strong id="unassigned-count">0</strong> {{ t('users.unassigned_tokens') }}</span>
  </div>
  <div id="unassigned-list"></div>
</div>

{# -- Users table -- #}
<div class="card">
  <div class="card-head">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
    <span class="card-title">{{ t('users.title') }}</span>
  </div>
  <table class="peer-table" id="users-table">
    <thead>
      <tr>
        <th>{{ t('users.col_name') }}</th>
        <th>{{ t('users.col_role') }}</th>
        <th>{{ t('users.col_tokens') }}</th>
        <th>{{ t('users.col_peers') }}</th>
        <th>{{ t('users.col_status') }}</th>
        <th>{{ t('users.col_last_access') }}</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="users-tbody">
      <tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:20px 0">{{ t('common.loading') }}</td></tr>
    </tbody>
  </table>
</div>

{# -- Create/Edit User Modal -- #}
<div class="modal-overlay" id="user-modal-overlay" style="display:none">
  <div class="modal" style="width:540px">
    <div class="modal-head">
      <span class="modal-title" id="user-modal-title">{{ t('users.add_user') }}</span>
      <button class="modal-close" id="user-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <form id="user-form" autocomplete="off">
        <input type="hidden" id="user-edit-id">

        <div class="form-group">
          <label class="form-label" for="user-username">{{ t('users.username') }}</label>
          <input type="text" id="user-username" required maxlength="100">
        </div>

        <div class="form-group">
          <label class="form-label" for="user-display-name">{{ t('users.display_name') }}</label>
          <input type="text" id="user-display-name" maxlength="200">
        </div>

        <div class="form-group">
          <label class="form-label" for="user-email">{{ t('users.email') }}</label>
          <input type="email" id="user-email" maxlength="200">
        </div>

        <div class="form-group">
          <label class="form-label" for="user-role">{{ t('users.role') }}</label>
          <select id="user-role">
            <option value="user">{{ t('users.role_user') }}</option>
            <option value="admin">{{ t('users.role_admin') }}</option>
          </select>
        </div>

        <div class="form-group" id="user-password-group" style="display:none">
          <label class="form-label" for="user-password">{{ t('users.password') }}</label>
          <input type="password" id="user-password" maxlength="200" autocomplete="new-password">
          <small class="form-hint">{{ t('users.password_hint') }}</small>
        </div>

        <div id="user-form-error" class="form-error" style="display:none"></div>
      </form>

      {# Token section (edit mode only) #}
      <div id="user-tokens-section" style="display:none;border-top:1px solid var(--border);margin-top:14px;padding-top:14px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <span style="font-size:13px;font-weight:600;color:var(--text-1)">{{ t('users.tokens') }}</span>
          <button type="button" class="btn btn-ghost" style="font-size:12px;padding:4px 10px" id="btn-add-token">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            {{ t('users.add_token') }}
          </button>
        </div>
        <div id="user-tokens-list" style="display:flex;flex-direction:column;gap:6px"></div>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" id="user-modal-cancel">{{ t('config.cancel') }}</button>
      <button class="btn btn-primary" id="user-modal-save">{{ t('data.save') or 'Save' }}</button>
    </div>
  </div>
</div>

{# -- Token Wizard Modal (4 steps) -- #}
<div class="modal-overlay" id="token-modal-overlay" style="display:none;z-index:201">
  <div class="modal" style="width:500px;max-width:95vw">
    <div class="modal-head">
      <span class="modal-title" id="token-wizard-title">{{ t('users.create_token') }}</span>
      <span style="font-size:11px;color:var(--text-3);margin-left:auto" id="token-wizard-step">1/4</span>
      <button class="modal-close" id="token-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      {# Step 1: Name & User #}
      <div id="tw-step-1" class="tw-step">
        <div class="form-group">
          <label class="form-label" for="tw-name">{{ t('users.token_name') }}</label>
          <input type="text" id="tw-name" required maxlength="100" placeholder="z.B. Familien PC, Pixel Fold">
        </div>
        <div class="form-group">
          <label class="form-label" for="tw-user">{{ t('users.assign_to') or 'Zuweisen an' }}</label>
          <select id="tw-user"></select>
        </div>
      </div>

      {# Step 2: Scopes #}
      <div id="tw-step-2" class="tw-step" style="display:none">
        <div class="form-group">
          <label class="form-label">{{ t('users.token_scopes') }}</label>
          <div id="tw-presets" style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px">
            <label class="tw-preset-label"><input type="radio" name="tw-preset" value="client" checked> <strong>{{ t('users.preset_client') or 'Client-Zugriff' }}</strong> <span style="color:var(--text-3);font-size:11px">VPN + RDP + Services</span></label>
            <label class="tw-preset-label"><input type="radio" name="tw-preset" value="full-access"> <strong>{{ t('users.preset_full') or 'Vollzugriff' }}</strong> <span style="color:var(--text-3);font-size:11px">{{ t('users.preset_full_desc') or 'Alle Admin-Funktionen' }}</span></label>
            <label class="tw-preset-label"><input type="radio" name="tw-preset" value="read-only"> <strong>{{ t('users.preset_readonly') or 'Nur Lesen' }}</strong> <span style="color:var(--text-3);font-size:11px">Dashboard + Status</span></label>
            <label class="tw-preset-label"><input type="radio" name="tw-preset" value="custom"> <strong>{{ t('users.preset_custom') or 'Benutzerdefiniert' }}</strong></label>
          </div>
          <div id="tw-custom-scopes" style="display:none;flex-wrap:wrap;gap:6px"></div>
        </div>
      </div>

      {# Step 3: Peer & Expiry #}
      <div id="tw-step-3" class="tw-step" style="display:none">
        <div class="form-group">
          <label class="form-label" for="tw-peer">{{ t('users.bind_peer') or 'An Peer binden' }}</label>
          <select id="tw-peer"></select>
          <small class="form-hint">{{ t('users.bind_peer_hint') or 'Token wird beim ersten Connect automatisch gebunden' }}</small>
        </div>
        <div class="form-group">
          <label class="form-label">{{ t('users.token_expiry') }}</label>
          <div style="display:flex;flex-direction:column;gap:6px">
            <label><input type="radio" name="tw-expiry" value="" checked> {{ t('users.no_expiry') }}</label>
            <label><input type="radio" name="tw-expiry" value="30"> 30 {{ t('users.days') }}</label>
            <label><input type="radio" name="tw-expiry" value="90"> 90 {{ t('users.days') }}</label>
            <label><input type="radio" name="tw-expiry" value="365"> 1 {{ t('users.year') or 'Jahr' }}</label>
          </div>
        </div>
      </div>

      {# Step 4: Token Created #}
      <div id="tw-step-4" class="tw-step" style="display:none">
        <div style="padding:12px;background:var(--amber-lt);border:1px solid var(--amber-bd);border-radius:var(--radius-sm);margin-bottom:12px;font-size:12px">
          ⚠️ {{ t('users.token_warning') or 'Diesen Token jetzt kopieren — er wird nur einmal angezeigt!' }}
        </div>
        <div style="position:relative">
          <code id="tw-token-value" style="font-size:12px;word-break:break-all;display:block;padding:12px;padding-right:80px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font-mono);user-select:all"></code>
          <button class="btn btn-primary" id="tw-copy-btn" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);font-size:11px;padding:4px 12px">{{ t('common.copy') or 'Kopieren' }}</button>
        </div>
        <div id="tw-copy-confirm" style="display:none;color:var(--green);font-size:12px;margin-top:6px;font-weight:500">✓ {{ t('users.token_copied') or 'Kopiert!' }}</div>
      </div>

      <div id="token-form-error" class="form-error" style="display:none"></div>
    </div>
    <div class="modal-foot" id="tw-footer">
      <button class="btn btn-ghost" id="tw-cancel">{{ t('config.cancel') }}</button>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost" id="tw-back" style="display:none">← {{ t('common.back') or 'Zurück' }}</button>
        <button class="btn btn-primary" id="tw-next">{{ t('common.next') or 'Weiter' }} →</button>
      </div>
    </div>
  </div>
</div>

<style>
  .tw-step { animation: fadeIn .15s ease }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px) } to { opacity: 1; transform: none } }
  .tw-preset-label { display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;font-size:13px;transition:border-color .15s }
  .tw-preset-label:has(input:checked) { border-color:var(--accent);background:var(--accent-lt,rgba(59,130,246,.06)) }
  .tw-preset-label input { accent-color:var(--accent) }

  {# Mobile responsive: table → cards under 768px #}
  @media (max-width: 768px) {
    #users-table thead { display: none }
    #users-table, #users-table tbody, #users-table tr, #users-table td { display: block; width: 100% }
    #users-table tr { padding: 12px; border-bottom: 1px solid var(--border); position: relative }
    #users-table td { padding: 2px 0; border: none; font-size: 13px }
    #users-table td:first-child { font-size: 14px; margin-bottom: 4px }
    #users-table td:last-child { display: flex; gap: 8px; margin-top: 8px }
    .page-header { flex-direction: column; align-items: flex-start; gap: 12px }
  }
</style>

{% endblock %}

{% block scripts %}
<script src="/js/users.js"></script>
{% endblock %}
