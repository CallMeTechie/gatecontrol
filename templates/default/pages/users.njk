{% extends theme + "/layout.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-title">{{ t('users.title') }}</div>
    <div class="page-sub">{{ t('users.subtitle') }}</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:4px">
    <button class="btn btn-primary" id="btn-add-user">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      {{ t('users.add_user') }}
    </button>
  </div>
</div>

{# -- Unassigned tokens banner -- #}
<div class="alert alert-warning" id="unassigned-banner" style="display:none;margin-bottom:16px">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  <span id="unassigned-count">0</span> {{ t('users.unassigned_tokens') }}
</div>

{# -- Users table -- #}
<div class="card">
  <div class="card-body" style="padding:0;overflow-x:auto">
    <table class="data-table" id="users-table">
      <thead>
        <tr>
          <th>{{ t('users.col_name') }}</th>
          <th>{{ t('users.col_role') }}</th>
          <th>{{ t('users.col_tokens') }}</th>
          <th>{{ t('users.col_peers') }}</th>
          <th>{{ t('users.col_status') }}</th>
          <th>{{ t('users.col_last_access') }}</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="users-tbody">
        <tr><td colspan="7" style="text-align:center;color:var(--text-3);font-size:13px;padding:20px 0">{{ t('common.loading') }}</td></tr>
      </tbody>
    </table>
  </div>
</div>

{# -- Create/Edit User Modal -- #}
<div class="modal-overlay" id="user-modal-overlay" style="display:none">
  <div style="background:var(--bg-panel);border-radius:var(--radius);width:560px;max-width:95vw;max-height:85vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);position:relative">

    <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--bg-panel);z-index:1">
      <div style="font-family:var(--font-display);font-size:20px" id="user-modal-title">{{ t('users.add_user') }}</div>
      <button class="icon-btn" id="user-modal-close" style="width:32px;height:32px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <form id="user-form" autocomplete="off">
      <input type="hidden" id="user-edit-id">
      <div style="padding:20px 24px;display:flex;flex-direction:column;gap:14px">

        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="user-username">{{ t('users.username') }}</label>
          <input type="text" id="user-username" required maxlength="100" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
        </div>

        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="user-display-name">{{ t('users.display_name') }}</label>
          <input type="text" id="user-display-name" maxlength="200" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
        </div>

        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="user-email">{{ t('users.email') }}</label>
          <input type="email" id="user-email" maxlength="200" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
        </div>

        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="user-role">{{ t('users.role') }}</label>
          <select id="user-role" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
            <option value="user">{{ t('users.role_user') }}</option>
            <option value="admin">{{ t('users.role_admin') }}</option>
          </select>
        </div>

        <div class="form-group" id="user-password-group" style="margin-bottom:0;display:none">
          <label class="form-label" for="user-password">{{ t('users.password') }}</label>
          <input type="password" id="user-password" maxlength="200" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
          <div style="font-size:11px;color:var(--text-3);margin-top:4px">{{ t('users.password_hint') }}</div>
        </div>

        {# Token section (edit mode only) #}
        <div id="user-tokens-section" style="display:none;border-top:1px solid var(--border);padding-top:14px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
            <div style="font-size:13px;font-weight:600;color:var(--text-1)">{{ t('users.tokens') }}</div>
            <button type="button" class="btn btn-ghost btn-sm" id="btn-add-token">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              {{ t('users.add_token') }}
            </button>
          </div>
          <div id="user-tokens-list" style="display:flex;flex-direction:column;gap:6px">
          </div>
        </div>

      </div>
    </form>

    <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:var(--bg-panel)">
      <button class="btn btn-ghost" id="user-modal-cancel">{{ t('common.cancel') }}</button>
      <button class="btn btn-primary" id="user-modal-save">{{ t('common.save') }}</button>
    </div>

  </div>
</div>

{# -- Create Token Sub-Modal -- #}
<div class="modal-overlay" id="token-modal-overlay" style="display:none;z-index:1001">
  <div style="background:var(--bg-panel);border-radius:var(--radius);width:480px;max-width:95vw;max-height:80vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3);position:relative">

    <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--bg-panel);z-index:1">
      <div style="font-family:var(--font-display);font-size:18px">{{ t('users.create_token') }}</div>
      <button class="icon-btn" id="token-modal-close" style="width:32px;height:32px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div style="padding:20px 24px;display:flex;flex-direction:column;gap:14px">

      <div class="form-group" style="margin-bottom:0">
        <label class="form-label" for="new-token-name">{{ t('users.token_name') }}</label>
        <input type="text" id="new-token-name" required maxlength="100" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
      </div>

      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">{{ t('users.token_scopes') }}</label>
        <div id="new-token-scopes" style="display:flex;flex-wrap:wrap;gap:6px">
        </div>
      </div>

      <div class="form-group" style="margin-bottom:0">
        <label class="form-label" for="new-token-expiry">{{ t('users.token_expiry') }}</label>
        <select id="new-token-expiry" style="width:100%;padding:8px 12px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--bg-input);font-family:var(--font-ui);box-sizing:border-box">
          <option value="">{{ t('users.no_expiry') }}</option>
          <option value="30">30 {{ t('users.days') }}</option>
          <option value="90">90 {{ t('users.days') }}</option>
          <option value="365">365 {{ t('users.days') }}</option>
        </select>
      </div>

      <div id="token-created-result" style="display:none;padding:12px;background:var(--bg-base);border:1px solid var(--accent);border-radius:var(--radius-xs)">
        <div style="font-size:12px;font-weight:600;margin-bottom:6px">{{ t('users.token_created_copy') }}</div>
        <code id="token-created-value" style="font-size:12px;word-break:break-all;display:block;padding:8px;background:var(--bg-input);border-radius:var(--radius-xs);user-select:all"></code>
      </div>

    </div>

    <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:var(--bg-panel)">
      <button class="btn btn-ghost" id="token-modal-cancel">{{ t('common.cancel') }}</button>
      <button class="btn btn-primary" id="btn-create-token">{{ t('users.create_token') }}</button>
    </div>

  </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/users.js"></script>
{% endblock %}
