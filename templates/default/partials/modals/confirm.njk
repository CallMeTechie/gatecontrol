<div class="modal-overlay" id="modal-confirm" style="display:none">
  <div class="modal modal-sm">
    <div class="modal-head">
      <span class="modal-title">{{ t('common.confirm') }}</span>
      <button class="modal-close" data-close-modal>&times;</button>
    </div>
    <div class="modal-body">
      <p id="confirm-message" style="font-size:14px;line-height:1.6;color:var(--text-1)"></p>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" data-close-modal>{{ t('common.cancel') }}</button>
      <button class="btn btn-danger" id="btn-confirm-yes">{{ t('common.delete') }}</button>
    </div>
  </div>
</div>
