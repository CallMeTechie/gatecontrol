            <div class="toggle-group" id="edit-ip-filter-mode-group" style="margin-bottom:8px">
              <button type="button" class="toggle-btn on" data-value="whitelist">Whitelist</button>
              <button type="button" class="toggle-btn" data-value="blacklist">Blacklist</button>
            </div>
            <input type="hidden" id="edit-ip-filter-mode" value="whitelist">
          </div>
          <div id="edit-ip-filter-rules-list" style="display:flex;flex-direction:column;gap:4px;margin-bottom:8px"></div>
          <div style="display:flex;gap:6px">
            <input type="text" id="edit-ip-filter-input" placeholder="{{ t('ip_filter.add_placeholder') or 'IP, CIDR, or country code (DE)' }}" style="flex:1;padding:6px 10px;font-size:12px">
            <select id="edit-ip-filter-type" style="padding:6px 8px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs)">
              <option value="ip">IP</option>
              <option value="cidr">CIDR</option>
              <option value="country">{{ t('ip_filter.country') or 'Country' }}</option>
            </select>
            <button type="button" class="btn btn-ghost" id="edit-ip-filter-add" style="padding:6px 10px;font-size:12px">+</button>
          </div>
        </div>
        {% else %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm)" class="feature-locked" title="{{ t('license.requires_pro') }}">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('ip_filter.title') or 'IP Access Control' }} <span class="lock-icon"></span></div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('ip_filter.toggle_desc') or 'Restrict access by IP, CIDR range, or country' }}</div>
          </div>
          <div class="toggle" id="edit-route-ip-filter"></div>
        </div>
        {% endif %}
        {% if license.features.rate_limiting %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('routes.rate_limit') }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.rate_limit_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-rate-limit"></div>
        </div>
        <div id="edit-rate-limit-fields" style="display:none;margin-top:10px">
          <div style="display:flex;gap:8px">
            <div style="flex:1">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.rate_limit_requests') }}</label>
              <input type="number" id="edit-rate-limit-requests" value="100" min="1" max="100000" style="width:100%;padding:6px 10px;font-size:12px">
            </div>
            <div style="flex:1">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.rate_limit_window') }}</label>
              <select id="edit-rate-limit-window" style="width:100%;padding:6px 10px;font-size:12px;border:1px solid var(--border);border-radius:var(--radius-xs)">
                <option value="1s">{{ t('routes.rate_limit_window_1s') }}</option>
                <option value="1m">{{ t('routes.rate_limit_window_1m') }}</option>
                <option value="5m">{{ t('routes.rate_limit_window_5m') }}</option>
                <option value="1h">{{ t('routes.rate_limit_window_1h') }}</option>
              </select>
            </div>
          </div>
        </div>
        {% else %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px" class="feature-locked" title="{{ t('license.requires_pro') }}">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('routes.rate_limit') }} <span class="lock-icon"></span></div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.rate_limit_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-rate-limit"></div>
        </div>
        {% endif %}
        {% if license.features.retry_on_error %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('routes.retry') }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.retry_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-retry"></div>
        </div>
        <div id="edit-retry-fields" style="display:none;margin-top:10px">
          <div style="display:flex;gap:8px">
            <div style="flex:1">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.retry_count') }}</label>
              <input type="number" id="edit-retry-count" value="3" min="1" max="10" style="width:100%;padding:6px 10px;font-size:12px">
            </div>
            <div style="flex:1">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('routes.retry_status_codes') }}</label>
              <input type="text" id="edit-retry-status" value="502,503,504" style="width:100%;padding:6px 10px;font-size:12px" placeholder="502,503,504">
              <small class="form-hint" style="font-size:10px;color:var(--text-3)">{{ t('routes.retry_status_codes_hint') }}</small>
            </div>
          </div>
        </div>
        {% else %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px" class="feature-locked" title="{{ t('license.requires_pro') }}">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('routes.retry') }} <span class="lock-icon"></span></div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.retry_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-retry"></div>
        </div>
        {% endif %}
        {# ─── Circuit Breaker ─── #}
        {% if license.features.circuit_breaker %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('circuit_breaker.title') }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('circuit_breaker.toggle_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-circuit-breaker"></div>
        </div>
        <div id="edit-circuit-breaker-fields" style="display:none;margin-top:10px">
          <div id="edit-cb-requires-monitoring" style="display:none;font-size:11px;color:var(--amber);margin-bottom:8px;padding:6px 10px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-xs)">
            {{ t('circuit_breaker.requires_monitoring') }}
          </div>
          <div style="display:flex;gap:8px;margin-bottom:8px">
            <div style="flex:1">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('circuit_breaker.threshold') }}</label>
              <input type="number" id="edit-cb-threshold" value="5" min="1" max="100" style="width:100%;padding:6px 10px;font-size:12px">
              <small class="form-hint" style="font-size:10px;color:var(--text-3)">{{ t('circuit_breaker.threshold_hint') }}</small>
            </div>
            <div style="flex:1">
              <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('circuit_breaker.timeout') }}</label>
              <input type="number" id="edit-cb-timeout" value="30" min="5" max="3600" style="width:100%;padding:6px 10px;font-size:12px">
              <small class="form-hint" style="font-size:10px;color:var(--text-3)">{{ t('circuit_breaker.timeout_hint') }}</small>
            </div>
          </div>
          <div id="edit-cb-status-indicator" style="display:none;padding:6px 10px;border-radius:var(--radius-xs);font-size:12px;font-weight:600;text-align:center;margin-bottom:4px">
          </div>
        </div>
        {% else %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px" class="feature-locked" title="{{ t('license.requires_pro') }}">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('circuit_breaker.title') }} <span class="lock-icon"></span></div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('circuit_breaker.toggle_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-circuit-breaker"></div>
        </div>
        {% endif %}
        {% if license.features.request_mirroring %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('routes.mirror') }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.mirror_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-mirror"></div>
        </div>
        <div id="edit-mirror-fields" style="display:none;margin-top:10px">
          <div id="edit-mirror-targets-list" style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px"></div>
          <button type="button" class="btn btn-ghost" id="edit-mirror-add-target" style="font-size:12px">+ {{ t('routes.mirror_add_target') }}</button>
          <div id="edit-mirror-max-hint" style="display:none;font-size:11px;color:var(--text-3);margin-top:4px">{{ t('routes.mirror_max') }}</div>
        </div>
        {% else %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-top:14px" class="feature-locked" title="{{ t('license.requires_pro') }}">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('routes.mirror') }} <span class="lock-icon"></span></div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('routes.mirror_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-mirror"></div>
        </div>
        {% endif %}
      </div>

      {# ═══ TAB: Headers ═══════════════════════════════ #}
      <div class="edit-route-panel" data-panel="headers" style="display:none">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <div style="font-size:13px;font-weight:600">{{ t('headers.title') or 'Custom Headers' }}</div>
          <div style="display:flex;gap:6px">
            <select id="edit-headers-preset" style="padding:4px 8px;font-size:11px;border:1px solid var(--border);border-radius:var(--radius-xs)">
              <option value="">{{ t('headers.preset') or 'Presets' }}...</option>
              <option value="cors">{{ t('headers.preset_cors') or 'CORS Headers' }}</option>
              <option value="security">{{ t('headers.preset_security') or 'Security Headers' }}</option>
            </select>
          </div>
        </div>
        <div style="margin-bottom:16px">
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('headers.request_headers') or 'Request Headers' }}</label>
          <div id="edit-headers-request-list" style="display:flex;flex-direction:column;gap:4px;margin-bottom:8px"></div>
          <div style="display:flex;gap:6px">
            <input type="text" id="edit-headers-req-name" placeholder="{{ t('headers.name') or 'Header Name' }}" style="flex:1;padding:6px 10px;font-size:12px">
            <input type="text" id="edit-headers-req-value" placeholder="{{ t('headers.value') or 'Value' }}" style="flex:1;padding:6px 10px;font-size:12px">
            <button type="button" class="btn btn-ghost" id="edit-headers-req-add" style="padding:6px 10px;font-size:12px">+</button>
          </div>
        </div>
        <div>
          <label style="font-size:11px;font-family:var(--font-mono);color:var(--text-2);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;font-weight:600">{{ t('headers.response_headers') or 'Response Headers' }}</label>
          <div id="edit-headers-response-list" style="display:flex;flex-direction:column;gap:4px;margin-bottom:8px"></div>
          <div style="display:flex;gap:6px">
            <input type="text" id="edit-headers-resp-name" placeholder="{{ t('headers.name') or 'Header Name' }}" style="flex:1;padding:6px 10px;font-size:12px">
            <input type="text" id="edit-headers-resp-value" placeholder="{{ t('headers.value') or 'Value' }}" style="flex:1;padding:6px 10px;font-size:12px">
            <button type="button" class="btn btn-ghost" id="edit-headers-resp-add" style="padding:6px 10px;font-size:12px">+</button>
          </div>
        </div>
      </div>

      {# ═══ TAB: Branding ══════════════════════════════ #}
      <div class="edit-route-panel" data-panel="branding" style="display:none">
        <div class="form-group" style="margin-bottom:8px">
          <label class="form-label" for="edit-branding-title">{{ t('branding.page_title') or 'Title' }}</label>
          <input type="text" id="edit-branding-title" placeholder="GateControl" maxlength="100" style="width:100%">
        </div>
        <div class="form-group" style="margin-bottom:8px">
          <label class="form-label" for="edit-branding-text">{{ t('branding.text') or 'Welcome text' }}</label>
          <input type="text" id="edit-branding-text" placeholder="{{ t('branding.text_placeholder') or 'Please sign in to continue' }}" maxlength="255" style="width:100%">
        </div>
        <div class="form-group" style="margin-bottom:8px">
          <label class="form-label">{{ t('branding.logo') or 'Logo' }}</label>
          <div style="display:flex;align-items:center;gap:8px">
            <input type="file" id="edit-branding-logo-file" accept="image/*" style="font-size:12px;flex:1">
            <span id="edit-branding-logo-current" style="font-size:11px;color:var(--text-3)"></span>
            <button type="button" class="btn btn-ghost" id="edit-branding-logo-remove" style="font-size:11px;padding:3px 8px;color:var(--red);display:none">{{ t('common.delete') or 'Delete' }}</button>
          </div>
        </div>
        <div style="display:flex;gap:10px">
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label" for="edit-branding-color">{{ t('branding.color') or 'Accent color' }}</label>
            <input type="color" id="edit-branding-color" value="#0a6e4f" style="width:100%;height:32px;padding:2px;border:1px solid var(--border);border-radius:var(--radius-xs)">
          </div>
          <div class="form-group" style="flex:1;margin-bottom:0">
            <label class="form-label" for="edit-branding-bg">{{ t('branding.bg_color') or 'Background color' }}</label>
            <input type="color" id="edit-branding-bg" value="#f2f0eb" style="width:100%;height:32px;padding:2px;border:1px solid var(--border);border-radius:var(--radius-xs)">
          </div>
        </div>
        <div class="form-group" style="margin-top:8px">
          <label class="form-label">{{ t('branding.bg_image') or 'Background image (optional, overrides color)' }}</label>
          <div style="display:flex;align-items:center;gap:8px">
            <input type="file" id="edit-branding-bg-file" accept="image/*" style="flex:1">
            <span id="edit-branding-bg-current" style="font-size:11px;color:var(--text-3)"></span>
            <button type="button" class="btn btn-ghost" id="edit-branding-bg-remove" style="font-size:11px;padding:3px 8px;color:var(--red);display:none">{{ t('common.delete') or 'Delete' }}</button>
          </div>
        </div>
      </div>

      {# ═══ TAB: Debug ═══════════════════════════════ #}
      <div class="edit-route-panel" data-panel="debug" style="display:none">
        {% if license.features.request_debugging %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:14px">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('debug.title') }}</div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('debug.toggle_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-debug"></div>
        </div>
        <div id="edit-debug-container" style="display:none">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
            <div style="font-size:11px;color:var(--text-3);font-family:var(--font-mono)">{{ t('debug.auto_refresh') }}</div>
            <button type="button" class="btn btn-ghost" id="edit-debug-clear" style="font-size:11px;padding:4px 8px">{{ t('debug.clear') }}</button>
          </div>
          <div id="edit-debug-log" style="max-height:400px;overflow-y:auto;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px;font-family:var(--font-mono);font-size:11px">
            <div id="edit-debug-empty" style="color:var(--text-3);text-align:center;padding:20px 0">{{ t('debug.no_entries') }}</div>
          </div>
        </div>
        {% else %}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:14px" class="feature-locked" title="{{ t('license.requires_pro') }}">
          <div>
            <div style="font-size:13px;font-weight:600">{{ t('debug.title') }} <span class="lock-icon"></span></div>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">{{ t('debug.toggle_desc') }}</div>
          </div>
          <div class="toggle" id="edit-route-debug"></div>
        </div>
        {% endif %}
      </div>

      <div id="edit-route-error" class="form-error" style="display:none"></div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" data-close-modal>{{ t('common.cancel') }}</button>
      <button class="btn btn-primary" id="btn-edit-route-submit">{{ t('common.save') }}</button>
    </div>
  </div>
</div>
