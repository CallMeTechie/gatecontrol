<div class="modal-overlay" id="modal-peer-traffic" style="display:none">
  <div class="modal" style="max-width:600px">
    <div class="modal-head">
      <span class="modal-title" id="traffic-peer-title">Traffic</span>
      <button class="modal-close" data-close-modal>&times;</button>
    </div>
    <div class="modal-body">
      <div id="traffic-peer-total" style="font-family:var(--font-mono);font-size:13px;color:var(--text-2);margin-bottom:12px"></div>
      <div class="tabs" style="margin-bottom:12px">
        <button class="tab active" data-period="24h">24h</button>
        <button class="tab" data-period="7d">7d</button>
        <button class="tab" data-period="30d">30d</button>
      </div>
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;overflow:hidden">
        <svg id="traffic-peer-chart" viewBox="0 0 520 120" style="width:100%;height:120px"></svg>
      </div>
      <div style="display:flex;gap:16px;justify-content:center;margin-top:8px;font-size:11px;color:var(--text-3)">
        <span><span style="display:inline-block;width:10px;height:3px;background:#0a6e4f;border-radius:2px;vertical-align:middle;margin-right:4px"></span>{{ t('peers.upload') or 'Upload' }}</span>
        <span><span style="display:inline-block;width:10px;height:3px;background:#1d4ed8;border-radius:2px;vertical-align:middle;margin-right:4px"></span>{{ t('peers.download') or 'Download' }}</span>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" data-close-modal>{{ t('common.close') or 'Close' }}</button>
    </div>
  </div>
</div>
