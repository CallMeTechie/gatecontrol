<header class="topbar">
  <a href="/dashboard" class="topbar-logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/>
      </svg>
    </div>
    <div>
      <div class="logo-wordmark">{{ appName }}</div>
    </div>
  </a>

  <div class="topbar-spacer"></div>

  <div class="topbar-status" id="wg-status">
    <div class="pulse-dot"></div>
    <span>{{ t('status.wg_active') }}</span>
  </div>

  <div class="topbar-divider"></div>

  <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-3)">
    {{ wgHost }}
  </div>

  <div class="topbar-divider"></div>

  <div class="topbar-lang" id="lang-switcher" style="display:flex;gap:2px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius-sm);padding:2px">
    {% for lang in availableLanguages %}
    <button class="lang-btn {{ 'active' if lang == language }}" data-lang="{{ lang }}" style="padding:3px 8px;border:none;background:{{ 'var(--bg-panel)' if lang == language else 'transparent' }};border-radius:3px;font-family:var(--font-mono);font-size:10px;font-weight:600;cursor:pointer;color:{{ 'var(--text-1)' if lang == language else 'var(--text-3)' }};text-transform:uppercase;{{ 'box-shadow:var(--shadow)' if lang == language else '' }}">{{ lang }}</button>
    {% endfor %}
  </div>

  <div class="topbar-divider"></div>

  <div class="topbar-profile" id="topbar-profile">
    <button class="topbar-avatar" title="{{ user.username if user else 'Admin' }}">
      {{ (user.display_name[0] if user and user.display_name else 'A') | upper }}
    </button>
    <div class="topbar-dropdown" id="topbar-dropdown">
      <div class="topbar-dropdown-header">
        <div style="font-size:13px;font-weight:600;color:var(--text-1)">{{ user.display_name if user and user.display_name else user.username if user else 'Admin' }}</div>
        <div style="font-size:11px;color:var(--text-3);font-family:var(--font-mono)">{{ user.username if user else 'admin' }}</div>
      </div>
      <a href="/profile" class="topbar-dropdown-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {{ t('nav.profile') }}
      </a>
      <a href="/settings" class="topbar-dropdown-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        {{ t('nav.settings') }}
      </a>
      <div class="topbar-dropdown-divider"></div>
      <form action="/logout" method="POST" style="margin:0">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <button type="submit" class="topbar-dropdown-item topbar-dropdown-logout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          {{ t('nav.logout') }}
        </button>
      </form>
    </div>
  </div>
</header>

