<!DOCTYPE html>
<html lang="{{ language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#f2f0eb">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="{{ appName }}">
  <title>{{ title }} — {{ appName }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  {% block head %}{% endblock %}
</head>
<body>

{% include theme + "/partials/topbar.njk" %}

<div class="shell">
  {% include theme + "/partials/sidebar.njk" %}

  <main class="main" id="main-content">
    {% if flash.success %}
    <div class="flash flash-success">{{ flash.success }}</div>
    {% endif %}
    {% if flash.error %}
    <div class="flash flash-error">{{ flash.error }}</div>
    {% endif %}

    {% block content %}{% endblock %}
  </main>
</div>

{% include theme + "/partials/bottomnav.njk" %}
{% include theme + "/partials/fab.njk" %}

<script>
  window.GC = {
    csrfToken: '{{ csrfToken }}',
    language: '{{ language }}',
    baseUrl: '{{ baseUrl }}'
  };
</script>
<script src="/js/app.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
